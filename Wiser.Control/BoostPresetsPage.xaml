<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Wiser.Control"
             x:Class="Wiser.Control.BoostPresetsPage"
             Title="Boost presets">

    <Grid RowDefinitions="Auto,*"
          Padding="16,12"
          RowSpacing="10">

        <Label Grid.Row="0"
               Text="Presets appear in Mode > Boost. Changes save when you tap Save."
               FontSize="13"
               LineBreakMode="WordWrap"
               TextColor="{AppThemeBinding Light={StaticResource SubtleTextLight}, Dark={StaticResource SubtleTextDark}}" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="PresetHost"
                                 Spacing="12" />
        </ScrollView>
    </Grid>
</ContentPage>

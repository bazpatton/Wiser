# Copy to .env and edit. Docker Compose loads .env automatically.

WISER_IP=192.168.1.50
WISER_SECRET=your-hub-secret

# Leave empty for graphs-only (no ntfy).
NTFY_TOPIC=

INTERVAL_SEC=300

# ntfy latch alerts (see scripts/wiser_ntfy_monitor.py). Set ABOVE to 0 to disable high; BELOW=0 disables low.
TEMP_ALERT_ABOVE_C=22
TEMP_ALERT_BELOW_C=14

# SQLite retention
RETENTION_DAYS=60

# Optional: outdoor air temp for context (Open-Meteo, no API key). Set both or neither.
# OPEN_METEO_LAT=51.5074
# OPEN_METEO_LON=-0.1278

# Published port when using docker compose (host side)
HOST_PORT=8080

# Copy to .env for docker compose. Same variable names as the Python image.

WISER_IP=192.168.1.50
WISER_SECRET=your-hub-secret

NTFY_TOPIC=
# Used for temperature alerts and Settings → gas meter reading reminders (ntfy on your phone).
INTERVAL_SEC=300
TEMP_ALERT_ABOVE_C=22
TEMP_ALERT_BELOW_C=14
RETENTION_DAYS=60
TIME_ZONE=Europe/London

# OPEN_METEO_LAT=51.5074
# OPEN_METEO_LON=-0.1278

OCR_PYTHON_PATH=/opt/ocr-venv/bin/python
# OCR_SCRIPT_PATH=./scripts/gas_receipt_ocr.py
OCR_TIMEOUT_SEC=120
# Persistent EasyOCR worker (models load once; scans are much faster). Set false to use one-shot gas_receipt_ocr.py per scan.
OCR_PERSISTENT_WORKER=true
OCR_WORKER_URL=http://127.0.0.1:8765
# Spawn uvicorn ocr_worker.py with the app. Set false if you run the worker separately.
OCR_WORKER_AUTO_START=true
# First startup waits for EasyOCR / model load (seconds).
OCR_WORKER_STARTUP_TIMEOUT_SEC=180

HOST_PORT=8080

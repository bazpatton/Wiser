# Copy to .env for docker compose. Same variable names as the Python image.

WISER_IP=192.168.1.50
WISER_SECRET=your-hub-secret

NTFY_TOPIC=
# Used for temperature alerts and Settings → gas meter reading reminders (ntfy on your phone).
INTERVAL_SEC=300
TEMP_ALERT_ABOVE_C=22
TEMP_ALERT_BELOW_C=14
RETENTION_DAYS=60
TIME_ZONE=Europe/London

# OPEN_METEO_LAT=51.5074
# OPEN_METEO_LON=-0.1278

HOST_PORT=8080

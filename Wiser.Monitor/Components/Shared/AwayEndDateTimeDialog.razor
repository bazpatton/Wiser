@using System.Globalization
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudSelect T="int?"
                       Label="Quick set (hours from now)"
                       Value="_quickHours"
                       ValueChanged="OnQuickHoursChanged"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Clearable="true"
                       Placeholder="Choose a preset…">
                <MudSelectItem T="int?" Value="@((int?)1)">1 hour</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)3)">3 hours</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)6)">6 hours</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)9)">9 hours</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)12)">12 hours</MudSelectItem>
                <MudSelectItem T="int?" Value="@((int?)24)">24 hours</MudSelectItem>
            </MudSelect>
            <MudDivider />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Or choose an exact end time (local):
            </MudText>
            <MudDatePicker @bind-Date="_endDate"
                           Label="End date"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense" />
            <MudTimePicker @bind-Time="_endTime"
                           Label="End time"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense" />
            @if (!string.IsNullOrWhiteSpace(_validationMessage))
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    @_validationMessage
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm">Set away mode</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DateTime? InitialDate { get; set; }
    [Parameter] public TimeSpan? InitialTime { get; set; }
    [Parameter] public TimeZoneInfo Zone { get; set; } = TimeZoneInfo.Local;

    private DateTime? _endDate;
    private TimeSpan? _endTime;
    private int? _quickHours;
    private string? _validationMessage;

    protected override void OnInitialized()
    {
        var nowLocal = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, Zone);
        var defaultEnd = nowLocal.AddHours(1);
        _endDate = InitialDate ?? defaultEnd.Date;
        _endTime = InitialTime ?? defaultEnd.TimeOfDay;
    }

    private void OnQuickHoursChanged(int? hours)
    {
        _quickHours = hours;
        _validationMessage = null;
        if (hours is null)
            return;

        var target = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, Zone).AddHours(hours.Value);
        _endDate = target.Date;
        _endTime = target.TimeOfDay;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm()
    {
        if (_endDate is null || _endTime is null)
        {
            _validationMessage = "Pick end date and time.";
            return;
        }

        var localWall = _endDate.Value.Date + _endTime.Value;
        var localUnspecified = DateTime.SpecifyKind(localWall, DateTimeKind.Unspecified);
        var nowLocal = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, Zone);
        if (localUnspecified <= nowLocal.DateTime)
        {
            _validationMessage = "End must be in the future (local time).";
            return;
        }

        MudDialog.Close(DialogResult.Ok(localUnspecified));
    }
}

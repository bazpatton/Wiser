@using System.Globalization
@implements IDisposable
@inject MonitorOptions Options
@inject TemperatureStore Store
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@* MudBlazor 9+: custom ActivatorContent must call MenuContext.ToggleAsync. *@
<MudMenu AnchorOrigin="Origin.BottomRight"
         MaxHeight="400"
         OpenChanged="OnOpenChanged">
    <ActivatorContent>
        @* Badge = unread only (after user opens menu or /notifications, count hides until new alerts). *@
        <MudBadge Content="@BadgeContent"
                  Color="Color.Error"
                  Overlap="true"
                  Bordered="true"
                  Visible="@(_unreadCount > 0)">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                           Color="Color.Inherit"
                           Class="touch-target-icon"
                           OnClick="@context.ToggleAsync"
                           aria-label="Notification history" />
        </MudBadge>
    </ActivatorContent>
    <ChildContent>
        @if (_recent.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="px-4 py-2 mud-text-secondary">No notifications recorded yet.</MudText>
        }
        else
        {
            @foreach (var row in _recent)
            {
                <div class="d-flex align-start gap-1 px-3 py-2" style="max-width: 22rem;">
                    <div class="flex-grow-1" style="min-width: 0;">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@FormatSent(row.SentTs) · @row.Kind</MudText>
                        <MudText Typo="Typo.body2">@row.Title</MudText>
                    </div>
                    <div @onclick:stopPropagation="true">
                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       title="Delete"
                                       aria-label="Delete notification"
                                       OnClick="@(() => DeleteRecentAsync(row))" />
                    </div>
                </div>
            }
        }
        <MudDivider />
        <MudMenuItem Icon="@Icons.Material.Filled.List" Href="/notifications">View all</MudMenuItem>
    </ChildContent>
</MudMenu>

@code {
    private int _unreadCount;
    private IReadOnlyList<NtfyNotificationRow> _recent = [];
    private TimeZoneInfo DisplayZone => TimeZoneResolver.Resolve(Options.TimeZoneId);

    private string BadgeContent => _unreadCount > 99 ? "99+" : _unreadCount.ToString(CultureInfo.InvariantCulture);

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        Refresh();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(RefreshBadgeUiAsync);
    }

    private Task RefreshBadgeUiAsync()
    {
        Refresh();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnOpenChanged(bool open)
    {
        if (open)
        {
            Store.MarkNtfyNotificationsViewedNow();
            Refresh();
        }
    }

    private void Refresh()
    {
        _unreadCount = Store.CountNtfyNotificationsUnread();
        _recent = Store.ListNtfyNotifications(10);
    }

    private string FormatSent(long sentTsUtc)
    {
        var local = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(sentTsUtc), DisplayZone);
        return local.ToString("g", CultureInfo.CurrentCulture);
    }

    private async Task DeleteRecentAsync(NtfyNotificationRow row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Delete notification?",
            $"Remove the entry sent {FormatSent(row.SentTs)} ({row.Kind})? This cannot be undone.",
            yesText: "Delete",
            noText: null,
            cancelText: "Cancel");
        if (confirm is not true)
            return;

        if (Store.DeleteNtfyNotification(row.Id))
        {
            Refresh();
            Snackbar.Add("Notification removed.", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
    }
}

@using System.Globalization
@implements IDisposable
@inject TemperatureStore Store
@inject NavigationManager Nav

@* MudBlazor 9+: custom ActivatorContent must call MenuContext.ToggleAsync. *@
<MudMenu AnchorOrigin="Origin.BottomRight"
         MaxHeight="400"
         OpenChanged="OnOpenChanged">
    <ActivatorContent>
        @* Badge = unread only (after user opens menu or /notifications, count hides until new alerts). *@
        <MudBadge Content="@BadgeContent"
                  Color="Color.Error"
                  Overlap="true"
                  Bordered="true"
                  Visible="@(_unreadCount > 0)">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                           Color="Color.Inherit"
                           Class="touch-target-icon"
                           OnClick="@context.ToggleAsync"
                           aria-label="Notification history" />
        </MudBadge>
    </ActivatorContent>
    <ChildContent>
        @if (_recent.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="px-4 py-2 mud-text-secondary">No notifications recorded yet.</MudText>
        }
        else
        {
            @foreach (var row in _recent)
            {
                <div class="px-3 py-2" style="max-width: 22rem;">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@FormatLocal(row.SentTs) · @row.Kind</MudText>
                    <MudText Typo="Typo.body2">@row.Title</MudText>
                </div>
            }
        }
        <MudDivider />
        <MudMenuItem Icon="@Icons.Material.Filled.List" Href="/notifications">View all</MudMenuItem>
    </ChildContent>
</MudMenu>

@code {
    private int _unreadCount;
    private IReadOnlyList<NtfyNotificationRow> _recent = [];

    private string BadgeContent => _unreadCount > 99 ? "99+" : _unreadCount.ToString(CultureInfo.InvariantCulture);

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        Refresh();
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(RefreshBadgeUiAsync);
    }

    private Task RefreshBadgeUiAsync()
    {
        Refresh();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void OnOpenChanged(bool open)
    {
        if (open)
        {
            Store.MarkNtfyNotificationsViewedNow();
            Refresh();
        }
    }

    private void Refresh()
    {
        _unreadCount = Store.CountNtfyNotificationsUnread();
        _recent = Store.ListNtfyNotifications(10);
    }

    private static string FormatLocal(long sentTsUtc)
    {
        var local = DateTimeOffset.FromUnixTimeSeconds(sentTsUtc).ToLocalTime();
        return local.ToString("g", CultureInfo.CurrentCulture);
    }
}

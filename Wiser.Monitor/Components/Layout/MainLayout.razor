@inherits LayoutComponentBase
@implements IDisposable

@inject NavigationManager Navigation
@inject IJSRuntime JS

<MudThemeProvider @ref="_themeProvider"
                  Theme="_theme"
                  @bind-IsDarkMode="_isDarkMode"
                  ObserveSystemDarkModeChange="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@(_compactMode ? "compact-ui" : string.Empty)">
    <MudAppBar Elevation="0" Class="top-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Class="mobile-nav-button touch-target-icon"
                       OnClick="ToggleDrawer"
                       aria-label="Open menu" />
        <MudText Typo="Typo.h6" Class="app-title">Wiser Monitor</MudText>
        <MudHidden Breakpoint="Breakpoint.MdAndDown">
            <MudStack Row="true" Spacing="1" Class="desktop-nav">
                <MudButton Href="/" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Home">Home</MudButton>
                <MudButton Href="/rooms" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.MeetingRoom">Rooms</MudButton>
                <MudButton Href="/devices" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Memory">Devices</MudButton>
                <MudButton Href="/schedules" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.CalendarMonth">Schedules</MudButton>
                <MudButton Href="/gas-meter" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.LocalGasStation">Gas meter</MudButton>
                <MudButton Href="/charts" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.ShowChart">Charts</MudButton>
                <NotificationMenu />
                <MudButton Href="/settings" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Settings">Settings</MudButton>
            </MudStack>
        </MudHidden>
        <MudSpacer />
        <MudHidden Breakpoint="Breakpoint.MdAndDown" Invert="true">
            <NotificationMenu />
        </MudHidden>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       Class="touch-target-icon"
                       OnClick="ToggleDarkModeAsync"
                       aria-label="@(_isDarkMode ? "Switch to light theme" : "Switch to dark theme")" />
        <MudIconButton Icon="@(_compactMode ? Icons.Material.Filled.DensityMedium : Icons.Material.Filled.DensitySmall)"
                       Color="Color.Inherit"
                       Class="touch-target-icon"
                       OnClick="ToggleCompactModeAsync"
                       aria-label="@(_compactMode ? "Disable compact mode" : "Enable compact mode")" />
        <MudText Typo="Typo.body2" Class="fa-header desktop-tagline">
            <i class="fa-solid fa-temperature-half" aria-hidden="true"></i>
            Heat hub dashboard
        </MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Temporary"
               Anchor="Anchor.Left"
               OverlayAutoClose="true"
               Elevation="1"
               Class="mobile-drawer">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Navigate</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home" OnClick="@(() => CloseDrawer())">Home</MudNavLink>
            <MudNavLink Href="/rooms" Icon="@Icons.Material.Filled.MeetingRoom" OnClick="@(() => CloseDrawer())">Rooms</MudNavLink>
            <MudNavLink Href="/devices" Icon="@Icons.Material.Filled.Memory" OnClick="@(() => CloseDrawer())">Devices</MudNavLink>
            <MudNavLink Href="/schedules" Icon="@Icons.Material.Filled.CalendarMonth" OnClick="@(() => CloseDrawer())">Schedules</MudNavLink>
            <MudNavLink Href="/gas-meter" Icon="@Icons.Material.Filled.LocalGasStation" OnClick="@(() => CloseDrawer())">Gas meter</MudNavLink>
            <MudNavLink Href="/charts" Icon="@Icons.Material.Filled.ShowChart" OnClick="@(() => CloseDrawer())">Charts</MudNavLink>
            <MudNavLink Href="/notifications" Icon="@Icons.Material.Filled.Notifications" OnClick="@(() => CloseDrawer())">Notifications</MudNavLink>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings" OnClick="@(() => CloseDrawer())">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="main-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private const string ThemeStorageKey = "wiser-monitor-dark";
    private const string CompactStorageKey = "wiser-monitor-compact";

    private bool _drawerOpen;
    private bool _isDarkMode;
    private bool _themeHydrated;
    private bool _compactMode;
    private MudThemeProvider? _themeProvider;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2563eb",
            Secondary = "#0891b2",
            Background = "#f1f5f9",
            AppbarBackground = "#0f172a",
            AppbarText = "#f8fafc",
            Surface = "#ffffff",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#60a5fa",
            Secondary = "#22d3ee",
            Background = "#0f172a",
            Surface = "#1e293b",
            AppbarBackground = "#020617",
            AppbarText = "#f1f5f9",
            DrawerBackground = "#1e293b",
            DrawerText = "#e2e8f0",
            TextPrimary = "#f1f5f9",
            TextSecondary = "#94a3b8",
            TextDisabled = "#64748b",
            ActionDefault = "#94a3b8",
            Divider = "#334155",
            LinesDefault = "#475569",
            TableLines = "#334155",
            TableHover = "rgba(148, 163, 184, 0.08)",
            TableStriped = "rgba(148, 163, 184, 0.06)",
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "260px",
        },
    };

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _themeHydrated || _themeProvider is null)
            return;

        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", ThemeStorageKey);
            if (stored == "1")
                _isDarkMode = true;
            else if (stored == "0")
                _isDarkMode = false;
            else
                _isDarkMode = await _themeProvider.GetSystemDarkModeAsync();

            var compactStored = await JS.InvokeAsync<string?>("localStorage.getItem", CompactStorageKey);
            _compactMode = compactStored == "1";

            _themeHydrated = true;
            StateHasChanged();
        }
        catch
        {
            _themeHydrated = true;
        }
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
    }

    private async Task ToggleDarkModeAsync()
    {
        _isDarkMode = !_isDarkMode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", ThemeStorageKey, _isDarkMode ? "1" : "0");
        }
        catch
        {
            // ignore (e.g. prerender without JS)
        }
    }

    private async Task ToggleCompactModeAsync()
    {
        _compactMode = !_compactMode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", CompactStorageKey, _compactMode ? "1" : "0");
        }
        catch
        {
            // ignore
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        // Ensure temporary drawer closes after any navigation.
        _drawerOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}

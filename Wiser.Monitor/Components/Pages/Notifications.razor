@page "/notifications"
@rendermode InteractiveServer
@using System.Globalization

@inject MonitorOptions Options
@inject TemperatureStore Store
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Wiser Monitor - Notifications</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h5">
        <i class="fa-solid fa-bell"></i> ntfy notification history
    </MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary">
        Successful pushes to your configured ntfy topic. Opening this page clears the unread count on the bell. Identical messages within a few minutes are not stored or sent again. Temperature alerts repeat only after the room returns below/above the threshold and crosses again. Failed sends are not listed.
    </MudText>

    @if (_rows.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Dense="true">No notifications recorded yet.</MudAlert>
    }
    else
    {
        <MudTable T="NtfyNotificationRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_rows">
            <HeaderContent>
                <MudTh>Sent (local)</MudTh>
                <MudTh>Kind</MudTh>
                <MudTh>Title</MudTh>
                <MudTh>Message</MudTh>
                <MudTh Style="width: 3rem;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Sent">@FormatSent(context.SentTs)</MudTd>
                <MudTd DataLabel="Kind">@context.Kind</MudTd>
                <MudTd DataLabel="Title">@context.Title</MudTd>
                <MudTd DataLabel="Message" Style="white-space: pre-wrap; max-width: 28rem;">@context.Message</MudTd>
                <MudTd DataLabel="">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   title="Delete this notification"
                                   aria-label="Delete notification"
                                   OnClick="@(() => DeleteRowAsync(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudStack>

@code {
    private readonly List<NtfyNotificationRow> _rows = [];
    private TimeZoneInfo DisplayZone => TimeZoneResolver.Resolve(Options.TimeZoneId);

    protected override void OnInitialized()
    {
        Store.MarkNtfyNotificationsViewedNow();
        ReloadRows();
    }

    private string FormatSent(long sentTsUtc)
    {
        var local = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(sentTsUtc), DisplayZone);
        return local.ToString("g", CultureInfo.CurrentCulture);
    }

    private async Task DeleteRowAsync(NtfyNotificationRow row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Delete notification?",
            $"Remove the entry sent {FormatSent(row.SentTs)} ({row.Kind})? This cannot be undone.",
            yesText: "Delete",
            noText: null,
            cancelText: "Cancel");
        if (confirm is not true)
            return;

        if (Store.DeleteNtfyNotification(row.Id))
        {
            ReloadRows();
            Snackbar.Add("Notification removed.", Severity.Success);
        }
    }

    private void ReloadRows()
    {
        _rows.Clear();
        _rows.AddRange(Store.ListNtfyNotifications(200));
    }
}

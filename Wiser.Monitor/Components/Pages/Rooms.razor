@page "/rooms"
@inject MonitorOptions Options
@inject WiserHubFetch Hub
@inject TemperatureStore Store
@inject ISnackbar Snackbar

<PageTitle>Wiser Monitor - Rooms</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4 page-header-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h5">
                <i class="fa-solid fa-house-chimney-window"></i> Rooms
            </MudText>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="RefreshAsync">
                Refresh
            </MudButton>
        </MudStack>
        @if (!string.IsNullOrWhiteSpace(_actionMessage))
        {
            <MudAlert Severity="@(_actionError ? Severity.Error : Severity.Success)" Dense="true" Class="mt-3">
                @_actionMessage
            </MudAlert>
        }
    </MudPaper>

    @if (_loading)
    {
        <MudPaper Class="pa-6 card-soft">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Class="mt-2">Loading room data...</MudText>
        </MudPaper>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Warning">@_loadError</MudAlert>
        }
        <MudGrid>
            <MudItem xs="12">
                <MudPaper Class="pa-4 status-card">
                    <MudText Typo="Typo.h6">
                        <i class="fa-solid fa-fire-flame-curved"></i>
                        Heating status
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mt-2" Wrap="Wrap.Wrap">
                        <MudChip T="string" Color="@(_heatingRelayOn ? Color.Error : Color.Default)" Variant="Variant.Filled">
                            Boiler relay: @(_heatingRelayOn ? "On" : "Off")
                        </MudChip>
                        <MudChip T="string" Color="@(_heatingActive ? Color.Warning : Color.Success)" Variant="Variant.Filled">
                            Heating active: @(_heatingActive ? "Yes" : "No")
                        </MudChip>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @foreach (var room in _rooms.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase))
            {
                <MudItem xs="12" sm="6" lg="4">
                    <MudPaper Class="pa-4 room-card">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudText Typo="Typo.h6">@room.Name</MudText>
                            <MudChip T="string" Color="@(room.HeatDemand != 0 ? Color.Error : Color.Info)" Variant="Variant.Outlined">
                                @(room.HeatDemand != 0 ? "Calling heat" : "Idle")
                            </MudChip>
                        </MudStack>

                        <MudText Typo="Typo.body1" Class="mt-2">
                            <i class="fa-solid fa-temperature-half"></i>
                            Measured: <strong>@($"{room.TempC:F1} °C")</strong>
                        </MudText>
                        <MudText Typo="Typo.body2">
                            Target:
                            @(room.SetpointC is null ? "—" : $"{room.SetpointC:F1} °C")
                            · Valve:
                            @(room.PercentageDemand is null ? "—" : $"{room.PercentageDemand}%")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mt-1">
                            Mode: @(room.Mode ?? "Unknown")
                            · Radiator: @room.RadiatorState
                        </MudText>

                        <MudDivider Class="my-3" />
                        <MudMenu Dense="true" AnchorOrigin="Origin.BottomCenter">
                            <ActivatorContent>
                                <MudButton Variant="Variant.Outlined"
                                           Color="@(room.HeatDemand != 0 ? Color.Error : Color.Primary)"
                                           StartIcon="@Icons.Material.Filled.Settings"
                                           EndIcon="@Icons.Material.Filled.ArrowDropDown"
                                           FullWidth="true">
                                    Actions
                                </MudButton>
                            </ActivatorContent>
                            <ChildContent>
                                <MudMenu Label="Mode"
                                         StartIcon="@Icons.Material.Filled.Tune"
                                         IconColor="Color.Info"
                                         Dense="true">
                                    <ChildContent>
                                        <MudMenuItem Icon="@Icons.Material.Filled.AutoMode"
                                                     IconColor="Color.Info"
                                                     OnClick='@(() => ApplyModeAsync(room, "auto", null))'>
                                            Set Auto
                                        </MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Thermostat"
                                                     IconColor="Color.Info"
                                                     OnClick='@(() => ApplyModeAsync(room, "manual", 20.0))'>
                                            Set Manual (20.0 °C)
                                        </MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.PowerSettingsNew"
                                                     IconColor="Color.Warning"
                                                     OnClick='@(() => ApplyModeAsync(room, "off", null))'>
                                            Turn Off (manual low)
                                        </MudMenuItem>
                                    </ChildContent>
                                </MudMenu>
                                <MudMenu Label="Boost presets"
                                         StartIcon="@Icons.Material.Filled.LocalFireDepartment"
                                         IconColor="Color.Error"
                                         Dense="true">
                                    <ChildContent>
                                        @foreach (var preset in _boostPresets)
                                        {
                                            <MudMenuItem Icon="@Icons.Material.Filled.Bolt"
                                                         IconColor="Color.Error"
                                                         OnClick="@(() => ApplyBoostAsync(room, preset))">
                                                @preset.Name (@($"{preset.TemperatureC:F1} °C / {preset.Minutes}m"))
                                            </MudMenuItem>
                                        }
                                    </ChildContent>
                                </MudMenu>
                            </ChildContent>
                        </MudMenu>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>

@code {
    private readonly List<HubLiveRoom> _rooms = [];
    private readonly IReadOnlyList<BoostPresetInfo> _boostPresets =
    [
        new BoostPresetInfo("Quick", 21, 30),
        new BoostPresetInfo("Comfort", 22, 60),
        new BoostPresetInfo("Gentle", 20, 45),
    ];

    private bool _heatingRelayOn;
    private bool _heatingActive;
    private bool _loading = true;
    private string? _loadError;
    private string? _actionMessage;
    private bool _actionError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            using var doc = await Hub.FetchDomainDocumentAsync(Options, CancellationToken.None);
            var overview = HubLiveRoomsParser.ParseOverview(doc, _boostPresets);
            _rooms.Clear();
            _rooms.AddRange(overview.Rooms);
            _heatingRelayOn = overview.HeatingRelayOn;
            _heatingActive = overview.HeatingActive;
        }
        catch (Exception ex)
        {
            _loadError = $"Could not load live data: {ex.Message}. Showing latest stored values.";
            _rooms.Clear();
            _rooms.AddRange(
                Store.LatestByRoom()
                    .OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
                    .Select(x => new HubLiveRoom(
                        0,
                        x.Key,
                        "Saved",
                        x.Value.TempC,
                        x.Value.SetpointC,
                        x.Value.HeatDemand,
                        x.Value.HeatDemand != 0 ? "on" : "off",
                        x.Value.PercentageDemand,
                        null,
                        null,
                        null)));
            var latestSystem = Store.GetLatestSystem();
            _heatingRelayOn = latestSystem?.HeatingRelayOn ?? false;
            _heatingActive = latestSystem?.HeatingActive ?? _rooms.Any(r => r.HeatDemand != 0);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ApplyModeAsync(HubLiveRoom room, string mode, double? temp)
    {
        if (!EnsureLiveRoom(room))
            return;

        _actionMessage = null;
        _actionError = false;
        try
        {
            await Hub.PatchRoomModeAsync(Options, room.Id, mode, temp, CancellationToken.None);
            _actionMessage = $"Mode updated for {room.Name}.";
            Snackbar.Add(_actionMessage!, Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = true;
            _actionMessage = $"Action failed: {ex.Message}";
            Snackbar.Add(_actionMessage!, Severity.Error);
        }
    }

    private async Task ApplyBoostAsync(HubLiveRoom room, BoostPresetInfo preset)
    {
        if (!EnsureLiveRoom(room))
            return;

        _actionMessage = null;
        _actionError = false;
        try
        {
            await Hub.PatchRoomBoostAsync(Options, room.Id, preset.TemperatureC, preset.Minutes, CancellationToken.None);
            _actionMessage = $"Boost applied to {room.Name}.";
            Snackbar.Add(_actionMessage!, Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = true;
            _actionMessage = $"Action failed: {ex.Message}";
            Snackbar.Add(_actionMessage!, Severity.Error);
        }
    }

    private bool EnsureLiveRoom(HubLiveRoom room)
    {
        if (room.Id > 0)
            return true;

        _actionError = true;
        _actionMessage = "Live hub data required for control actions.";
        Snackbar.Add(_actionMessage, Severity.Warning);
        return false;
    }
}

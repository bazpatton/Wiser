@page "/rooms"
@rendermode InteractiveServer

@using Microsoft.JSInterop
@inject MonitorOptions Options
@inject WiserHubFetch Hub
@inject TemperatureStore Store
@inject RoomsLiveDataCache RoomsCache
@inject NavigationManager Nav
@inject IJSRuntime Js
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Wiser Monitor - Rooms</PageTitle>

<MudStack Spacing="3" Class="rooms-page">
    <MudPaper Class="pa-4 page-header-card">
        <MudStack Spacing="2">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.h5" Class="rooms-page-title">
                    <i class="fa-solid fa-house-chimney-window" aria-hidden="true"></i> Rooms
                </MudText>
                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                    <MudCheckBox T="bool"
                                 Label="Auto refresh"
                                 Value="_autoRefreshEnabled"
                                 ValueChanged="OnAutoRefreshChanged"
                                 Class="touch-control" />
                    <MudSelect T="int"
                               Label="Interval"
                               Value="_autoRefreshSec"
                               ValueChanged="OnAutoRefreshSecondsChanged"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                               Class="touch-control"
                               Disabled="@(!_autoRefreshEnabled)">
                        <MudSelectItem Value="15">15s</MudSelectItem>
                        <MudSelectItem Value="30">30s</MudSelectItem>
                        <MudSelectItem Value="60">60s</MudSelectItem>
                        <MudSelectItem Value="120">120s</MudSelectItem>
                    </MudSelect>
                    <MudButton Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               Class="touch-target"
                               Disabled="@_loading"
                               OnClick="@(() => RefreshAsync(fullPageLoader: true))">
                        Refresh
                    </MudButton>
                </MudStack>
            </MudStack>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@LastUpdatedText</MudText>
            @if (!string.IsNullOrWhiteSpace(_actionMessage))
            {
                <MudAlert Severity="@(_actionError ? Severity.Error : Severity.Success)" Dense="true">
                    @_actionMessage
                </MudAlert>
            }
        </MudStack>
    </MudPaper>

    @if (_loading && !_hasLoadedOnce)
    {
        <MudPaper Class="pa-4 card-soft">
            <MudSkeleton Height="44px" Width="72%" Animation="Animation.Wave" Class="mb-3" />
            <MudSkeleton Height="120px" Animation="Animation.Wave" Class="mb-3 rounded-lg" />
            <MudGrid Class="room-grid">
                @for (var i = 0; i < 6; i++)
                {
                    <MudItem xs="12" sm="6" lg="4">
                        <MudSkeleton Height="232px" Animation="Animation.Wave" Class="rounded-lg" />
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Warning" Dense="true">@_loadError</MudAlert>
        }

        <MudPaper Class="pa-3 filter-bar">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">Show</MudText>
            <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Style="width:100%;" Class="room-filter-group">
                <MudButton FullWidth="true"
                           Class="touch-target"
                           Variant="@(_heatOnlyFilter ? Variant.Outlined : Variant.Filled)"
                           OnClick="@(() => SetHeatFilter(false))">
                    All rooms
                </MudButton>
                <MudButton FullWidth="true"
                           Class="touch-target"
                           Variant="@(_heatOnlyFilter ? Variant.Filled : Variant.Outlined)"
                           OnClick="@(() => SetHeatFilter(true))">
                    Calling heat
                </MudButton>
            </MudButtonGroup>
        </MudPaper>

        @if (_isRefreshing)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="rounded" />
        }

        <MudGrid Class="room-grid">
            <MudItem xs="12">
                <MudPaper Class="pa-4 status-card">
                    <MudText Typo="Typo.h6">
                        <i class="fa-solid fa-fire-flame-curved" aria-hidden="true"></i>
                        Heating status
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mt-2" Wrap="Wrap.Wrap">
                        <MudTooltip Text="Heating channel relay state from the hub (boiler demand).">
                            <MudChip T="string" Color="@(_heatingRelayOn ? Color.Error : Color.Default)" Variant="Variant.Filled">
                                Boiler relay: @(_heatingRelayOn ? "On" : "Off")
                            </MudChip>
                        </MudTooltip>
                        <MudTooltip Text="Whether any zone is currently calling for heat (aggregate).">
                            <MudChip T="string" Color="@(_heatingActive ? Color.Warning : Color.Success)" Variant="Variant.Filled">
                                Heating active: @(_heatingActive ? "Yes" : "No")
                            </MudChip>
                        </MudTooltip>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @foreach (var room in FilteredRooms())
            {
                <MudItem xs="12" sm="6" lg="4">
                    <MudPaper Class="pa-3 room-card" @key="room.Id" id="@BuildRoomAnchorId(room.Name)">
                        <MudStack Spacing="2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap">
                                <MudText Typo="Typo.h6" Class="room-name">@room.Name</MudText>
                                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                    @if (IsOfflineTemperature(room.TempC))
                                    {
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Icon="@Icons.Material.Filled.SensorsOff"
                                                 Color="Color.Warning"
                                                 Variant="Variant.Filled">
                                            Offline
                                        </MudChip>
                                    }
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Icon="@(room.HeatDemand != 0 ? Icons.Material.Filled.LocalFireDepartment : Icons.Material.Filled.AcUnit)"
                                             Color="@(room.HeatDemand != 0 ? Color.Warning : Color.Info)"
                                             Variant="@(room.HeatDemand != 0 ? Variant.Filled : Variant.Outlined)">
                                        @(room.HeatDemand != 0 ? "Calling heat" : "Idle")
                                    </MudChip>
                                </MudStack>
                            </MudStack>

                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="room-temp-row">
                                <MudIcon Icon="@RoomClimateIcon(room)"
                                         Class="@RoomClimateIconClass(room)"
                                         Size="Size.Medium"
                                         aria-hidden="true" />
                                <MudText Typo="Typo.body1" Class="room-measured">
                                    @if (IsOfflineTemperature(room.TempC))
                                    {
                                        <strong>Offline</strong><span class="mud-text-secondary"> (sensor value -327.68 °C)</span>
                                    }
                                    else
                                    {
                                        <strong>@($"{room.TempC:F1}")</strong><span class="mud-text-secondary"> °C</span>
                                    }
                                </MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary room-target-line">
                                    <MudIcon Icon="@Icons.Material.Filled.DeviceThermostat" Class="room-inline-icon mud-text-secondary" Size="Size.Small" aria-hidden="true" />
                                    Target @WiserSetpointDisplay.FormatTargetForUi(room.SetpointC)
                                    <span class="room-meta-sep" aria-hidden="true">·</span>
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Class="room-inline-icon mud-text-secondary" Size="Size.Small" aria-hidden="true" />
                                    Valve @(room.PercentageDemand is null ? "—" : $"{room.PercentageDemand}%")
                                </MudText>
                            </MudStack>

                            @if (!string.IsNullOrWhiteSpace(FormatBoostSummary(room)))
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="py-2 room-override-alert">
                                    <MudStack Row="true"
                                              Justify="Justify.SpaceBetween"
                                              AlignItems="AlignItems.Center"
                                              Wrap="Wrap.Wrap"
                                              Spacing="2">
                                        <MudText Typo="Typo.body2" Class="room-override-alert-text">
                                            @FormatBoostSummary(room)
                                        </MudText>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   Class="touch-target"
                                                   StartIcon="@Icons.Material.Filled.CancelScheduleSend"
                                                   Disabled="@(room.Id <= 0 || _busyRoomId == room.Id)"
                                                   OnClick="@(() => CancelTimedOverrideAsync(room))">
                                            Cancel override
                                        </MudButton>
                                    </MudStack>
                                </MudAlert>
                            }

                            @if (room.Id <= 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="py-2">
                                    Hub offline — showing last saved readings. Controls need a live connection.
                                </MudAlert>
                            }

                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary room-section-label">
                                    <MudIcon Icon="@Icons.Material.Filled.Tune" Class="room-inline-icon" Size="Size.Small" aria-hidden="true" />
                                    Mode
                                </MudText>
                                <MudMenu AnchorOrigin="Origin.BottomRight"
                                         TransformOrigin="Origin.TopRight"
                                         Dense="true"
                                         Disabled="@(room.Id <= 0 || _busyRoomId == room.Id)">
                                    <ActivatorContent Context="modeMenu">
                                        @* Custom activator must toggle the menu; see MudMenu ActivatorContent docs. *@
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Class="room-mode-activator"
                                                   StartIcon="@ModeActivatorIcon(room)"
                                                   EndIcon="@Icons.Material.Filled.ArrowDropDown"
                                                   Disabled="@(room.Id <= 0 || _busyRoomId == room.Id)"
                                                   OnClick="@(e => modeMenu.ToggleAsync(e))">
                                            @CurrentModeLabel(room)
                                        </MudButton>
                                    </ActivatorContent>
                                    <ChildContent>
                                        <MudMenuItem Icon="@Icons.Material.Filled.CalendarMonth"
                                                     IconColor="Color.Primary"
                                                     OnClick="@(() => OnRoomModeSelectChanged(room, "auto"))">
                                            Auto — follow schedule
                                        </MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.Gesture"
                                                     IconColor="Color.Primary"
                                                     OnClick="@(() => OnRoomModeSelectChanged(room, "manual"))">
                                            Manual — hold current target
                                        </MudMenuItem>
                                        <MudMenuItem Icon="@Icons.Material.Filled.PowerSettingsNew"
                                                     IconColor="Color.Default"
                                                     OnClick="@(() => OnRoomModeSelectChanged(room, "off"))">
                                            Off — heating off
                                        </MudMenuItem>
                                    </ChildContent>
                                </MudMenu>
                            </MudStack>

                            <MudText Typo="Typo.caption" Class="mud-text-secondary room-hub-mode-line">
                                <MudIcon Icon="@Icons.Material.Filled.Hub" Class="room-inline-icon" Size="Size.Small" aria-hidden="true" />
                                Hub mode: @(room.Mode ?? "—")
                            </MudText>

                            <MudDivider Class="my-1" />
                            <MudText Typo="Typo.caption" Class="mud-text-secondary room-section-label">
                                <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="room-inline-icon" Size="Size.Small" aria-hidden="true" />
                                Boost (timed)
                            </MudText>
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="boost-button-row">
                                @foreach (var preset in _boostPresets)
                                {
                                    <MudTooltip Text="@($"Timed boost to {preset.TemperatureC:F0} °C for {preset.Minutes} minutes")">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Class="boost-preset-btn touch-target"
                                                   StartIcon="@BoostPresetIcon(preset)"
                                                   Disabled="@(room.Id <= 0 || _busyRoomId == room.Id)"
                                                   OnClick="@(() => ApplyBoostAsync(room, preset))">
                                            <span class="boost-preset-btn-text">
                                                <span class="boost-preset-label">@preset.Name</span>
                                                <span class="boost-preset-meta mud-text-secondary">@($"{preset.TemperatureC:F0}°") · @preset.Minutes min</span>
                                            </span>
                                        </MudButton>
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>

@code {
    private readonly List<HubLiveRoom> _rooms = [];
    private readonly IReadOnlyList<BoostPresetInfo> _boostPresets =
    [
        new BoostPresetInfo("Quick", 21, 30),
        new BoostPresetInfo("Comfort", 22, 60),
        new BoostPresetInfo("Gentle", 20, 45),
    ];

    private bool _heatingRelayOn;
    private bool _heatingActive;
    private bool _loading = true;
    private bool _hasLoadedOnce;
    private bool _isRefreshing;
    private bool _heatOnlyFilter;
    private int? _busyRoomId;
    private string? _loadError;
    private string? _actionMessage;
    private bool _actionError;
    private bool _autoRefreshEnabled;
    private int _autoRefreshSec = 30;
    private DateTimeOffset? _lastRefreshAt;
    private CancellationTokenSource? _autoRefreshCts;
    private Task? _autoRefreshTask;
    private bool _scrollFragmentOnce;

    /// <summary>Same zone as Charts / daily summary (<c>TIME_ZONE</c>), not the server OS timezone.</summary>
    private TimeZoneInfo DisplayZone => TimeZoneResolver.Resolve(Options.TimeZoneId);

    private string LastUpdatedText => _lastRefreshAt is null
        ? "Last updated: never"
        : $"Last updated: {_lastRefreshAt.Value:HH:mm:ss} ({(int)Math.Max(0, (DateTimeOffset.Now - _lastRefreshAt.Value).TotalSeconds)}s ago)";

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        if (UriHasRoomFragment(Nav.Uri))
            _scrollFragmentOnce = true;

        if (RoomsCache.TryGetSnapshot(out var snap, out var cachedAt))
        {
            HydrateFromOverview(snap);
            _lastRefreshAt = cachedAt;
            _loading = false;
            _hasLoadedOnce = true;
            await RefreshAsync(fullPageLoader: false);
        }
        else
        {
            await RefreshAsync(fullPageLoader: true);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_scrollFragmentOnce || _loading || !_hasLoadedOnce)
            return;
        if (_rooms.Count == 0)
        {
            _scrollFragmentOnce = false;
            return;
        }

        _scrollFragmentOnce = false;
        await ScrollToFragmentIfPresentAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!LocationHasNonEmptyFragment(e.Location))
            return;
        _ = InvokeAsync(ScrollToFragmentIfPresentAsync);
    }

    private static bool LocationHasNonEmptyFragment(string location)
    {
        var hash = location.IndexOf('#', StringComparison.Ordinal);
        return hash >= 0 && hash < location.Length - 1;
    }

    private static bool UriHasRoomFragment(string uri) => LocationHasNonEmptyFragment(uri);

    private async Task ScrollToFragmentIfPresentAsync()
    {
        try
        {
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            var frag = uri.Fragment;
            if (frag.Length <= 1)
                return;
            var id = Uri.UnescapeDataString(frag.AsSpan(1).ToString());
            if (!IsSafeFragmentElementId(id))
                return;
            await Js.InvokeVoidAsync("wiserScrollToId", id);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private static bool IsSafeFragmentElementId(string id)
    {
        if (id.Length == 0 || id.Length > 200)
            return false;
        foreach (var c in id)
        {
            if (char.IsAsciiLetterOrDigit(c) || c is '-' or '_')
                continue;
            return false;
        }

        return true;
    }

    private void HydrateFromOverview(HubLiveOverview overview)
    {
        _rooms.Clear();
        _rooms.AddRange(overview.Rooms);
        _heatingRelayOn = overview.HeatingRelayOn;
        _heatingActive = overview.HeatingActive;
    }

    private bool TryHydrateFromServiceCache()
    {
        if (!RoomsCache.TryGetSnapshot(out var snap, out _))
            return false;
        HydrateFromOverview(snap);
        return _rooms.Count > 0;
    }

    private Task OnAutoRefreshChanged(bool enabled)
    {
        _autoRefreshEnabled = enabled;
        ConfigureAutoRefresh();
        return Task.CompletedTask;
    }

    private Task OnAutoRefreshSecondsChanged(int seconds)
    {
        _autoRefreshSec = seconds;
        ConfigureAutoRefresh();
        return Task.CompletedTask;
    }

    private void ConfigureAutoRefresh()
    {
        _autoRefreshCts?.Cancel();
        _autoRefreshCts?.Dispose();
        _autoRefreshCts = null;
        _autoRefreshTask = null;

        if (!_autoRefreshEnabled)
            return;

        _autoRefreshCts = new CancellationTokenSource();
        var ct = _autoRefreshCts.Token;
        _autoRefreshTask = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(Math.Max(10, _autoRefreshSec)));
            try
            {
                while (await timer.WaitForNextTickAsync(ct))
                {
                    await InvokeAsync(async () =>
                    {
                        if (!_loading && !_isRefreshing)
                            await RefreshAsync();
                    });
                }
            }
            catch (OperationCanceledException)
            {
                // expected on toggle/teardown
            }
        }, ct);
    }

    private IEnumerable<HubLiveRoom> FilteredRooms()
    {
        var q = _rooms.AsEnumerable();
        if (_heatOnlyFilter)
            q = q.Where(r => r.HeatDemand != 0);
        return q.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase);
    }

    private void SetHeatFilter(bool heatOnly)
    {
        _heatOnlyFilter = heatOnly;
    }

    private static string RoomClimateIcon(HubLiveRoom room)
    {
        if (IsOfflineTemperature(room.TempC))
            return Icons.Material.Filled.SensorsOff;
        if (room.RadiatorState.Equals("on", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Filled.LocalFireDepartment;
        if (room.RadiatorState.Equals("off", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Filled.AcUnit;
        return Icons.Material.Filled.DeviceThermostat;
    }

    private static string RoomClimateIconClass(HubLiveRoom room)
    {
        if (IsOfflineTemperature(room.TempC))
            return "room-climate-icon room-climate-icon--offline";
        if (room.RadiatorState.Equals("on", StringComparison.OrdinalIgnoreCase))
            return "room-climate-icon room-climate-icon--heat";
        if (room.RadiatorState.Equals("off", StringComparison.OrdinalIgnoreCase))
            return "room-climate-icon room-climate-icon--cool";
        return "room-climate-icon";
    }

    private static string ModeActivatorIcon(HubLiveRoom room) =>
        GetModeKey(room) switch
        {
            "auto" => Icons.Material.Filled.CalendarMonth,
            "off" => Icons.Material.Filled.PowerSettingsNew,
            _ => Icons.Material.Filled.TouchApp,
        };

    private static string BoostPresetIcon(BoostPresetInfo preset) =>
        preset.Name.Equals("Quick", StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Filled.FlashOn
            : preset.Name.Equals("Comfort", StringComparison.OrdinalIgnoreCase)
                ? Icons.Material.Filled.WbSunny
                : preset.Name.Equals("Gentle", StringComparison.OrdinalIgnoreCase)
                    ? Icons.Material.Filled.WaterDrop
                    : Icons.Material.Filled.Bolt;

    private static bool IsOfflineTemperature(double tempC) =>
        Math.Abs(tempC - (-327.68)) < 0.001;

    private static string BuildRoomAnchorId(string roomName)
    {
        var chars = roomName.Trim().ToLowerInvariant()
            .Select(static c => char.IsLetterOrDigit(c) ? c : '-')
            .ToArray();
        var normalized = new string(chars).Trim('-');
        return $"room-{(string.IsNullOrWhiteSpace(normalized) ? "unknown" : normalized)}";
    }

    private string? FormatBoostSummary(HubLiveRoom room)
    {
        var raw = room.OverrideTimeoutUnix;
        if (raw is null or 0)
            return null;

        DateTimeOffset endUtc;
        try
        {
            var v = raw.Value;
            endUtc = v > 10_000_000_000L
                ? DateTimeOffset.FromUnixTimeMilliseconds(v)
                : DateTimeOffset.FromUnixTimeSeconds(v);
        }
        catch (ArgumentOutOfRangeException)
        {
            return null;
        }

        if (endUtc <= DateTimeOffset.UtcNow)
            return null;

        var endDisplay = TimeZoneInfo.ConvertTime(endUtc, DisplayZone);
        var prefix = room.SetpointOrigin?.Contains("Boost", StringComparison.OrdinalIgnoreCase) == true
            ? "Boost until "
            : "Heat until ";

        var target = room.SetpointC is null ? null : $"{WiserSetpointDisplay.ToDisplayTargetC(room.SetpointC.Value):F1} °C";
        var timeStr = endDisplay.ToString("t", CultureInfo.CurrentCulture);
        return target is null ? $"{prefix}{timeStr}" : $"{prefix}{timeStr} · target {target}";
    }

    private static string CurrentModeLabel(HubLiveRoom room) =>
        GetModeKey(room) switch
        {
            "auto" => "Auto",
            "off" => "Off",
            _ => "Manual",
        };

    /// <summary>Dropdown value for current hub state.</summary>
    private static string GetModeKey(HubLiveRoom room)
    {
        if (string.Equals(room.Mode, "Auto", StringComparison.OrdinalIgnoreCase))
            return "auto";
        if (room.SetpointC is double sp && sp < 5.0)
            return "off";
        return "manual";
    }

    private async Task OnRoomModeSelectChanged(HubLiveRoom room, string value)
    {
        if (string.Equals(value, GetModeKey(room), StringComparison.OrdinalIgnoreCase))
            return;

        switch (value)
        {
            case "auto":
                await ApplyModeAsync(room, "auto", null);
                break;
            case "manual":
                await ApplyModeAsync(room, "manual", room.SetpointC is >= 5.0 ? room.SetpointC : 20.0);
                break;
            case "off":
                await ApplyModeAsync(room, "off", null);
                break;
        }
    }

    private async Task RefreshAsync(bool fullPageLoader = false)
    {
        if (fullPageLoader)
            _loading = true;
        else
            _isRefreshing = true;

        _loadError = null;
        try
        {
            using var doc = await Hub.FetchDomainDocumentAsync(Options, CancellationToken.None);
            var overview = HubLiveRoomsParser.ParseOverview(doc, _boostPresets);
            RoomsCache.Update(overview);
            _rooms.Clear();
            _rooms.AddRange(overview.Rooms);
            _heatingRelayOn = overview.HeatingRelayOn;
            _heatingActive = overview.HeatingActive;
        }
        catch (Exception ex)
        {
            if (TryHydrateFromServiceCache())
            {
                _loadError = $"Could not refresh live data: {ex.Message}. Showing cached snapshot.";
            }
            else
            {
                _loadError = $"Could not load live data: {ex.Message}. Showing latest stored values.";
                _rooms.Clear();
                _rooms.AddRange(
                    Store.LatestByRoom()
                        .OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase)
                        .Select(x => new HubLiveRoom(
                            0,
                            x.Key,
                            "Saved",
                            x.Value.TempC,
                            x.Value.SetpointC,
                            x.Value.HeatDemand,
                            x.Value.HeatDemand != 0 ? "on" : "off",
                            x.Value.PercentageDemand,
                            null,
                            null,
                            null)));
                var latestSystem = Store.GetLatestSystem();
                _heatingRelayOn = latestSystem?.HeatingRelayOn ?? false;
                _heatingActive = latestSystem?.HeatingActive ?? _rooms.Any(r => r.HeatDemand != 0);
            }
        }
        finally
        {
            _lastRefreshAt = DateTimeOffset.Now;
            if (fullPageLoader)
                _loading = false;
            _isRefreshing = false;
            _hasLoadedOnce = true;
        }
    }

    private async Task ApplyModeAsync(HubLiveRoom room, string mode, double? temp)
    {
        if (!EnsureLiveRoom(room))
            return;

        _actionMessage = null;
        _actionError = false;
        _busyRoomId = room.Id;
        try
        {
            await Hub.PatchRoomModeAsync(Options, room.Id, mode, temp, CancellationToken.None);
            _actionMessage = $"Mode updated for {room.Name}.";
            Snackbar.Add(_actionMessage!, Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = true;
            _actionMessage = $"Action failed: {ex.Message}";
            Snackbar.Add(_actionMessage!, Severity.Error);
        }
        finally
        {
            _busyRoomId = null;
        }
    }

    private async Task ApplyBoostAsync(HubLiveRoom room, BoostPresetInfo preset)
    {
        if (!EnsureLiveRoom(room))
            return;

        _actionMessage = null;
        _actionError = false;
        _busyRoomId = room.Id;
        try
        {
            await Hub.PatchRoomBoostAsync(Options, room.Id, preset.TemperatureC, preset.Minutes, CancellationToken.None);
            _actionMessage = $"Boost applied to {room.Name}.";
            Snackbar.Add(_actionMessage!, Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = true;
            _actionMessage = $"Action failed: {ex.Message}";
            Snackbar.Add(_actionMessage!, Severity.Error);
        }
        finally
        {
            _busyRoomId = null;
        }
    }

    private async Task CancelTimedOverrideAsync(HubLiveRoom room)
    {
        if (!EnsureLiveRoom(room))
            return;

        _actionMessage = null;
        _actionError = false;
        _busyRoomId = room.Id;
        try
        {
            await Hub.PatchRoomCancelTimedOverrideAsync(Options, room.Id, CancellationToken.None);
            _actionMessage = $"Timed override cleared for {room.Name}; room is back on schedule.";
            Snackbar.Add(_actionMessage!, Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _actionError = true;
            _actionMessage = $"Action failed: {ex.Message}";
            Snackbar.Add(_actionMessage!, Severity.Error);
        }
        finally
        {
            _busyRoomId = null;
        }
    }

    private bool EnsureLiveRoom(HubLiveRoom room)
    {
        if (room.Id > 0)
            return true;

        _actionError = true;
        _actionMessage = "Live hub data required for control actions.";
        Snackbar.Add(_actionMessage, Severity.Warning);
        return false;
    }

    public ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        _autoRefreshCts?.Cancel();
        _autoRefreshCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}

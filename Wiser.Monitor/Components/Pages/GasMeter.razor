@page "/gas-meter"
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms

@inject TemperatureStore Store
@inject GasReceiptOcrService Ocr
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Wiser Monitor - Gas Meter</PageTitle>

<MudStack Spacing="3" Class="gas-meter-page">
    <MudPaper Class="pa-4 page-header-card">
        <MudText Typo="Typo.h5">
            <i class="fa-solid fa-fire-flame-curved"></i> Gas meter receipts
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Capture a receipt photo, scan key values, verify before save, and correct or delete entries later if needed.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        <MudText Typo="Typo.subtitle1" Class="mb-2">1) Capture and scan</MudText>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Outlined"
                       HtmlTag="label"
                       for="@_fileInputId"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PhotoCamera"
                       Class="touch-target">
                Open camera / choose image
            </MudButton>
            <InputFile id="@_fileInputId"
                       OnChange="OnReceiptFileChangedAsync"
                       accept="image/jpeg,image/png,image/webp"
                       capture="environment"
                       class="gas-meter-input-file-hidden" />
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@_selectedFileLabel</MudText>
        </MudStack>

        <MudStack Row="true" Class="mt-3" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Disabled="@_scanBusy"
                       StartIcon="@Icons.Material.Filled.DocumentScanner"
                       Class="touch-target"
                       OnClick="ScanAsync">
                @(_scanBusy ? "Scanning..." : "Scan image")
            </MudButton>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(_rawOcrText))
        {
            <MudExpansionPanels Class="mt-3">
                <MudExpansionPanel Text="OCR text preview">
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_rawOcrText</MudText>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        <MudText Typo="Typo.subtitle1" Class="mb-2">2) Verify and save</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Vol Credit"
                              @bind-Value="_volCreditText"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Amount (GBP)"
                              @bind-Value="_amountText"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Date (dd/mm/yy)"
                              @bind-Value="_entryDateText"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        @if (_ocrConfidence is not null)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
                OCR confidence: @_ocrConfidence.Value.ToString("0.00", CultureInfo.InvariantCulture)
            </MudText>
        }

        <MudStack Row="true" Spacing="1" Class="mt-3" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@_saveBusy"
                       StartIcon="@Icons.Material.Filled.Save"
                       Class="touch-target"
                       OnClick="SaveAsync">
                @(_editingId is null ? "Save entry" : "Update entry")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Disabled="@_saveBusy"
                       StartIcon="@Icons.Material.Filled.Clear"
                       Class="touch-target"
                       OnClick="ClearEditor">
                Clear
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        <MudText Typo="Typo.subtitle1" Class="mb-2">Current meter reading</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Reading (integer)"
                              @bind-Value="_meterReadingText"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField T="int"
                                 Label="Display scale (÷ divisor)"
                                 Value="_displayDivisor"
                                 ValueChanged="OnDisplayDivisorChanged"
                                 Min="1"
                                 Max="1000000"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 HelperText="Stored value is still the raw integer; this only affects the display column." />
            </MudItem>
            <MudItem xs="12" md="4" Class="d-flex align-center flex-wrap" Style="gap: 8px;">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           Class="touch-target"
                           OnClick="SaveDisplayDivisorAsync">
                    Save scale
                </MudButton>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Read time is set when saving a reading.
                </MudText>
            </MudItem>
        </MudGrid>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
            Cost rate from latest receipt:
            @if (GetUnitCostPerVolume() is decimal unitCost)
            {
                <span>GBP @((unitCost * 100m).ToString("0.000", CultureInfo.InvariantCulture)) per 100 volume units</span>
            }
            else
            {
                <span>Add at least one receipt with Vol Credit + Amount to calculate cost.</span>
            }
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
            <strong>Estimated cost</strong> uses the <strong>raw integer</strong> difference between readings × that rate (same units as Vol Credit on the receipt). The <strong>Display reading</strong> column is cosmetic (reading ÷ divisor), e.g. ÷1000 when the meter shows cubic metres with three decimals behind the register.
        </MudText>

        <MudStack Row="true" Spacing="1" Class="mt-3" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@_meterReadingSaveBusy"
                       StartIcon="@Icons.Material.Filled.Save"
                       Class="touch-target"
                       OnClick="SaveMeterReadingAsync">
                @(_meterReadingEditingId is null ? "Save reading" : "Update reading")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       Disabled="@_meterReadingSaveBusy"
                       StartIcon="@Icons.Material.Filled.Clear"
                       Class="touch-target"
                       OnClick="ClearMeterReadingEditor">
                Clear
            </MudButton>
        </MudStack>

        <MudDivider Class="my-3" />

        @if (_meterReadings.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">No meter readings yet.</MudAlert>
        }
        else
        {
            <MudTable T="GasMeterReadingRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_meterReadings">
                <HeaderContent>
                    <MudTh>Read datetime</MudTh>
                    <MudTh>Reading</MudTh>
                    <MudTh>Display reading</MudTh>
                    <MudTh>Usage</MudTh>
                    <MudTh>Estimated cost</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Read datetime">@FormatLocalDateTime(context.ReadTs)</MudTd>
                    <MudTd DataLabel="Reading">@context.ReadingValue</MudTd>
                    <MudTd DataLabel="Display reading">@FormatDisplayReading(context)</MudTd>
                    <MudTd DataLabel="Usage">@FormatUsage(context)</MudTd>
                    <MudTd DataLabel="Estimated cost">@FormatEstimatedCost(context)</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => StartEditMeterReading(context))">
                                Edit
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => DeleteMeterReadingAsync(context))">
                                Delete
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Saved entries</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Ordered by scanned receipt date (most recent first)
            </MudText>
        </MudStack>

        @if (_receipts.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">No gas meter entries yet.</MudAlert>
        }
        else
        {
            <MudTable T="GasMeterReceiptRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_receipts">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Vol Credit</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Cost per unit x100</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.EntryDate.ToString("dd/MM/yy", CultureInfo.InvariantCulture)</MudTd>
                    <MudTd DataLabel="Vol Credit">@context.VolCredit</MudTd>
                    <MudTd DataLabel="Amount">GBP @context.AmountGbp.ToString("0.00", CultureInfo.InvariantCulture)</MudTd>
                    <MudTd DataLabel="Cost per unit">@FormatReceiptUnitCost(context)</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => StartEdit(context))">
                                Edit
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => DeleteAsync(context))">
                                Delete
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@code {
    private readonly string _fileInputId = $"gas-receipt-{Guid.NewGuid():N}";
    private readonly List<GasMeterReceiptRow> _receipts = [];
    private readonly List<GasMeterReadingRow> _meterReadings = [];

    private byte[]? _selectedImageBytes;
    private string _selectedFileLabel = "No image selected.";
    private string? _rawOcrJson;
    private string? _rawOcrText;
    private double? _ocrConfidence;

    private string _volCreditText = "";
    private string _amountText = "";
    private string _entryDateText = "";

    private int? _editingId;
    private bool _scanBusy;
    private bool _saveBusy;
    private string _meterReadingText = "";
    private int? _meterReadingEditingId;
    private bool _meterReadingSaveBusy;
    private int _displayDivisor = 1000;

    protected override Task OnInitializedAsync()
    {
        _displayDivisor = Store.GetGasMeterDisplayDivisor();
        LoadRows();
        LoadMeterReadings();
        ApplyQuickEntryDefaults();
        return Task.CompletedTask;
    }

    private void OnDisplayDivisorChanged(int value)
    {
        _displayDivisor = Math.Clamp(value, 1, 1_000_000);
    }

    private Task SaveDisplayDivisorAsync()
    {
        Store.SetGasMeterDisplayDivisor(_displayDivisor);
        _displayDivisor = Store.GetGasMeterDisplayDivisor();
        Snackbar.Add("Display scale saved.", Severity.Success);
        return Task.CompletedTask;
    }

    private async Task OnReceiptFileChangedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
            return;

        var ext = Path.GetExtension(file.Name)?.ToLowerInvariant();
        if (ext is not (".jpg" or ".jpeg" or ".png" or ".webp"))
        {
            Snackbar.Add("Unsupported image type. Please use JPG, PNG, or WEBP.", Severity.Warning);
            _selectedImageBytes = null;
            _selectedFileLabel = "No image selected.";
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(10_000_000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _selectedImageBytes = ms.ToArray();
            _selectedFileLabel = file.Name;
            Snackbar.Add($"Loaded image: {file.Name}", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read image: {ex.Message}", Severity.Error);
        }
    }

    private async Task ScanAsync()
    {
        if (_selectedImageBytes is null || _selectedImageBytes.Length == 0)
        {
            Snackbar.Add("Select an image first.", Severity.Warning);
            return;
        }

        _scanBusy = true;
        try
        {
            var result = await Ocr.ScanAsync(_selectedImageBytes, _selectedFileLabel, CancellationToken.None);
            _volCreditText = result.VolCredit?.ToString(CultureInfo.InvariantCulture) ?? "";
            _amountText = result.AmountGbp?.ToString("0.00", CultureInfo.InvariantCulture) ?? "";
            _entryDateText = result.EntryDate?.ToString("dd/MM/yy", CultureInfo.InvariantCulture) ?? "";
            _rawOcrText = result.RawText;
            _rawOcrJson = result.RawJson;
            _ocrConfidence = result.Confidence;
            Snackbar.Add("Scan complete. Verify the values before saving.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"OCR failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _scanBusy = false;
        }
    }

    private Task SaveAsync()
    {
        if (!int.TryParse(_volCreditText, NumberStyles.Integer, CultureInfo.InvariantCulture, out var volCredit) || volCredit <= 0)
        {
            Snackbar.Add("Vol Credit must be a positive whole number.", Severity.Warning);
            return Task.CompletedTask;
        }

        if (!decimal.TryParse(_amountText, NumberStyles.Number, CultureInfo.InvariantCulture, out var amount) || amount <= 0)
        {
            Snackbar.Add("Amount must be a positive value (e.g. 75.00).", Severity.Warning);
            return Task.CompletedTask;
        }

        if (!TryParseDate(_entryDateText, out var entryDate))
        {
            Snackbar.Add("Date must be dd/MM/yy, dd/MM/yyyy, or yyyy-MM-dd.", Severity.Warning);
            return Task.CompletedTask;
        }

        _saveBusy = true;
        try
        {
            if (_editingId is int id)
            {
                if (!Store.UpdateGasMeterReceipt(id, entryDate, volCredit, amount))
                {
                    Snackbar.Add("Could not update entry (not found).", Severity.Error);
                    return Task.CompletedTask;
                }

                Snackbar.Add("Entry updated.", Severity.Success);
            }
            else
            {
                Store.CreateGasMeterReceipt(entryDate, volCredit, amount, _rawOcrJson, null);
                Snackbar.Add("Entry saved.", Severity.Success);
            }

            LoadRows();
            ApplyQuickEntryDefaults();
        }
        finally
        {
            _saveBusy = false;
        }

        return Task.CompletedTask;
    }

    private void StartEdit(GasMeterReceiptRow row)
    {
        _editingId = row.Id;
        _volCreditText = row.VolCredit.ToString(CultureInfo.InvariantCulture);
        _amountText = row.AmountGbp.ToString("0.00", CultureInfo.InvariantCulture);
        _entryDateText = row.EntryDate.ToString("dd/MM/yy", CultureInfo.InvariantCulture);
        _rawOcrJson = row.OcrRawJson;
        _rawOcrText = null;
        _ocrConfidence = null;
    }

    private async Task DeleteAsync(GasMeterReceiptRow row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Delete entry?",
            $"Delete gas meter record for {row.EntryDate:dd/MM/yy} (Vol Credit {row.VolCredit})?",
            yesText: "Delete",
            noText: null,
            cancelText: "Cancel");
        if (confirm is not true)
            return;

        var ok = Store.DeleteGasMeterReceipt(row.Id);
        if (ok)
        {
            LoadRows();
            ApplyQuickEntryDefaults();
            Snackbar.Add("Entry deleted.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Could not delete entry (not found).", Severity.Error);
        }
    }

    private void ClearEditor()
    {
        ApplyQuickEntryDefaults();
    }

    private void ApplyQuickEntryDefaults()
    {
        _editingId = null;
        var latest = _receipts.FirstOrDefault();
        _volCreditText = latest is null ? "" : latest.VolCredit.ToString(CultureInfo.InvariantCulture);
        _amountText = latest is null ? "" : latest.AmountGbp.ToString("0.00", CultureInfo.InvariantCulture);
        _entryDateText = DateOnly.FromDateTime(DateTime.Now).ToString("dd/MM/yy", CultureInfo.InvariantCulture);
        _rawOcrJson = null;
        _rawOcrText = null;
        _ocrConfidence = null;
    }

    private Task SaveMeterReadingAsync()
    {
        if (!int.TryParse(_meterReadingText, NumberStyles.Integer, CultureInfo.InvariantCulture, out var readingValue))
        {
            Snackbar.Add("Reading must be a valid integer.", Severity.Warning);
            return Task.CompletedTask;
        }

        _meterReadingSaveBusy = true;
        try
        {
            if (_meterReadingEditingId is int id)
            {
                if (!Store.UpdateGasMeterReading(id, readingValue))
                {
                    Snackbar.Add("Could not update reading (not found).", Severity.Error);
                    return Task.CompletedTask;
                }

                Snackbar.Add("Meter reading updated.", Severity.Success);
            }
            else
            {
                Store.CreateGasMeterReading(readingValue);
                Snackbar.Add("Meter reading saved.", Severity.Success);
            }

            LoadMeterReadings();
            ClearMeterReadingEditor();
        }
        finally
        {
            _meterReadingSaveBusy = false;
        }

        return Task.CompletedTask;
    }

    private void StartEditMeterReading(GasMeterReadingRow row)
    {
        _meterReadingEditingId = row.Id;
        _meterReadingText = row.ReadingValue.ToString(CultureInfo.InvariantCulture);
    }

    private async Task DeleteMeterReadingAsync(GasMeterReadingRow row)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Delete meter reading?",
            $"Delete meter reading {row.ReadingValue} from {FormatLocalDateTime(row.ReadTs)}?",
            yesText: "Delete",
            noText: null,
            cancelText: "Cancel");
        if (confirm is not true)
            return;

        var ok = Store.DeleteGasMeterReading(row.Id);
        if (ok)
        {
            LoadMeterReadings();
            ClearMeterReadingEditor();
            Snackbar.Add("Meter reading deleted.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Could not delete reading (not found).", Severity.Error);
        }
    }

    private void ClearMeterReadingEditor()
    {
        _meterReadingEditingId = null;
        _meterReadingText = "";
    }

    private void LoadRows()
    {
        _receipts.Clear();
        _receipts.AddRange(Store.ListGasMeterReceipts());
    }

    private void LoadMeterReadings()
    {
        _meterReadings.Clear();
        _meterReadings.AddRange(Store.ListGasMeterReadings());
    }

    private static bool TryParseDate(string? text, out DateOnly date)
    {
        if (DateOnly.TryParseExact(text, "dd/MM/yy", CultureInfo.InvariantCulture, DateTimeStyles.None, out date))
            return true;
        if (DateOnly.TryParseExact(text, "dd/MM/yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out date))
            return true;
        if (DateOnly.TryParseExact(text, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out date))
            return true;
        return false;
    }

    private static string FormatLocalDateTime(long ts)
    {
        return DateTimeOffset.FromUnixTimeSeconds(ts).ToLocalTime().ToString("dd/MM/yy HH:mm", CultureInfo.InvariantCulture);
    }

    private decimal? GetUnitCostPerVolume()
    {
        var latestReceipt = _receipts.FirstOrDefault();
        if (latestReceipt is null || latestReceipt.VolCredit <= 0)
            return null;
        return latestReceipt.AmountGbp / latestReceipt.VolCredit;
    }

    private int? GetUsageSincePrevious(GasMeterReadingRow row)
    {
        var idx = _meterReadings.FindIndex(x => x.Id == row.Id);
        if (idx < 0 || idx + 1 >= _meterReadings.Count)
            return null;

        var previous = _meterReadings[idx + 1];
        var usage = row.ReadingValue - previous.ReadingValue;
        return usage >= 0 ? usage : null;
    }

    private string FormatUsage(GasMeterReadingRow row)
    {
        var usage = GetUsageSincePrevious(row);
        return usage is null ? "—" : usage.Value.ToString(CultureInfo.InvariantCulture);
    }

    private string FormatEstimatedCost(GasMeterReadingRow row)
    {
        var usage = GetUsageSincePrevious(row);
        var unitCost = GetUnitCostPerVolume();
        if (usage is null || unitCost is null)
            return "—";

        var total = usage.Value * unitCost.Value;
        return $"GBP {total.ToString("0.00", CultureInfo.InvariantCulture)}";
    }

    private string FormatDisplayReading(GasMeterReadingRow row)
    {
        var d = Math.Max(1, _displayDivisor);
        var v = row.ReadingValue / (decimal)d;
        return v.ToString("0.000", CultureInfo.InvariantCulture);
    }

    private static string FormatReceiptUnitCost(GasMeterReceiptRow row)
    {
        if (row.VolCredit <= 0)
            return "—";
        var unit = (row.AmountGbp / row.VolCredit) * 100m;
        return $"GBP {unit.ToString("0.000", CultureInfo.InvariantCulture)}";
    }
}

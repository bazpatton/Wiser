@page "/"
@rendermode InteractiveServer
@using System.Globalization

@inject MonitorState MonitorState
@inject MonitorOptions Options
@inject TemperatureStore Store
@inject OutdoorWeatherClient OutdoorWeather
@inject WiserHubFetch Hub

<PageTitle>Wiser Monitor</PageTitle>

<MudStack Spacing="3">
    @if (_gasMeterReadingBannerText is not null)
    {
        <MudAlert Severity="Severity.Warning"
                  Dense="true"
                  Class="home-gas-meter-banner"
                  ShowCloseIcon="false"
                  ContentAlignment="HorizontalAlignment.Left">
            <div class="d-flex flex-wrap align-center" style="gap: 12px;">
                <MudText Typo="Typo.body1" Class="flex-grow-1">@_gasMeterReadingBannerText</MudText>
                <MudButton Href="/gas-meter"
                           Variant="Variant.Filled"
                           Color="Color.Warning"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.LocalGasStation"
                           Class="touch-target">
                    Gas meter
                </MudButton>
            </div>
        </MudAlert>
    }

    <MudPaper Class="pa-5 hero-card">
        <MudTooltip Text="Polls your Wiser hub on the configured interval and records room data locally.">
            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">Live monitoring</MudChip>
        </MudTooltip>
        <MudText Typo="Typo.h4" Class="mt-2">Wiser Heat Hub Monitor</MudText>
        <MudText Typo="Typo.body1" Class="mt-1">
            Track room temperatures, heating demand, and trend charts from one dashboard designed for desktop and mobile.
        </MudText>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-4">
            <MudButton Href="/rooms" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home" Class="touch-target">
                Rooms
            </MudButton>
            <MudButton Href="/devices" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Memory" Class="touch-target">
                Devices
            </MudButton>
            <MudButton Href="/charts" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ShowChart" Class="touch-target">
                Charts
            </MudButton>
            <MudButton Href="/settings" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Settings" Class="touch-target">
                Settings
            </MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">
                <i class="fa-solid fa-map-location-dot"></i> Floorplan temperature overlay
            </MudText>
            <MudButton Href="/settings"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.OpenInNew">
                Configure
            </MudButton>
        </MudStack>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
            Room pins are mapped in Settings. Colors reflect current temperature against each room's recommended range.
        </MudText>
        @if (FloorplanImageHref is null)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                Upload a floorplan image and map room pins in Settings to enable this view.
            </MudAlert>
        }
        else if (_homeFloorplanPins.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                No room pins are mapped yet. Add pin coordinates in Settings.
            </MudAlert>
        }
        else
        {
            <div class="home-floorplan-wrap mt-2">
                <img src="@FloorplanImageHref" alt="House floorplan" class="home-floorplan-image" />
                @foreach (var pin in _homeFloorplanPins)
                {
                    <a class="home-floorplan-pin"
                       href="@GetRoomDetailsHref(pin.Room)"
                       style="@($"left:{pin.XPercent:0.##}%;top:{pin.YPercent:0.##}%;--pin-color:{pin.Color};")"
                       title="@pin.Tooltip">
                        <span class="home-floorplan-pin-dot"></span>
                        <span class="home-floorplan-pin-label">@pin.Label</span>
                    </a>
                }
            </div>
        }
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudText Typo="Typo.h6">
            <i class="fa-solid fa-cloud-sun"></i> Heating demand outlook (estimate)
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
            Compares last 7 local days of HDD (from stored outdoor samples) to the next 7 days from Open-Meteo forecast daily temperatures. Same 15.5 °C base as the daily summary. Not a bill forecast.
        </MudText>
        @if (Options.OpenMeteoLat is null || Options.OpenMeteoLon is null)
        {
            <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
                Configure Open-Meteo latitude and longitude on Settings to enable this outlook.
            </MudText>
        }
        else if (_outlookLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
        }
        else if (!string.IsNullOrWhiteSpace(_outlookError))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@_outlookError</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.body1" Class="mt-2">@_outlookSummary</MudText>
            @if (!string.IsNullOrWhiteSpace(_outlookDetail))
            {
                <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">@_outlookDetail</MudText>
            }
        }
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">
                <i class="fa-solid fa-table"></i> Daily summary (energy proxies)
            </MudText>
            <MudButton Href="/charts"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.OpenInNew">
                Charts
            </MudButton>
        </MudStack>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
            Per local day: HDD (15.5 °C base), mean outdoor °C, and heating demand / boiler relay minutes estimated from poll activity. Needs outdoor samples for HDD columns.
        </MudText>
        @if (_homeDailyRows.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                No daily summary rows yet (needs recorded history).
            </MudAlert>
        }
        else
        {
            <MudTable T="DailySummaryRow" Items="_homeDailyRows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh Class="text-right">HDD</MudTh>
                    <MudTh Class="text-right">Avg out °C</MudTh>
                    <MudTh Class="text-right">Heat est. min</MudTh>
                    <MudTh Class="text-right">Relay est. min</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.Date</MudTd>
                    <MudTd DataLabel="HDD" Class="text-right">@FmtOpt(context.Hdd)</MudTd>
                    <MudTd DataLabel="Avg out" Class="text-right">@FmtOpt(context.AvgOutdoorC)</MudTd>
                    <MudTd DataLabel="Heat min" Class="text-right">@FmtHeatMin(context.HeatingActiveEstimateMin)</MudTd>
                    <MudTd DataLabel="Relay min" Class="text-right">@FmtHeatMin(context.HeatingRelayEstimateMin)</MudTd>
                </RowTemplate>
            </MudTable>
            <MudButton Href="/api/export/daily-summary.csv?days=14"
                       Variant="Variant.Text"
                       Size="Size.Small"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       Class="mt-1">
                Export CSV (14 days)
            </MudButton>
        }
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">
                <i class="fa-solid fa-piggy-bank"></i> Save on heating - schedule ideas
            </MudText>
            <MudButton Href="/settings"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Tune">
                Customize routine
            </MudButton>
        </MudStack>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-1">
            Suggestions are heuristics from your routine profile, recent heating activity, forecast context, and schedule mapping when hub data is available.
        </MudText>
        @if (_savingsSuggestions.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">No suggestions yet.</MudAlert>
        }
        else
        {
            <MudStack Spacing="1" Class="mt-2">
                @foreach (var tip in _savingsSuggestions)
                {
                    <MudAlert Severity="@(tip.Level == HeatingSavingsSuggestionLevel.Warning ? Severity.Warning : Severity.Info)"
                              Dense="true">
                        <div class="d-flex flex-wrap align-center" style="gap: 10px;">
                            <MudText Typo="Typo.body2" Class="flex-grow-1">
                                <strong>@tip.Title:</strong> @tip.Body
                            </MudText>
                            <MudButton Href="@tip.ActionHref"
                                       Variant="Variant.Text"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       EndIcon="@Icons.Material.Filled.OpenInNew">
                                @tip.ActionText
                            </MudButton>
                        </div>
                    </MudAlert>
                }
            </MudStack>
        }
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudText Typo="Typo.h6">
            <i class="fa-solid fa-heart-pulse"></i> Service status
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-2">@_status</MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
            <MudTooltip Text="Temperature alert rules via ntfy (when configured).">
                <MudChip T="string" Color="@(Options.AlertsEnabled ? Color.Success : Color.Default)" Variant="Variant.Outlined">
                    Alerts: @(Options.AlertsEnabled ? "Enabled" : "Disabled")
                </MudChip>
            </MudTooltip>
            <MudTooltip Text="Open-Meteo outdoor temperature pull for chart overlays.">
                <MudChip T="string" Color="@(Options.OpenMeteoLat is null ? Color.Default : Color.Info)" Variant="Variant.Outlined">
                    Outdoor data: @(Options.OpenMeteoLat is null ? "Off" : "On")
                </MudChip>
            </MudTooltip>
        </MudStack>
        @if (!string.IsNullOrWhiteSpace(_lastError))
        {
            <MudAlert Dense="true" Severity="Severity.Warning" Class="mt-2">@_lastError</MudAlert>
        }
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudText Typo="Typo.h6">
            <i class="fa-solid fa-filter-circle-xmark"></i> Data quality (last 24h)
        </MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
            <MudTooltip Text="Invalid hub readings not stored in history (last 24h).">
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">
                    Dropped invalid readings: @_qualityTotal24h
                </MudChip>
            </MudTooltip>
            @foreach (var item in _qualityReasons24h)
            {
                <MudTooltip Text="Why samples were dropped.">
                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
                        @($"{item.Reason}: {item.Count}")
                    </MudChip>
                </MudTooltip>
            }
        </MudStack>
        <MudButton Href="/charts#data-quality"
                   Variant="Variant.Text"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.OpenInNew"
                   Class="mt-2">
            View details
        </MudButton>
    </MudPaper>

    <MudPaper Class="pa-4 status-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6">
                <i class="fa-solid fa-grip"></i> Current room temperatures and trend status
            </MudText>
            <MudButton Href="/charts"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.OpenInNew">
                Open charts
            </MudButton>
        </MudStack>
        @if (_homeRoomTiles.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">No room trend data yet.</MudAlert>
        }
        else
        {
            <div class="room-heat-grid home-room-heat-grid mt-2">
                @foreach (var tile in _homeRoomTiles)
                {
                    <a class="room-heat-tile room-heat-link"
                       style="background-color:@tile.Color;"
                       href="@GetRoomDetailsHref(tile.Room)"
                       title="@($"Open {tile.Room} in Rooms")">
                        <div class="room-heat-name">
                            <span class="room-heat-state-square" style="background-color:@tile.CurrentStateColor;" title="@tile.CurrentStateText"></span>
                            @tile.Room
                        </div>
                        <div class="room-heat-temp">@tile.DisplayTemp</div>
                        <div class="room-heat-meta">@tile.RangeText</div>
                        <div class="room-heat-meta">@tile.StatusText</div>
                        <div class="room-heat-meta">@tile.TrendText</div>
                    </a>
                }
            </div>
        }
    </MudPaper>
</MudStack>

@code {
    private const int HomeTrendHours = 24;
    private string _status = "Loading...";
    private string? _lastError;
    private int _qualityTotal24h;
    private List<DataQualityReasonCount> _qualityReasons24h = [];
    private readonly List<HomeRoomHeatTile> _homeRoomTiles = [];

    private bool _outlookLoading;
    private string? _outlookError;
    private string _outlookSummary = "";
    private string? _outlookDetail;
    private readonly List<HeatingSavingsSuggestion> _savingsSuggestions = [];
    private readonly List<DailySummaryRow> _homeDailyRows = [];
    private FloorplanConfig _homeFloorplanConfig = FloorplanConfig.Default;
    private readonly List<HomeFloorplanPin> _homeFloorplanPins = [];
    private double? _outlookPastWeekHddSum;
    private double? _outlookForecastWeekHddSum;

    private string? _gasMeterReadingBannerText;

    private TimeZoneInfo DisplayZone => TimeZoneResolver.Resolve(Options.TimeZoneId);
    private string? FloorplanImageHref =>
        string.IsNullOrWhiteSpace(_homeFloorplanConfig.ImageFileName)
            ? null
            : $"/api/floorplan/image?v={_homeFloorplanConfig.UpdatedTs}";

    protected override async Task OnInitializedAsync()
    {
        var (err, ok) = MonitorState.Snapshot();
        _lastError = err;
        var okText = ok is null
            ? "No successful poll yet."
            : $"Last OK: {TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(ok.Value), DisplayZone).ToString("g", CultureInfo.CurrentCulture)}";
        _status = $"Poll interval: {Options.IntervalSec}s · Alerts: {(Options.AlertsEnabled ? "On" : "Off")} · {okText}";

        var quality = Store.GetDataQualitySummary(24);
        _qualityTotal24h = quality.TotalIgnored;
        _qualityReasons24h = quality.ByReason.Take(4).ToList();
        LoadHomeDailySummary();
        BuildHomeRoomHeatMap();
        BuildHomeFloorplanOverlay();
        UpdateGasMeterReadingBanner();
        await LoadHeatingOutlookAsync();
        await LoadSavingsSuggestionsAsync();
    }

    private void LoadHomeDailySummary()
    {
        _homeDailyRows.Clear();
        _homeDailyRows.AddRange(
            Store.GetDailySummaries(7, Math.Max(10, Options.IntervalSec), DisplayZone)
                .OrderByDescending(static x => x.Date, StringComparer.Ordinal));
    }

    private static string FmtOpt(double? value) =>
        value is null || double.IsNaN(value.Value) ? "—" : value.Value.ToString("0.0", CultureInfo.InvariantCulture);

    private static string FmtHeatMin(double value) =>
        double.IsNaN(value) ? "—" : value.ToString("0.0", CultureInfo.InvariantCulture);

    private void UpdateGasMeterReadingBanner()
    {
        const long weekSec = 7L * 24 * 60 * 60;
        var latestTs = Store.GetLatestGasMeterReadingUnixTs();
        var cutoff = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - weekSec;

        if (latestTs is null)
        {
            _gasMeterReadingBannerText =
                "No gas meter reading has been logged yet. Add readings on the Gas meter page to track credit and estimated cost.";
            return;
        }

        if (latestTs.Value < cutoff)
        {
            var local = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(latestTs.Value), DisplayZone);
            _gasMeterReadingBannerText =
                $"Your last gas meter reading was {local.ToString("g", CultureInfo.CurrentCulture)} — over a week ago. Log a new reading on the Gas meter page.";
            return;
        }

        _gasMeterReadingBannerText = null;
    }

    private async Task LoadHeatingOutlookAsync()
    {
        _outlookPastWeekHddSum = null;
        _outlookForecastWeekHddSum = null;
        if (Options.OpenMeteoLat is not { } lat || Options.OpenMeteoLon is not { } lon)
            return;

        _outlookLoading = true;
        _outlookError = null;
        _outlookSummary = "";
        _outlookDetail = null;

        try
        {
            var daily = Store.GetDailySummaries(7, Math.Max(10, Options.IntervalSec), DisplayZone);
            var hddValues = daily
                .Where(d => d.Hdd is { } h && !double.IsNaN(h) && !double.IsInfinity(h))
                .Select(d => d.Hdd!.Value)
                .ToList();
            var pastHddSum = hddValues.Count > 0 ? hddValues.Sum() : (double?)null;
            _outlookPastWeekHddSum = pastHddSum;
            var pastHeatMin = daily.Sum(d => d.HeatingActiveEstimateMin);

            var outlook = await OutdoorWeather.GetSevenDayHddOutlookAsync(lat, lon, Options.TimeZoneId, CancellationToken.None)
                .ConfigureAwait(false);

            if (outlook is null)
            {
                _outlookError = "Could not load the 7-day weather outlook from Open-Meteo.";
                return;
            }

            if (pastHddSum is null)
            {
                _outlookSummary =
                    "There is not enough outdoor temperature history in the last 7 days to compare (HDD needs stored Open-Meteo samples). Once outdoor data accumulates, this card will compare past HDD to the forecast.";
                _outlookDetail =
                    $"Next 7 days (forecast HDD proxy total): {outlook.TotalHddProxy.ToString("0.0", CultureInfo.InvariantCulture)} degree-days. " +
                    $"Last week heating-active estimate: {pastHeatMin.ToString("0", CultureInfo.InvariantCulture)} min.";
                return;
            }

            var forecastSum = outlook.TotalHddProxy;
            _outlookForecastWeekHddSum = forecastSum;
            const double band = 0.15;
            string verdict;
            if (forecastSum > pastHddSum.Value * (1 + band))
                verdict = "higher";
            else if (forecastSum < pastHddSum.Value * (1 - band))
                verdict = "lower";
            else
                verdict = "similar";

            _outlookSummary = verdict switch
            {
                "higher" =>
                    "Next week’s outlook suggests higher heating demand than last week, based on colder outdoor temperatures in the forecast.",
                "lower" =>
                    "Next week’s outlook suggests lower heating demand than last week, based on milder outdoor temperatures in the forecast.",
                _ =>
                    "Next week’s outlook suggests similar heating demand to last week, based on outdoor temperatures.",
            };

            var tMin = outlook.Days.Min(d => d.TempMinC);
            var tMax = outlook.Days.Max(d => d.TempMaxC);
            _outlookDetail =
                $"Last 7 days: HDD total {pastHddSum.Value.ToString("0.0", CultureInfo.InvariantCulture)} (from recorded outdoor data), " +
                $"heating-active estimate {pastHeatMin.ToString("0", CultureInfo.InvariantCulture)} min. " +
                $"Forecast week: HDD proxy total {forecastSum.ToString("0.0", CultureInfo.InvariantCulture)}, " +
                $"daily max/min span about {tMin.ToString("0", CultureInfo.InvariantCulture)}–{tMax.ToString("0", CultureInfo.InvariantCulture)} °C.";
        }
        catch (Exception ex)
        {
            _outlookError = $"Outlook unavailable: {ex.Message}";
        }
        finally
        {
            _outlookLoading = false;
        }
    }

    private async Task LoadSavingsSuggestionsAsync()
    {
        var profile = Store.GetHeatingSavingsProfile();
        var daily14 = Store.GetDailySummaries(14, Math.Max(10, Options.IntervalSec), DisplayZone);

        HubScheduleSavingsHints? hubHints = null;
        if (!string.IsNullOrWhiteSpace(Options.WiserIp)
            && Options.WiserIp != "192.168.x.x"
            && !string.IsNullOrWhiteSpace(Options.WiserSecret)
            && Options.WiserSecret != "your-secret-here")
        {
            try
            {
                using var doc = await Hub.FetchDomainDocumentAsync(Options, CancellationToken.None).ConfigureAwait(false);
                hubHints = HubSchedulesParser.AnalyzeSavingsHints(doc);
            }
            catch
            {
                // Hub might be offline/degraded; skip hub-specific hints.
            }
        }

        var tips = HeatingSavingsSuggestionBuilder.Build(new HeatingSavingsSuggestionContext(
            profile,
            daily14,
            Options.OpenMeteoLat is not null && Options.OpenMeteoLon is not null,
            _outlookPastWeekHddSum,
            _outlookForecastWeekHddSum,
            hubHints));
        _savingsSuggestions.Clear();
        _savingsSuggestions.AddRange(tips);
    }

    private void BuildHomeRoomHeatMap()
    {
        _homeRoomTiles.Clear();
        var rooms = Store.ListRooms().OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList();
        if (rooms.Count == 0)
            return;

        var sinceTs = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - (HomeTrendHours * 3600L);
        var activityMap = Store.GetRoomActivityMap();
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();

        var tiles = new List<HomeRoomHeatTile>(rooms.Count);
        foreach (var room in rooms)
        {
            var isActive = !activityMap.TryGetValue(room, out var activeFlag) || activeFlag;
            var rows = Store.SeriesRoom(room, sinceTs);
            if (rows.Count == 0)
            {
                var (missingMin, missingMax) = GetRecommendedTempRange(room, isActive);
                tiles.Add(new HomeRoomHeatTile(
                    room,
                    null,
                    "—",
                    "#334155",
                    $"Recommended {missingMin:0.#} - {missingMax:0.#}C",
                    $"No data in selected period{(isActive ? string.Empty : ", inactive profile")}",
                    "Trend unavailable",
                    null,
                    -1,
                    0,
                    0,
                    "Current state unavailable",
                    "#94a3b8"));
                continue;
            }

            var current = rows[^1].TempC;
            var trendRows = rows
                .Where(x => !IsWithinIgnoreWindow(x.Ts, ignoreStart, ignoreEnd, DisplayZone))
                .ToList();
            if (trendRows.Count == 0)
            {
                var (missingMin, missingMax) = GetRecommendedTempRange(room, isActive);
                tiles.Add(new HomeRoomHeatTile(
                    room,
                    current,
                    $"{current:0.0}C",
                    "#334155",
                    $"Recommended {missingMin:0.#} - {missingMax:0.#}C",
                    $"No trend data outside ignored window{(isActive ? string.Empty : ", inactive profile")}",
                    $"Ignored {ignoreStart:hh\\:mm}-{ignoreEnd:hh\\:mm}",
                    null,
                    -1,
                    0,
                    0,
                    "Current state unavailable",
                    "#94a3b8"));
                continue;
            }

            var average = trendRows.Average(static x => x.TempC);
            var trendDelta = trendRows[^1].TempC - trendRows[0].TempC;
            var (rangeMin, rangeMax) = GetRecommendedTempRange(room, isActive);
            var status = average < rangeMin
                ? "Too cold"
                : average > rangeMax
                    ? "Too hot"
                    : "In range";
            var statusRank = status switch
            {
                "Too hot" => 2,
                "In range" => 1,
                _ => 0,
            };
            var severity = status switch
            {
                "Too hot" => average - rangeMax,
                "Too cold" => rangeMin - average,
                _ => Math.Abs(average - ((rangeMin + rangeMax) / 2.0)),
            };
            // Too cold: ascending sort key (smallest gap below range first — closest to OK). Too hot / in range: negate so OrderBy puts larger severity first.
            var sortKeyWithinBand = status == "Too cold" ? severity : -severity;
            var color = GetComfortGradientColor(average, rangeMin, rangeMax);
            var (currentStateText, currentStateColor) = GetCurrentState(current, rangeMin, rangeMax);
            tiles.Add(new HomeRoomHeatTile(
                room,
                current,
                $"{current:0.0}C",
                color,
                $"Recommended {rangeMin:0.#} - {rangeMax:0.#}C",
                $"{status} (avg {average:0.0}C over {HomeTrendHours}h){(isActive ? string.Empty : ", inactive profile")}",
                $"Trend {FormatTrend(trendDelta)}",
                trendDelta,
                statusRank,
                severity,
                sortKeyWithinBand,
                currentStateText,
                currentStateColor));
        }

        _homeRoomTiles.AddRange(tiles
            .OrderByDescending(static x => x.StatusRank)
            .ThenBy(static x => x.SortKeyWithinBand)
            .ThenByDescending(static x => x.TrendDeltaC.HasValue)
            .ThenByDescending(static x => x.TrendDeltaC)
            .ThenBy(static x => x.Room, StringComparer.OrdinalIgnoreCase));
    }

    private void BuildHomeFloorplanOverlay()
    {
        _homeFloorplanPins.Clear();
        _homeFloorplanConfig = Store.GetFloorplanConfig();
        if (_homeFloorplanConfig.Pins.Count == 0)
            return;

        var latestByRoom = Store.LatestByRoom();
        var activityMap = Store.GetRoomActivityMap();

        foreach (var pin in _homeFloorplanConfig.Pins)
        {
            var room = pin.Room.Trim();
            if (room.Length == 0)
                continue;

            if (!latestByRoom.TryGetValue(room, out var latest))
            {
                _homeFloorplanPins.Add(new HomeFloorplanPin(
                    room,
                    Math.Clamp(pin.XPercent, 0, 100),
                    Math.Clamp(pin.YPercent, 0, 100),
                    "#64748b",
                    $"{room}: —",
                    $"{room}: no current reading"));
                continue;
            }

            var isActive = !activityMap.TryGetValue(room, out var activeFlag) || activeFlag;
            var (rangeMin, rangeMax) = GetRecommendedTempRange(room, isActive);
            var color = GetComfortGradientColor(latest.TempC, rangeMin, rangeMax);
            var label = $"{room}: {latest.TempC:0.0}C";
            var tooltip =
                $"{room}: {latest.TempC:0.0}C. Recommended {rangeMin:0.#}-{rangeMax:0.#}C"
                + (isActive ? string.Empty : " (inactive profile)");

            _homeFloorplanPins.Add(new HomeFloorplanPin(
                room,
                Math.Clamp(pin.XPercent, 0, 100),
                Math.Clamp(pin.YPercent, 0, 100),
                color,
                label,
                tooltip));
        }
    }

    private static (double Min, double Max) GetRecommendedTempRange(string roomName, bool isActive)
    {
        var r = roomName.ToLowerInvariant();
        var baseRange = r switch
        {
            _ when r.Contains("bath") => (21.0, 23.0),
            _ when r.Contains("bed") => (17.0, 19.0),
            _ when r.Contains("kitchen") => (18.0, 20.0),
            _ when r.Contains("hall") || r.Contains("landing") => (16.0, 18.0),
            _ when r.Contains("living") || r.Contains("lounge") => (20.0, 22.0),
            _ => (19.0, 21.0),
        };

        if (isActive)
            return baseRange;

        const double inactiveOffsetC = 2.0;
        return (baseRange.Item1 - inactiveOffsetC, baseRange.Item2 - inactiveOffsetC);
    }

    private static string GetComfortGradientColor(double avgTemp, double targetMin, double targetMax)
    {
        if (avgTemp > targetMax)
        {
            var tHot = Math.Clamp((avgTemp - targetMax) / 4.0, 0.0, 1.0);
            if (tHot < 0.33)
                return "#ff7f50";
            if (tHot < 0.66)
                return "#ff4500";
            return "#b22222";
        }

        if (avgTemp < targetMin)
        {
            var tCold = Math.Clamp((targetMin - avgTemp) / 4.0, 0.0, 1.0);
            if (tCold < 0.33)
                return "#87cefa";
            if (tCold < 0.66)
                return "#00bfff";
            return "#1e3a8a";
        }

        return "#2e8b57";
    }

    private static (string Text, string Color) GetCurrentState(double currentTemp, double targetMin, double targetMax)
    {
        if (currentTemp > targetMax)
            return ("Now: too warm", "#b22222");
        if (currentTemp < targetMin)
            return ("Now: too cold", "#1e3a8a");
        return ("Now: in range", "#2e8b57");
    }

    private static string FormatTrend(double trendDelta)
    {
        if (trendDelta > 0.4)
            return $"up {trendDelta:+0.0;-0.0;0.0}C";
        if (trendDelta < -0.4)
            return $"down {trendDelta:+0.0;-0.0;0.0}C";
        return $"steady {trendDelta:+0.0;-0.0;0.0}C";
    }

    private static bool IsWithinIgnoreWindow(long timestampUtc, TimeSpan ignoreStart, TimeSpan ignoreEnd, TimeZoneInfo zone)
    {
        if (ignoreStart == ignoreEnd)
            return false;

        var localTod = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(timestampUtc), zone).TimeOfDay;
        if (ignoreStart < ignoreEnd)
            return localTod >= ignoreStart && localTod < ignoreEnd;

        return localTod >= ignoreStart || localTod < ignoreEnd;
    }

    private static string GetRoomDetailsHref(string roomName) => $"/rooms#{BuildRoomAnchorId(roomName)}";

    private static string BuildRoomAnchorId(string roomName)
    {
        var chars = roomName.Trim().ToLowerInvariant()
            .Select(static c => char.IsLetterOrDigit(c) ? c : '-')
            .ToArray();
        var normalized = new string(chars).Trim('-');
        return $"room-{(string.IsNullOrWhiteSpace(normalized) ? "unknown" : normalized)}";
    }

    private sealed record HomeRoomHeatTile(
        string Room,
        double? TempC,
        string DisplayTemp,
        string Color,
        string RangeText,
        string StatusText,
        string TrendText,
        double? TrendDeltaC,
        int StatusRank,
        double Severity,
        double SortKeyWithinBand,
        string CurrentStateText,
        string CurrentStateColor);

    private sealed record HomeFloorplanPin(
        string Room,
        double XPercent,
        double YPercent,
        string Color,
        string Label,
        string Tooltip);
}


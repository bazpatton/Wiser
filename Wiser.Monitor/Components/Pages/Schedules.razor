@page "/schedules"
@rendermode InteractiveServer

@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms

@inject MonitorOptions Options
@inject WiserHubFetch Hub
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Wiser Monitor - Schedules</PageTitle>

<MudStack Spacing="3" Class="schedules-page">
    <MudPaper Class="pa-4 page-header-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h5">
                <i class="fa-regular fa-calendar-days"></i> Schedules
            </MudText>
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Download"
                           Href="/api/export/schedules.json"
                           Class="touch-target">
                    Export JSON
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Download"
                           Href="/api/export/schedules.csv"
                           Class="touch-target">
                    Export CSV
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Color="Color.Primary"
                           Class="touch-target"
                           Disabled="@_loading"
                           OnClick="RefreshAsync">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>
        <MudText Typo="Typo.body2" Class="mt-1">
            Live schedule programs from the hub (same <code>/data/domain/</code> payload as room control). “Next change” uses hub local day/time when present.
        </MudText>
        @if (!string.IsNullOrWhiteSpace(_clockHint))
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">@_clockHint</MudText>
        }
    </MudPaper>

    <MudPaper Class="pa-3 card-soft">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-file-import"></i> Apply schedules to hub
        </MudText>
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            Export JSON first as a backup. Only user programs (schedule id below 100) are included; internal hub schedules are omitted. Each schedule is <code>PATCH</code>ed using the same JSON shape as in the export. Dry run checks parse + body size only (no hub calls). Scripts: <code>POST /api/schedules/apply?dry_run=true</code> with the same body.
        </MudAlert>
        <MudTextField T="string"
                      @bind-Value="_importJson"
                      Label="JSON"
                      Placeholder='Paste export or [ { "id": 1, "Monday": { ... } } ]'
                      Variant="Variant.Outlined"
                      Lines="14"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Code"
                      Class="schedule-import-field" />
        <MudStack Row="true" Spacing="2" Class="mt-2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudCheckBox T="bool"
                         @bind-Value="_dryRun"
                         Color="Color.Primary"
                         Dense="true"
                         Class="touch-control">
                Dry run (validate only — no hub PATCH)
            </MudCheckBox>
        </MudStack>
        <MudStack Row="true" Spacing="2" Class="mt-2" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Outlined"
                       HtmlTag="label"
                       for="@_importFileId"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.FolderOpen"
                       Class="touch-target">
                Load file
            </MudButton>
            <InputFile id="@_importFileId"
                       OnChange="OnImportFile"
                       accept=".json,application/json"
                       class="schedule-input-file-hidden" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       StartIcon="@(_dryRun ? Icons.Material.Filled.FactCheck : Icons.Material.Filled.CloudUpload)"
                       Class="touch-target"
                       Disabled="@_applyBusy"
                       OnClick="ApplyImportAsync">
                @(_dryRun ? "Dry run" : "Apply to hub")
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Warning" Dense="true">@_error</MudAlert>
    }

    @if (_loading && _overview is null)
    {
        <MudPaper Class="pa-4 card-soft">
            <MudSkeleton Height="42px" Width="55%" Animation="Animation.Wave" Class="mb-4" />
            <MudSkeleton Height="28px" Width="90%" Animation="Animation.Wave" Class="mb-2" />
            <MudSkeleton Height="28px" Width="80%" Animation="Animation.Wave" Class="mb-2" />
            <MudSkeleton Height="240px" Animation="Animation.Wave" />
        </MudPaper>
    }
    else if (_overview is not null)
    {
        <MudPaper Class="pa-3 card-soft">
            <MudText Typo="Typo.h6" Class="mb-2">By room</MudText>
            @if (_overview.RoomRows.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No rooms in hub payload.</MudAlert>
            }
            else
            {
                <MudTable T="HubRoomScheduleRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_overview.RoomRows">
                    <HeaderContent>
                        <MudTh>Room</MudTh>
                        <MudTh>Schedule</MudTh>
                        <MudTh>Next change</MudTh>
                        <MudTh>Today</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Room">@context.RoomName</MudTd>
                        <MudTd DataLabel="Schedule">@LabelSchedule(context.ScheduleId)</MudTd>
                        <MudTd DataLabel="Next change">@context.NextChangeText</MudTd>
                        <MudTd DataLabel="Today">@context.TimelineTodayText</MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>

        <MudPaper Class="pa-3 card-soft">
            <MudText Typo="Typo.h6" Class="mb-2">Schedule programs</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                Full week for each program. Rooms sharing the same <strong>Schedule id</strong> use the same timeline.
            </MudText>
            @if (_overview.Programs.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">No schedule definitions in hub payload.</MudAlert>
            }
            else
            {
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var prog in _overview.Programs.OrderBy(p => p.ScheduleId))
                    {
                        <MudExpansionPanel Text="@ProgramTitle(prog)">
                            <MudSimpleTable Dense="true" Class="schedule-week-table" Style="overflow-x: auto;">
                                <tbody>
                                @foreach (var day in prog.Days)
                                {
                                    <tr>
                                        <td class="schedule-day-cell"><strong>@day.DayName</strong></td>
                                        <td>@day.TimelineText</td>
                                    </tr>
                                }
                                </tbody>
                            </MudSimpleTable>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
        </MudPaper>
    }
</MudStack>

@code {
    private readonly string _importFileId = $"sched-json-{Guid.NewGuid():N}";
    private HubSchedulesOverview? _overview;
    private bool _loading = true;
    private bool _applyBusy;
    private bool _dryRun = true;
    private string _importJson = "";
    private string? _error;
    private string? _clockHint;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            using var doc = await Hub.FetchDomainDocumentAsync(Options, CancellationToken.None);
            _overview = HubSchedulesParser.ParseOverview(doc);
            _clockHint = _overview.ClockHint;
        }
        catch (Exception ex)
        {
            _error = $"Could not load schedules: {ex.Message}";
            _overview = null;
            _clockHint = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnImportFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
            return;
        try
        {
            using var stream = file.OpenReadStream(2_000_000);
            using var reader = new StreamReader(stream);
            _importJson = await reader.ReadToEndAsync();
            Snackbar.Add($"Loaded {file.Name}", Severity.Info);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read file: {ex.Message}", Severity.Error);
        }
    }

    private async Task ApplyImportAsync()
    {
        if (string.IsNullOrWhiteSpace(_importJson))
        {
            Snackbar.Add("Paste JSON or load a file first.", Severity.Warning);
            return;
        }

        _applyBusy = true;
        try
        {
            if (!_dryRun)
            {
                var confirm = await DialogService.ShowMessageBoxAsync(
                    "Apply schedules to hub?",
                    "This will PATCH each schedule on the Wiser hub. Export a JSON backup first.",
                    yesText: "Apply",
                    noText: null,
                    cancelText: "Cancel");
                if (confirm is not true)
                    return;
            }

            using var doc = JsonDocument.Parse(_importJson);
            var result = await Hub.ApplySchedulesFromImportAsync(Options, doc, _dryRun, CancellationToken.None);
            if (result.Succeeded)
            {
                if (result.DryRun)
                {
                    var sizes = result.Summaries is { Count: > 0 }
                        ? string.Join(", ", result.Summaries.Select(s => $"#{s.ScheduleId} ({s.PatchBodyBytes} B)"))
                        : string.Join(", ", result.AppliedScheduleIds.Select(static id => $"#{id}"));
                    Snackbar.Add($"Dry run OK — would PATCH {result.AppliedScheduleIds.Count} schedule(s): {sizes}", Severity.Info);
                }
                else
                {
                    Snackbar.Add($"Applied schedule id(s): {string.Join(", ", result.AppliedScheduleIds)}", Severity.Success);
                    await RefreshAsync();
                }

                return;
            }

            var msg = result.FailedScheduleId is int sid
                ? $"Schedule #{sid}: {result.ErrorMessage}"
                : result.ErrorMessage ?? "Apply failed.";
            Snackbar.Add((_dryRun ? "Dry run failed: " : "") + msg, Severity.Error);
        }
        catch (JsonException ex)
        {
            Snackbar.Add($"Invalid JSON: {ex.Message}", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _applyBusy = false;
        }
    }

    private static string LabelSchedule(int scheduleId)
    {
        if (scheduleId <= 0)
            return "—";
        return scheduleId >= HubScheduleIdPolicy.FirstInternalScheduleId
            ? $"#{scheduleId} (hub)"
            : $"#{scheduleId}";
    }

    private static string ProgramTitle(HubScheduleProgram prog)
    {
        var rooms = prog.RoomNames.Count > 0
            ? string.Join(", ", prog.RoomNames)
            : "unused in current room list";
        return $"Schedule #{prog.ScheduleId} · {rooms}";
    }
}

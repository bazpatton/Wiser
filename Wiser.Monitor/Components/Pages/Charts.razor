@page "/charts"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@using MudBlazor.Charts
@using MudBlazor.Services

@inject TemperatureStore Store
@inject MonitorOptions Options
@inject IBrowserViewportService Viewport
@inject WiserHubFetch Hub
@inject RoomsLiveDataCache RoomsCache

<PageTitle>Wiser Monitor - Charts</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4 page-header-card" id="data-quality">
        <MudText Typo="Typo.h5">
            <i class="fa-solid fa-chart-line"></i> Charts
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Compare room temperature, target, valve demand, and optional outdoor data.
        </MudText>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-2">
            <MudTooltip Text="Sensor readings rejected in the last 24h (invalid scale, missing temp, etc.). Open Charts → Data quality for detail.">
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">
                    Dropped invalid readings (24h): @_qualityTotal24h
                </MudChip>
            </MudTooltip>
            @foreach (var rc in _qualityReasons24h)
            {
                <MudTooltip Text="Breakdown of why samples were dropped.">
                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
                        @($"{rc.Reason}: {rc.Count}")
                    </MudChip>
                </MudTooltip>
            }
        </MudStack>
    </MudPaper>

    <MudTabs Rounded="true" Border="true" ApplyEffectsToContainer="true" Class="charts-page-tabs">
    <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
    <MudStack Spacing="2">
    <MudPaper Class="pa-3 chart-card">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-grip"></i> Current room temperatures and trend status
        </MudText>
        @if (_roomTiles.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">No heatmap data yet.</MudAlert>
        }
        else
        {
            <div class="room-heat-grid">
                @foreach (var tile in _roomTiles)
                {
                    <a class="room-heat-tile room-heat-link"
                       style="background-color:@tile.Color;"
                       href="@GetRoomDetailsHref(tile.Room)"
                       title="@($"Open {tile.Room} in Rooms")">
                        <div class="room-heat-name">
                            <span class="room-heat-state-square" style="background-color:@tile.CurrentStateColor;" title="@tile.CurrentStateText"></span>
                            @tile.Room
                        </div>
                        <div class="room-heat-temp">
                            @tile.DisplayTemp
                        </div>
                        <div class="room-heat-meta">@tile.RangeText</div>
                        <div class="room-heat-meta">@tile.StatusText</div>
                        <div class="room-heat-meta">@tile.TrendText</div>
                    </a>
                }
            </div>
        }
    </MudPaper>

    <MudPaper Class="pa-3 chart-card" id="rooms-calling-heat-trend">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-fire-flame-curved"></i> 24-hour temperature — rooms calling for heat
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
            Same room set and history window as <strong>Selected room trend</strong>: measured °C and valve demand % where the hub reported it.
            Rooms qualify if they had valve/output demand or a poll with heating active (see daily <strong>Heat demand est. min</strong>).
            Time axis uses your configured display timezone, matching other charts.
        </MudText>
        @if (_heatCallingHasAnyPlottedSeries && _heatCallingRoomPickerNames.Count > 0)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-1">
                Tap a room to hide it from <strong>both</strong> charts below (outlined = hidden).
            </MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3 align-center">
                @foreach (var name in _heatCallingRoomPickerNames)
                {
                    var hidden = _heatCallingHiddenRooms.Contains(name);
                    <MudChip T="string"
                             Text="@name"
                             Color="@(hidden ? Color.Default : Color.Primary)"
                             Variant="@(hidden ? Variant.Outlined : Variant.Filled)"
                             Icon="@(hidden ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                             OnClick="@(() => ToggleHeatCallingRoomVisibility(name))" />
                }
                @if (_heatCallingHiddenRooms.Count > 0)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="ClearHeatCallingHiddenRooms">
                        Show all
                    </MudButton>
                }
            </MudStack>
        }
        @if (!_heatCallingHasAnyPlottedSeries)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No qualifying rooms in the last 24 hours (no heating-active polls and no per-room demand), or no samples yet.
            </MudAlert>
        }
        else if (!HeatCallingAnyRoomVisible)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                All rooms are hidden. Tap a grey chip above to show one again, or <strong>Show all</strong>.
            </MudAlert>
        }
        else
        {
            @if (_heatCallingTempTsSeries.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    No plottable room temperature in this window (check sensor data quality).
                </MudAlert>
            }
            else
            {
            <MudText Typo="Typo.subtitle2" Class="mb-1">Room temperature (°C)</MudText>
            <MudChart T="double"
                      ChartType="ChartType.Timeseries"
                      ChartSeries="_heatCallingTempTsSeries"
                      ChartOptions="_heatCallingTempTsOptions"
                      Width="100%"
                      Height="260px"
                      MatchBoundsToSize="true"
                      Class="charts-heat-calling-ts mb-4" />
            }
            <MudText Typo="Typo.subtitle2" Class="mb-1">Valve demand (%)</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1 d-block">
                Legend matches the room chips. A flat line at 0% usually means no percentage-demand samples for that TRV in this window.
            </MudText>
            @if (_heatCallingValveTsSeries.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                    No valve series to plot.
                </MudAlert>
            }
            else
            {
                <MudChart T="double"
                          ChartType="ChartType.Timeseries"
                          ChartSeries="_heatCallingValveTsSeries"
                          ChartOptions="_heatCallingValveTsOptions"
                          Width="100%"
                          Height="260px"
                          MatchBoundsToSize="true"
                          Class="charts-heat-calling-ts" />
            }
        }
    </MudPaper>
    </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Room trends" Icon="@Icons.Material.Filled.ShowChart">
    <MudStack Spacing="2">
    <MudPaper Class="pa-3 card-soft charts-toolbar">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-wave-square"></i> Room trend chart
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="5">
                <MudTooltip Text="Choose a room to update the trend chart.">
                    <MudSelect T="string"
                               Label="Room"
                               Value="_selectedRoom"
                               ValueChanged="OnRoomChanged"
                               FullWidth="true"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                               Class="touch-control">
                        @foreach (var room in _rooms)
                        {
                            <MudSelectItem Value="@room">@room</MudSelectItem>
                        }
                    </MudSelect>
                </MudTooltip>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="int"
                           Label="Window"
                           Value="_hours"
                           ValueChanged="OnHoursChanged"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Margin="Margin.Dense"
                           Class="touch-control">
                    <MudSelectItem Value="12">12 hours</MudSelectItem>
                    <MudSelectItem Value="24">24 hours</MudSelectItem>
                    <MudSelectItem Value="48">48 hours</MudSelectItem>
                    <MudSelectItem Value="168">7 days</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="2" Class="d-flex align-center charts-outdoor-wrap">
                <MudCheckBox T="bool"
                             Label="Include outdoor"
                             Value="_includeOutdoor"
                             ValueChanged="OnOutdoorChanged"
                             Class="touch-control" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-stretch">
                <MudTooltip Text="Reload all chart data from the database for the selected window.">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               FullWidth="true"
                               Class="touch-target charts-refresh-btn"
                               OnClick="LoadChartAsync">
                        Refresh
                    </MudButton>
                </MudTooltip>
            </MudItem>
        </MudGrid>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-2">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@LastUpdatedText</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Href="@DailySummaryCsvHref">
                Export daily CSV
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Href="@RoomTrendsCsvHref">
                Export trends CSV
            </MudButton>
        </MudStack>
    </MudPaper>

    @* Room trend + compliance: half width each from md up (toolbar stays full width above). *@
    <MudGrid Spacing="2" Class="charts-two-col-row charts-line-pair-row">
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper id="selected-room-trend" Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-chart-area"></i> Selected room trend
                </MudText>
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                else if (_roomTrendTempSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No chart data yet.</MudAlert>
                }
                else
                {
                    <MudStack Spacing="2" Class="selected-room-trend-stack">
                        @if (RoomTrendToggleChipsVisible)
                        {
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                                @foreach (var name in RoomTrendToggleableNamesPresent)
                                {
                                    var hidden = _roomTrendHiddenSeries.Contains(name);
                                    <MudChip T="string"
                                             Text="@name"
                                             Color="@(hidden ? Color.Default : Color.Primary)"
                                             Variant="@(hidden ? Variant.Text : Variant.Filled)"
                                             OnClick="@(() => ToggleRoomTrendSeriesVisibility(name))" />
                                }
                                @if (_roomTrendHiddenSeries.Count > 0)
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="ClearRoomTrendHiddenSeries">
                                        Show all
                                    </MudButton>
                                }
                            </MudStack>
                        }
                        @if (!RoomTrendAnyTempSeriesVisible)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                                All temperature lines are hidden. Tap a grey chip to show one again, or <strong>Show all</strong>.
                            </MudAlert>
                        }
                        else
                        {
                        <MudText Typo="Typo.subtitle2" Class="mb-0">Room temperature &amp; target (°C)</MudText>
                        <MudChart T="double"
                                  ChartType="ChartType.Line"
                                  ChartSeries="_roomTrendTempSeries"
                                  ChartLabels="_labels"
                                  ChartOptions="_roomTrendTempLineOptions"
                                  Width="100%"
                                  Height="200px"
                                  MatchBoundsToSize="false"
                                  Class="@($"{ChartHostClass} chart-in-split-row selected-room-trend-chart")"
                                  @key="@($"temp-{_roomTrendChartRenderKey}")" />
                        }
                        <MudText Typo="Typo.subtitle2" Class="mb-0 mt-1">Valve demand (%)</MudText>
                        @if (!_roomTrendHasValveSeries)
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                                No valve percentage samples in this window (older data or TRV without PercentageDemand).
                            </MudAlert>
                        }
                        else
                        {
                            <MudChart T="double"
                                      ChartType="ChartType.Line"
                                      ChartSeries="_roomTrendValveSeries"
                                      ChartLabels="_labels"
                                      ChartOptions="_roomTrendValveLineOptions"
                                      Width="100%"
                                      Height="200px"
                                      MatchBoundsToSize="false"
                                      Class="@($"{ChartHostClass} chart-in-split-row selected-room-trend-chart")"
                                      @key="@($"valve-{_roomTrendChartRenderKey}")" />
                        }
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-calendar-check"></i> Comfort Compliance Timeline (7 days)
                </MudText>
                @if (_comfortComplianceLabels.Length == 0 || _comfortComplianceSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No compliance data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Line"
                              ChartSeries="_comfortComplianceSeries"
                              ChartLabels="_comfortComplianceLabels"
                              ChartOptions="_comfortComplianceLineOptions"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="mud-chart-responsive chart-in-split-row" />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Bar charts side-by-side from md breakpoint up (similar vertical scale, saves vertical scroll). *@
    <MudGrid Spacing="2" Class="charts-two-col-row">
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-sliders"></i> Current Deviation Chart (vs target midpoint)
                </MudText>
                @if (_currentDeviationLabels.Length == 0 || _currentDeviationSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No deviation data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Bar"
                              ChartSeries="_currentDeviationSeries"
                              ChartLabels="_currentDeviationLabels"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="mud-chart-responsive mud-chart-responsive--pair" />
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-clock"></i> Heating Runtime Distribution (local hour of day)
                </MudText>
                @if (_runtimeDistributionLabels.Length == 0 || _runtimeDistributionSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No heating runtime data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Bar"
                              ChartSeries="_runtimeDistributionSeries"
                              ChartLabels="_runtimeDistributionLabels"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="mud-chart-responsive mud-chart-responsive--pair" />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="2" Class="charts-two-col-row">
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-gauge-high"></i> Per-room efficiency score
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                    Estimated as positive room temperature gain (°C) per boiler relay-on minute in the selected window.
                    Lower or negative values can indicate underperforming emitters or heat loss.
                </MudText>
                @if (_roomEfficiencyRows.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No efficiency rows yet.</MudAlert>
                }
                else
                {
                    <MudTable T="RoomEfficiencyRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_roomEfficiencyRows">
                        <HeaderContent>
                            <MudTh>Room</MudTh>
                            <MudTh Class="text-right">Score (°C/min)</MudTh>
                            <MudTh Class="text-right">Temp gain (°C)</MudTh>
                            <MudTh Class="text-right">Relay min</MudTh>
                            <MudTh>Note</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Room">@context.Room</MudTd>
                            <MudTd DataLabel="Score" Class="text-right">@Fmt(context.ScoreCPerRelayMinute)</MudTd>
                            <MudTd DataLabel="Temp gain" Class="text-right">@Fmt(context.PositiveTempGainC)</MudTd>
                            <MudTd DataLabel="Relay min" Class="text-right">@Fmt(context.RelayMinutes)</MudTd>
                            <MudTd DataLabel="Note">@context.Note</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-arrows-rotate"></i> Boiler cycle health
                </MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                    Short-cycle estimate from relay on/off transitions in poll data. Very short runs can indicate inefficiency.
                </MudText>
                @if (_boilerCycleSummary is null)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No boiler cycle data in this window.</MudAlert>
                }
                else
                {
                    <MudGrid Spacing="1">
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Cycles</MudText>
                            <MudText Typo="Typo.body1">@_boilerCycleSummary.TotalCycles</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Short cycles</MudText>
                            <MudText Typo="Typo.body1">@_boilerCycleSummary.ShortCycles</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Short ratio</MudText>
                            <MudText Typo="Typo.body1">@_boilerCycleSummary.ShortCycleRatioText</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Threshold</MudText>
                            <MudText Typo="Typo.body1">@($"{_boilerCycleSummary.ShortCycleThresholdMin} min")</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Shortest</MudText>
                            <MudText Typo="Typo.body1">@Fmt(_boilerCycleSummary.ShortestCycleMinutes)</MudText>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Median</MudText>
                            <MudText Typo="Typo.body1">@Fmt(_boilerCycleSummary.MedianCycleMinutes)</MudText>
                        </MudItem>
                    </MudGrid>
                    @if (_boilerCycleSummary.ShortCycleRatio >= 0.35)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                            High short-cycling ratio in this window.
                        </MudAlert>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
    </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Daily summary" Icon="@Icons.Material.Filled.TableChart">
    <MudPaper Class="pa-4 table-card">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-table"></i> Daily summary (energy proxies)
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
            Sort and filter columns. Values are estimates from hub poll activity and outdoor samples.
        </MudText>
        <MudDataGrid T="DailySummaryRow"
                     Items="@_dailyRows"
                     Dense="true"
                     Hover="true"
                     Filterable="true"
                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                     SortMode="SortMode.Multiple"
                     Breakpoint="Breakpoint.Sm"
                     RowsPerPage="20"
                     Class="daily-summary-grid">
            <Columns>
                <PropertyColumn Property="x => x.Date" Title="Date (Local)" Sortable="true" />
                <TemplateColumn Title="HDD" Sortable="true" SortBy="@(x => x.Hdd)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@FmtOpt(context.Item.Hdd)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Avg outdoor °C" Sortable="true" SortBy="@(x => x.AvgOutdoorC)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@FmtOpt(context.Item.AvgOutdoorC)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Heat demand est. min" Sortable="true" SortBy="@(x => x.HeatingActiveEstimateMin)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@Fmt(context.Item.HeatingActiveEstimateMin)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Boiler relay est. min" Sortable="true" SortBy="@(x => x.HeatingRelayEstimateMin)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@Fmt(context.Item.HeatingRelayEstimateMin)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.OutdoorSamples" Title="Outdoor samples" Sortable="true" />
            </Columns>
        </MudDataGrid>
    </MudPaper>
    </MudTabPanel>

    <MudTabPanel Text="Gas vs heating" Icon="@Icons.Material.Filled.LocalFireDepartment">
        <MudPaper Class="pa-4 table-card">
            <MudText Typo="Typo.h6" Class="mb-2">
                <i class="fa-solid fa-fire-flame-curved"></i> Weekly estimated gas vs heating proxies
            </MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
                Gas cost uses a <strong>prepayment (credit) meter</strong>: <strong>credit used</strong> = older reading − newer reading; cost = used × <strong>1000</strong> × (Amount ÷ Vol Credit) from the <strong>latest receipt only</strong> — historical tariffs are not applied. Top-ups (reading goes up) are skipped for spend.
                Each interval is booked to the <strong>ISO week of the later reading</strong> (local time).
                HDD needs <strong>Open-Meteo</strong> outdoor data (lat/lon in settings); otherwise HDD stays blank.
            </MudText>
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="12" sm="6" md="4">
                    <MudSelect T="int"
                               Label="Weeks to show"
                               Value="_gasWeeksToShow"
                               ValueChanged="OnGasWeeksChanged"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                               Class="touch-control">
                        @for (var w = 4; w <= 16; w++)
                        {
                            var weeksOption = w;
                            <MudSelectItem Value="@weeksOption">@weeksOption weeks</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            @if (!_gasWeekHasReceipt)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Add a gas receipt with Vol Credit and Amount on the Gas meter page to estimate weekly spend.
                </MudAlert>
            }
            @if (_gasWeekReadingPairs < 1)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                    At least two meter readings are needed to attribute gas use to weeks.
                </MudAlert>
            }
            @if (_gasWeekRows.Count == 0)

    private const int HeatCallingTrendHours = 24;

    private DateTime TsToHeatChartDateTime(long tsUtc) =>
        TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(tsUtc), DisplayZone).DateTime;

    private static bool IsPlausibleHeatChartTemp(double tempC) => tempC is > -45 and < 75;

    /// <summary>
    /// MudChart timeseries draws straight segments only; a short moving average softens jagged poll-to-poll noise.
    /// </summary>
    private static List<(DateTime T, double Y)> SmoothHeatCallingTemperatureSeries(IReadOnlyList<(DateTime T, double Y)> pts, int window = 5)
    {
        if (pts.Count < 3)
            return [.. pts];
        var n = pts.Count;
        var half = window / 2;
        var result = new List<(DateTime T, double Y)>(n);
        for (var i = 0; i < n; i++)
        {
            var lo = Math.Max(0, i - half);
            var hi = Math.Min(n - 1, i + half);
            double sum = 0;
            var c = 0;
            for (var j = lo; j <= hi; j++)
            {
                sum += pts[j].Y;
                c++;
            }
            result.Add((pts[i].T, sum / c));
        }
        return result;
    }

    /// <summary>
    /// Valve demand series: keep 0% samples between peaks, but omit leading idle before the first &gt;0
    /// and trailing idle after the first 0% following the last &gt;0 (so the line does not span the full 24h at 0).
    /// </summary>
    private static List<(DateTime T, double Y)> TrimValveDemandWindowForChart(IReadOnlyList<(DateTime T, double Y)> pts)
    {
        if (pts.Count == 0)
            return [];

        var first = -1;
        for (var i = 0; i < pts.Count; i++)
        {
            if (pts[i].Y > 0)
            {
                first = i;
                break;
            }
        }

        if (first < 0)
            return [];

        var lastPos = -1;
        for (var i = pts.Count - 1; i >= first; i--)
        {
            if (pts[i].Y > 0)
            {
                lastPos = i;
                break;
            }
        }

        var end = lastPos;
        for (var i = lastPos + 1; i < pts.Count; i++)
        {
            end = i;
            if (pts[i].Y == 0)
                break;
        }

        return pts.Skip(first).Take(end - first + 1).ToList();
    }

    /// <summary>
    /// Extends plotted points to <paramref name="ws"/>..<paramref name="we"/> so multi-room charts share the same time domain (aligned with temperature).
    /// </summary>
    private static List<(DateTime T, double Y)> ExpandHeatCallingTempToWindow(IReadOnlyList<(DateTime T, double Y)> pts, DateTime ws, DateTime we)
    {
        if (pts.Count == 0)
            return [];
        var list = pts.ToList();
        if (list[0].T > ws)
            list.Insert(0, (ws, list[0].Y));
        if (list[^1].T < we)
            list.Add((we, list[^1].Y));
        return list;
    }

    /// <summary>Core valve samples (trimmed active window when possible); empty if there are no % samples at all.</summary>
    private static List<(DateTime T, double Y)> ValveCorePointsForHeatChart(IReadOnlyList<(DateTime T, double Y)> valvePairsFull)
    {
        var trimmed = TrimValveDemandWindowForChart(valvePairsFull);
        if (trimmed.Count > 0)
            return trimmed;
        return valvePairsFull.Count > 0 ? [.. valvePairsFull] : [];
    }

    /// <summary>
    /// Valve % is held between hub polls until the next sample. Expand to step segments so MudChart
    /// draws horizontal-then-vertical moves instead of long diagonals between sparse points.
    /// Rooms with no % samples get a flat 0% segment across the history window (legend parity only).
    /// </summary>
    private static List<(DateTime T, double Y)> BuildHeatCallingValvePlotPoints(
        IReadOnlyList<(DateTime T, double Y)> core,
        DateTime ws,
        DateTime we)
    {
        if (core.Count == 0)
            return [(ws, 0.0), (we, 0.0)];
        return ValvePercentToStepSeries(core);
    }

    private static List<(DateTime T, double Y)> ValvePercentToStepSeries(IReadOnlyList<(DateTime T, double Y)> core)
    {
        if (core.Count == 0)
            return [];
        if (core.Count == 1)
            return [core[0]];

        var list = new List<(DateTime T, double Y)>(core.Count * 2) { core[0] };
        for (var i = 1; i < core.Count; i++)
        {
            var prev = core[i - 1];
            var curr = core[i];
            if (curr.T < prev.T)
                continue;
            if (curr.T == prev.T)
            {
                list[^1] = curr;
                continue;
            }

            list.Add((curr.T, prev.Y));
            list.Add(curr);
        }

        return list;
    }

    /// <summary>
    /// Multi-room 24h view: same per-room series as <see cref="LoadChartAsync"/> (temp + valve %), using MudChart timeseries (DateTime X).
    /// </summary>
    private void BuildHeatCallingRoomsTimeseries(long sinceTsUtc)
    {
        var qualifying = Store.ListRoomsCallingHeatSince(sinceTsUtc);
        if (qualifying.Count == 0)
            return;

        var qualifyingSet = new HashSet<string>(qualifying, StringComparer.OrdinalIgnoreCase);
        _heatCallingHiddenRooms.IntersectWith(qualifyingSet);

        var orderedRooms = qualifying
            .Select(room => (Room: room, Rows: Store.SeriesRoom(room, sinceTsUtc)))
            .Where(x => x.Rows.Count > 0)
            .OrderBy(x => x.Room, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (orderedRooms.Count == 0)
            return;

        _heatCallingRoomPickerNames = [.. orderedRooms.Select(static x => x.Room)];

        DateTime ws = DateTime.MaxValue;
        DateTime we = DateTime.MinValue;
        foreach (var (_, rows) in orderedRooms)
        {
            foreach (var r in rows)
            {
                var t = TsToHeatChartDateTime(r.Ts);
                if (t < ws)
                    ws = t;
                if (t > we)
                    we = t;
            }
        }

        if (we <= ws)
            we = ws.AddMinutes(1);

        var tempSeries = new List<ChartSeries<double>>(orderedRooms.Count);
        var valveSeries = new List<ChartSeries<double>>(orderedRooms.Count);

        foreach (var (room, rows) in orderedRooms)
        {
            var visible = !_heatCallingHiddenRooms.Contains(room);
            var dedup = rows.GroupBy(static r => r.Ts).Select(static g => g.Last()).ToList();

            var tempPairsRaw = dedup
                .Where(r => IsPlausibleHeatChartTemp(r.TempC))
                .Select(r => (TsToHeatChartDateTime(r.Ts), r.TempC))
                .OrderBy(x => x.Item1)
                .ToList();

            if (tempPairsRaw.Count > 0)
            {
                var tempSmoothed = SmoothHeatCallingTemperatureSeries(tempPairsRaw);
                var tempPairs = ExpandHeatCallingTempToWindow(tempSmoothed, ws, we);
                tempSeries.Add(new ChartSeries<double>
                {
                    Name = room,
                    Visible = visible,
                    Data = tempPairs,
                    TooltipYValueFormat = "F1",
                    TooltipTitleFormat = "{{SERIES_NAME}}",
                    TooltipSubtitleFormat = "{{Y_VALUE}} °C",
                });
            }

            var valvePairsFull = dedup
                .Where(static r => r.PercentageDemand.HasValue)
                .Select(r => (TsToHeatChartDateTime(r.Ts), (double)r.PercentageDemand!.Value))
                .OrderBy(x => x.Item1)
                .ToList();

            var valveCore = ValveCorePointsForHeatChart(valvePairsFull);
            var valvePairs = BuildHeatCallingValvePlotPoints(valveCore, ws, we);

            valveSeries.Add(new ChartSeries<double>
            {
                Name = room,
                Visible = visible,
                Data = valvePairs,
                TooltipYValueFormat = "F0",
                TooltipTitleFormat = "{{SERIES_NAME}}",
                TooltipSubtitleFormat = "{{Y_VALUE}} %",
            });
        }

        _heatCallingTempTsSeries = tempSeries;
        _heatCallingValveTsSeries = valveSeries;
        _heatCallingHasAnyPlottedSeries = tempSeries.Count > 0 || valveSeries.Count > 0;

        var estPoints = orderedRooms.Sum(x => x.Rows.Count);
        var showMarkers = estPoints <= 200 && !_compactChartAxes;
        _heatCallingTempTsOptions.ShowDataMarkers = showMarkers;
        _heatCallingValveTsOptions.ShowDataMarkers = showMarkers;
    }

    private void ToggleHeatCallingRoomVisibility(string room)
    {
        if (_heatCallingHiddenRooms.Contains(room))
            _heatCallingHiddenRooms.Remove(room);
        else
            _heatCallingHiddenRooms.Add(room);

        ApplyHeatCallingSeriesVisibility();
    }

    private void ClearHeatCallingHiddenRooms()
    {
        _heatCallingHiddenRooms.Clear();
        ApplyHeatCallingSeriesVisibility();
    }

    private void ApplyHeatCallingSeriesVisibility()
    {
        foreach (var s in _heatCallingTempTsSeries)
            s.Visible = !_heatCallingHiddenRooms.Contains(s.Name);

        foreach (var s in _heatCallingValveTsSeries)
            s.Visible = !_heatCallingHiddenRooms.Contains(s.Name);

        StateHasChanged();
    }

    private double ResolveDisplayTempC(string room, double storedTempC)
    {
        if (_liveHubByRoom is not null
            && _liveHubByRoom.TryGetValue(room, out var live)
            && !LiveHubRoomTemps.IsUnavailableTemp(live.TempC))
            return live.TempC;
        return storedTempC;
    }

    private void BuildRoomHeatMap(long sinceTs)
    {
        if (_rooms.Count == 0)
            return;

        var activityMap = Store.GetRoomActivityMap();
        _roomIsActiveMap = activityMap;
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();
        _roomTiles.Clear();
        var tiles = new List<RoomHeatTile>(_rooms.Count);

        foreach (var room in _rooms)
        {
            var isActive = !activityMap.TryGetValue(room, out var activeFlag) || activeFlag;
            var rows = Store.SeriesRoom(room, sinceTs);
            if (rows.Count == 0)
            {
                var (missingMin, missingMax) = GetRecommendedTempRange(room, isActive);
                tiles.Add(new RoomHeatTile(
                    room,
                    null,
                    "—",
                    "#334155",
                    $"Recommended {missingMin:0.#} - {missingMax:0.#}C",
                    $"No data in selected period{(isActive ? string.Empty : ", inactive profile")}",
                    "Trend unavailable",
                    null,
                    -1,
                    0,
                    0,
                    "Current state unavailable",
                    "#94a3b8"));
                continue;
            }

            var storedCurrent = rows[^1].TempC;
            var displayTemp = ResolveDisplayTempC(room, storedCurrent);
            var trendRows = rows
                .Where(x => !IsWithinIgnoreWindow(x.Ts, ignoreStart, ignoreEnd, DisplayZone))
                .ToList();
            if (trendRows.Count == 0)
            {
                var (missingMin, missingMax) = GetRecommendedTempRange(room, isActive);
                var bandColor = ComfortColors.GetGradientColor(displayTemp, missingMin, missingMax);
                var (cst, csc) = ComfortColors.GetCurrentState(displayTemp, missingMin, missingMax);
                tiles.Add(new RoomHeatTile(
                    room,
                    displayTemp,
                    $"{displayTemp:0.0}C",
                    bandColor,
                    $"Recommended {missingMin:0.#} - {missingMax:0.#}C",
                    $"No trend data outside ignored window{(isActive ? string.Empty : ", inactive profile")}",
                    $"Ignored {ignoreStart:hh\\:mm}-{ignoreEnd:hh\\:mm}",
                    null,
                    -1,
                    0,
                    0,
                    cst,
                    csc));
                continue;
            }

            var average = trendRows.Average(static x => x.TempC);
            var trendDelta = trendRows[^1].TempC - trendRows[0].TempC;

            var (rangeMin, rangeMax) = GetRecommendedTempRange(room, isActive);
            var status = average < rangeMin
                ? "Too cold"
                : average > rangeMax
                    ? "Too hot"
                    : "In range";
            var statusRank = status switch
            {
                "Too hot" => 2,
                "In range" => 1,
                _ => 0,
            };
            var severity = status switch
            {
                "Too hot" => average - rangeMax,
                "Too cold" => rangeMin - average,
                _ => Math.Abs(average - ((rangeMin + rangeMax) / 2.0)),
            };
            var sortKeyWithinBand = status == "Too cold" ? severity : -severity;

            var color = ComfortColors.GetGradientColor(displayTemp, rangeMin, rangeMax);
            var (currentStateText, currentStateColor) = ComfortColors.GetCurrentState(displayTemp, rangeMin, rangeMax);
            tiles.Add(new RoomHeatTile(
                room,
                displayTemp,
                $"{displayTemp:0.0}C",
                color,
                $"Recommended {rangeMin:0.#} - {rangeMax:0.#}C",
                $"{status} (avg {average:0.0}C over {_hours}h){(isActive ? string.Empty : ", inactive profile")}",
                $"Trend {FormatTrend(trendDelta)}",
                trendDelta,
                statusRank,
                severity,
                sortKeyWithinBand,
                currentStateText,
                currentStateColor));
        }

        _roomTiles.AddRange(tiles
            .OrderByDescending(static x => x.StatusRank)
            .ThenBy(static x => x.SortKeyWithinBand)
            .ThenByDescending(static x => x.TrendDeltaC.HasValue)
            .ThenByDescending(static x => x.TrendDeltaC)
            .ThenBy(static x => RoomDisplayPriority.KindOrder(x.Room))
            .ThenBy(static x => x.Room, StringComparer.OrdinalIgnoreCase));
    }

    private void BuildComfortComplianceTimeline(int days)
    {
        days = Math.Clamp(days, 1, 31);
        if (_rooms.Count == 0)
            return;

        var activityMap = Store.GetRoomActivityMap();
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();
        var zone = DisplayZone;
        var todayLocal = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, zone).Date;
        var labels = new string[days];
        var values = new double[days];
        var hasAnySample = false;

        for (var i = 0; i < days; i++)
        {
            var day = todayLocal.AddDays(-(days - 1 - i));
            labels[i] = day.ToString("ddd d", CultureInfo.CurrentCulture);

            var start = new DateTimeOffset(day, zone.GetUtcOffset(day)).ToUnixTimeSeconds();
            var next = day.AddDays(1);
            var end = new DateTimeOffset(next, zone.GetUtcOffset(next)).ToUnixTimeSeconds();

            var inRangeCount = 0;
            var totalCount = 0;
            foreach (var room in _rooms)
            {
                var isActive = !activityMap.TryGetValue(room, out var activeFlag) || activeFlag;
                var (targetMin, targetMax) = GetRecommendedTempRange(room, isActive);
                var rows = Store.SeriesRoom(room, start)
                    .Where(x => x.Ts < end)
                    .Where(x => !IsWithinIgnoreWindow(x.Ts, ignoreStart, ignoreEnd, zone));
                foreach (var row in rows)
                {
                    hasAnySample = true;
                    totalCount++;
                    if (row.TempC >= targetMin && row.TempC <= targetMax)
                        inRangeCount++;
                }
            }

            values[i] = totalCount == 0 ? double.NaN : inRangeCount * 100.0 / totalCount;
        }

        if (!hasAnySample)
            return;

        FillComplianceNaNGapsForLineChart(values);

        _comfortComplianceLabels = labels;
        _comfortComplianceSeries =
        [
            new ChartSeries<double>
            {
                Name = "Comfort compliance %",
                Data = values,
            },
        ];
    }

    /// <summary>Mud line charts break Y scaling / splines when points are NaN; bridge gaps for display (no samples that day).</summary>
    private static void FillComplianceNaNGapsForLineChart(double[] values)
    {
        double? last = null;
        for (var i = 0; i < values.Length; i++)
        {
            if (!double.IsNaN(values[i]))
                last = values[i];
            else if (last is { } lv)
                values[i] = lv;
        }

        double? next = null;
        for (var i = values.Length - 1; i >= 0; i--)
        {
            if (!double.IsNaN(values[i]))
                next = values[i];
            else if (next is { } nv)
                values[i] = nv;
        }
    }

    private void BuildCurrentDeviationChart()
    {
        if (_roomTiles.Count == 0)
            return;

        var labels = _roomTiles.Select(static t => t.Room).ToArray();
        var values = _roomTiles
            .Select(t =>
            {
                if (t.TempC is null)
                    return double.NaN;
                var isActive = !_roomIsActiveMap.TryGetValue(t.Room, out var activeFlag) || activeFlag;
                var (targetMin, targetMax) = GetRecommendedTempRange(t.Room, isActive);
                var targetMid = (targetMin + targetMax) / 2.0;
                return t.TempC.Value - targetMid;
            })
            .ToArray();

        _currentDeviationLabels = labels;
        _currentDeviationSeries =
        [
            new ChartSeries<double>
            {
                Name = "Deviation °C (+ warm / - cold)",
                Data = values,
            },
        ];
    }

    private void BuildHeatingRuntimeDistribution()
    {
        var systemRows = _systemRowsWindow;
        if (systemRows.Count == 0)
            return;

        var minutesByHour = new double[24];
        var minutesPerSample = Math.Max(10, Options.IntervalSec) / 60.0;
        var zone = DisplayZone;

        foreach (var row in systemRows)
        {
            if (row.HeatingRelayOn == 0)
                continue;
            var hour = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(row.Ts), zone).Hour;
            minutesByHour[hour] += minutesPerSample;
        }

        _runtimeDistributionLabels = Enumerable.Range(0, 24)
            .Select(static h => h.ToString("00", CultureInfo.InvariantCulture))
            .ToArray();
        _runtimeDistributionSeries =
        [
            new ChartSeries<double>
            {
                Name = $"Relay runtime minutes ({_hours}h window)",
                Data = minutesByHour,
            },
        ];
    }

    private void BuildRoomEfficiencyScores(long sinceTs)
    {
        _roomEfficiencyRows.Clear();
        var relayMinutes = _systemRowsWindow.Count(static x => x.HeatingRelayOn != 0) * (Math.Max(10, Options.IntervalSec) / 60.0);
        foreach (var room in _rooms)
        {
            var rows = Store.SeriesRoom(room, sinceTs);
            if (rows.Count < 2)
                continue;
            double positiveGain = 0;
            for (var i = 1; i < rows.Count; i++)
            {
                var delta = rows[i].TempC - rows[i - 1].TempC;
                if (delta > 0)
                    positiveGain += delta;
            }

            var score = relayMinutes > 0 ? positiveGain / relayMinutes : double.NaN;
            var note = relayMinutes switch
            {
                <= 0 => "No relay-on samples in window",
                < 30 => "Low confidence (little relay runtime)",
                _ when positiveGain <= 0 => "No positive gain observed",
                _ => "OK",
            };
            _roomEfficiencyRows.Add(new RoomEfficiencyRow(room, score, positiveGain, relayMinutes, note));
        }

        _roomEfficiencyRows.Sort(static (a, b) => b.ScoreCPerRelayMinute.CompareTo(a.ScoreCPerRelayMinute));
    }

    private void BuildBoilerCycleHealth()
    {
        _boilerCycleSummary = null;
        if (_systemRowsWindow.Count < 2)
            return;

        var durationsMin = new List<double>();
        long? cycleStartTs = null;
        var previousOn = _systemRowsWindow[0].HeatingRelayOn != 0;
        if (previousOn)
            cycleStartTs = _systemRowsWindow[0].Ts;

        for (var i = 1; i < _systemRowsWindow.Count; i++)
        {
            var row = _systemRowsWindow[i];
            var isOn = row.HeatingRelayOn != 0;
            if (!previousOn && isOn)
            {
                cycleStartTs = row.Ts;
            }
            else if (previousOn && !isOn && cycleStartTs is { } start)
            {
                var durationMin = Math.Max(0, (row.Ts - start) / 60.0);
                if (durationMin > 0)
                    durationsMin.Add(durationMin);
                cycleStartTs = null;
            }

            previousOn = isOn;
        }

        if (durationsMin.Count == 0)
            return;

        durationsMin.Sort();
        var shortCycles = durationsMin.Count(x => x < ShortCycleThresholdMinutes);
        var ratio = shortCycles / (double)durationsMin.Count;
        var median = durationsMin.Count % 2 == 1
            ? durationsMin[durationsMin.Count / 2]
            : (durationsMin[(durationsMin.Count / 2) - 1] + durationsMin[durationsMin.Count / 2]) / 2.0;

        _boilerCycleSummary = new BoilerCycleSummary(
            durationsMin.Count,
            shortCycles,
            ratio,
            $"{ratio * 100:0.#}%",
            ShortCycleThresholdMinutes,
            durationsMin[0],
            median);
    }

    private void LoadDailyRows()
    {
        _dailyRows.Clear();
        _dailyRows.AddRange(
            Store.GetDailySummaries(14, Math.Max(10, Options.IntervalSec), DisplayZone)
                .OrderByDescending(static x => x.Date, StringComparer.Ordinal));
    }

    private static string Fmt(double value) => double.IsNaN(value) ? "—" : value.ToString("0.0");
    private static string FmtOpt(double? value) => value is null || double.IsNaN(value.Value) ? "—" : value.Value.ToString("0.0");
    private static (double Min, double Max) GetRecommendedTempRange(string roomName, bool isActive)
    {
        var r = roomName.ToLowerInvariant();
        var baseRange = r switch
        {
            _ when r.Contains("bath") => (21.0, 23.0),
            _ when r.Contains("bed") => (17.0, 19.0),
            _ when r.Contains("kitchen") => (18.0, 20.0),
            _ when r.Contains("hall") || r.Contains("landing") => (16.0, 18.0),
            _ when r.Contains("living") || r.Contains("lounge") => (20.0, 22.0),
            _ => (19.0, 21.0),
        };

        if (isActive)
            return baseRange;

        const double inactiveOffsetC = 2.0;
        return (baseRange.Item1 - inactiveOffsetC, baseRange.Item2 - inactiveOffsetC);
    }

    private static string FormatTrend(double trendDelta)
    {
        if (trendDelta > 0.4)
            return $"up {trendDelta:+0.0;-0.0;0.0}C";
        if (trendDelta < -0.4)
            return $"down {trendDelta:+0.0;-0.0;0.0}C";
        return $"steady {trendDelta:+0.0;-0.0;0.0}C";
    }

    private static bool IsWithinIgnoreWindow(long timestampUtc, TimeSpan ignoreStart, TimeSpan ignoreEnd, TimeZoneInfo zone)
    {
        if (ignoreStart == ignoreEnd)
            return false;

        var localTod = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(timestampUtc), zone).TimeOfDay;
        if (ignoreStart < ignoreEnd)
            return localTod >= ignoreStart && localTod < ignoreEnd;

        // Overnight window e.g. 22:00 -> 06:00
        return localTod >= ignoreStart || localTod < ignoreEnd;
    }

    private static string GetRoomDetailsHref(string roomName) => RoomLinkHelper.RoomsPagePath(roomName);

    private sealed record RoomHeatTile(
        string Room,
        double? TempC,
        string DisplayTemp,
        string Color,
        string RangeText,
        string StatusText,
        string TrendText,
        double? TrendDeltaC,
        int StatusRank,
        double Severity,
        double SortKeyWithinBand,
        string CurrentStateText,
        string CurrentStateColor);

    private sealed record RoomEfficiencyRow(
        string Room,
        double ScoreCPerRelayMinute,
        double PositiveTempGainC,
        double RelayMinutes,
        string Note);

    private sealed record BoilerCycleSummary(
        int TotalCycles,
        int ShortCycles,
        double ShortCycleRatio,
        string ShortCycleRatioText,
        double ShortCycleThresholdMin,
        double ShortestCycleMinutes,
        double MedianCycleMinutes);
}


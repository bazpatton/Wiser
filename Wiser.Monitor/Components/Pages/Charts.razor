@page "/charts"
@rendermode InteractiveServer
@using System.Globalization
@using MudBlazor.Charts

@inject TemperatureStore Store
@inject MonitorOptions Options

<PageTitle>Wiser Monitor - Charts</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4 page-header-card" id="data-quality">
        <MudText Typo="Typo.h5">
            <i class="fa-solid fa-chart-line"></i> Charts
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Compare room temperature, target, valve demand, and optional outdoor data.
        </MudText>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-2">
            <MudTooltip Text="Sensor readings rejected in the last 24h (invalid scale, missing temp, etc.). Open Charts → Data quality for detail.">
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">
                    Dropped invalid readings (24h): @_qualityTotal24h
                </MudChip>
            </MudTooltip>
            @foreach (var rc in _qualityReasons24h)
            {
                <MudTooltip Text="Breakdown of why samples were dropped.">
                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
                        @($"{rc.Reason}: {rc.Count}")
                    </MudChip>
                </MudTooltip>
            }
        </MudStack>
    </MudPaper>

    <MudTabs Rounded="true" Border="true" ApplyEffectsToContainer="true" Class="charts-page-tabs">
    <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
    <MudStack Spacing="2">
    <MudPaper Class="pa-3 chart-card">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-grip"></i> Current room temperatures and trend status
        </MudText>
        @if (_roomTiles.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">No heatmap data yet.</MudAlert>
        }
        else
        {
            <div class="room-heat-grid">
                @foreach (var tile in _roomTiles)
                {
                    <a class="room-heat-tile room-heat-link"
                       style="background-color:@tile.Color;"
                       href="@GetRoomDetailsHref(tile.Room)"
                       title="@($"Open {tile.Room} in Rooms")">
                        <div class="room-heat-name">
                            <span class="room-heat-state-square" style="background-color:@tile.CurrentStateColor;" title="@tile.CurrentStateText"></span>
                            @tile.Room
                        </div>
                        <div class="room-heat-temp">
                            @tile.DisplayTemp
                        </div>
                        <div class="room-heat-meta">@tile.RangeText</div>
                        <div class="room-heat-meta">@tile.StatusText</div>
                        <div class="room-heat-meta">@tile.TrendText</div>
                    </a>
                }
            </div>
        }
    </MudPaper>

    <MudPaper Class="pa-3 chart-card" id="rooms-calling-heat-trend">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-fire-flame-curved"></i> 24-hour temperature — rooms calling for heat
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
            Same room set and history window as <strong>Selected room trend</strong>: measured °C and valve demand % where the hub reported it.
            Rooms qualify if they had valve/output demand or a poll with heating active (see daily <strong>Heat demand est. min</strong>).
            Time axis uses your configured display timezone, matching other charts.
        </MudText>
        @if (!_heatCallingHasAnyPlottedSeries)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No qualifying rooms in the last 24 hours (no heating-active polls and no per-room demand), or no samples yet.
            </MudAlert>
        }
        else
        {
            @if (_heatCallingTempTsSeries.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    No plottable room temperature in this window (check sensor data quality).
                </MudAlert>
            }
            else
            {
            <MudText Typo="Typo.subtitle2" Class="mb-1">Room temperature (°C)</MudText>
            <MudChart T="double"
                      ChartType="ChartType.Timeseries"
                      ChartSeries="_heatCallingTempTsSeries"
                      ChartOptions="_heatCallingTempTsOptions"
                      Width="100%"
                      MatchBoundsToSize="true"
                      Class="mud-chart-responsive mb-4" />
            }
            <MudText Typo="Typo.subtitle2" Class="mb-1">Valve demand (%)</MudText>
            @if (!_heatCallingHasValveSeries)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0">
                    No valve percentage samples in this window for these rooms (older data or TRVs without PercentageDemand).
                </MudAlert>
            }
            else
            {
                <MudChart T="double"
                          ChartType="ChartType.Timeseries"
                          ChartSeries="_heatCallingValveTsSeries"
                          ChartOptions="_heatCallingValveTsOptions"
                          Width="100%"
                          MatchBoundsToSize="true"
                          Class="mud-chart-responsive" />
            }
        }
    </MudPaper>
    </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Room trends" Icon="@Icons.Material.Filled.ShowChart">
    <MudStack Spacing="2">
    <MudPaper Class="pa-3 card-soft charts-toolbar">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-wave-square"></i> Room trend chart
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudTooltip Text="Type to filter when you have many rooms.">
                    <MudAutocomplete T="string"
                                     Label="Room"
                                     Value="_selectedRoom"
                                     ValueChanged="OnRoomChanged"
                                     SearchFunc="SearchRoomsAsync"
                                     CoerceText="true"
                                     ResetValueOnEmptyText="true"
                                     Variant="Variant.Outlined"
                                     Dense="true"
                                     Margin="Margin.Dense"
                                     Class="touch-control"
                                     Immediate="true"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     AdornmentColor="Color.Default" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="int"
                           Label="Window"
                           Value="_hours"
                           ValueChanged="OnHoursChanged"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Margin="Margin.Dense"
                           Class="touch-control">
                    <MudSelectItem Value="12">12 hours</MudSelectItem>
                    <MudSelectItem Value="24">24 hours</MudSelectItem>
                    <MudSelectItem Value="48">48 hours</MudSelectItem>
                    <MudSelectItem Value="168">7 days</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="3" Class="d-flex align-center charts-outdoor-wrap">
                <MudCheckBox T="bool"
                             Label="Include outdoor"
                             Value="_includeOutdoor"
                             ValueChanged="OnOutdoorChanged"
                             Class="touch-control" />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-stretch">
                <MudTooltip Text="Reload all chart data from the database for the selected window.">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               FullWidth="true"
                               Class="touch-target charts-refresh-btn"
                               OnClick="LoadChartAsync">
                        Refresh
                    </MudButton>
                </MudTooltip>
            </MudItem>
        </MudGrid>
        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-2">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@LastUpdatedText</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Href="@DailySummaryCsvHref">
                Export daily CSV
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Href="@RoomTrendsCsvHref">
                Export trends CSV
            </MudButton>
        </MudStack>
    </MudPaper>

    @* Room trend + compliance: half width each from md up (toolbar stays full width above). *@
    <MudGrid Spacing="2" Class="charts-two-col-row charts-line-pair-row">
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-chart-area"></i> Selected room trend
                </MudText>
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
                }
                else if (_series.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No chart data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Line"
                              ChartSeries="_series"
                              ChartLabels="_labels"
                              ChartOptions="_lineOptions"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="@($"{ChartHostClass} chart-in-split-row")">
                        <TooltipTemplate>
                            @{
                                var path = context.Segment;
                                var i = path.Index;
                                var when = i >= 0 && i < _pointTs.Length
                                    ? TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(_pointTs[i]), DisplayZone).ToString("g", CultureInfo.CurrentCulture)
                                    : path.LabelXValue;
                            }
                            <rect x="-76" y="-30" width="152" height="34" rx="6" ry="6" fill="#0f172ae6" stroke="#334155" stroke-width="1" />
                            <text x="0" y="-16" text-anchor="middle" fill="#f8fafc" style="font-size:11px;font-weight:600">@when</text>
                            <text x="0" y="-2" text-anchor="middle" fill="#cbd5e1" style="font-size:10px">@path.LabelYValue</text>
                        </TooltipTemplate>
                    </MudChart>
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-calendar-check"></i> Comfort Compliance Timeline (7 days)
                </MudText>
                @if (_comfortComplianceLabels.Length == 0 || _comfortComplianceSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No compliance data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Line"
                              ChartSeries="_comfortComplianceSeries"
                              ChartLabels="_comfortComplianceLabels"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="mud-chart-responsive chart-in-split-row" />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Bar charts side-by-side from md breakpoint up (similar vertical scale, saves vertical scroll). *@
    <MudGrid Spacing="2" Class="charts-two-col-row">
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-sliders"></i> Current Deviation Chart (vs target midpoint)
                </MudText>
                @if (_currentDeviationLabels.Length == 0 || _currentDeviationSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No deviation data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Bar"
                              ChartSeries="_currentDeviationSeries"
                              ChartLabels="_currentDeviationLabels"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="mud-chart-responsive mud-chart-responsive--pair" />
                }
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6" Class="charts-grid-cell">
            <MudPaper Class="pa-3 chart-card charts-grid-paper">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <i class="fa-solid fa-clock"></i> Heating Runtime Distribution (local hour of day)
                </MudText>
                @if (_runtimeDistributionLabels.Length == 0 || _runtimeDistributionSeries.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">No heating runtime data yet.</MudAlert>
                }
                else
                {
                    <MudChart T="double"
                              ChartType="ChartType.Bar"
                              ChartSeries="_runtimeDistributionSeries"
                              ChartLabels="_runtimeDistributionLabels"
                              Width="100%"
                              MatchBoundsToSize="true"
                              Class="mud-chart-responsive mud-chart-responsive--pair" />
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
    </MudStack>
    </MudTabPanel>

    <MudTabPanel Text="Daily summary" Icon="@Icons.Material.Filled.TableChart">
    <MudPaper Class="pa-4 table-card">
        <MudText Typo="Typo.h6" Class="mb-2">
            <i class="fa-solid fa-table"></i> Daily summary (energy proxies)
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
            Sort and filter columns. Values are estimates from hub poll activity and outdoor samples.
        </MudText>
        <MudDataGrid T="DailySummaryRow"
                     Items="@_dailyRows"
                     Dense="true"
                     Hover="true"
                     Filterable="true"
                     FilterMode="DataGridFilterMode.ColumnFilterRow"
                     SortMode="SortMode.Multiple"
                     Breakpoint="Breakpoint.Sm"
                     RowsPerPage="20"
                     Class="daily-summary-grid">
            <Columns>
                <PropertyColumn Property="x => x.Date" Title="Date (Local)" Sortable="true" />
                <TemplateColumn Title="HDD" Sortable="true" SortBy="@(x => x.Hdd)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@FmtOpt(context.Item.Hdd)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Avg outdoor °C" Sortable="true" SortBy="@(x => x.AvgOutdoorC)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@FmtOpt(context.Item.AvgOutdoorC)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Heat demand est. min" Sortable="true" SortBy="@(x => x.HeatingActiveEstimateMin)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@Fmt(context.Item.HeatingActiveEstimateMin)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Boiler relay est. min" Sortable="true" SortBy="@(x => x.HeatingRelayEstimateMin)">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="text-right">@Fmt(context.Item.HeatingRelayEstimateMin)</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.OutdoorSamples" Title="Outdoor samples" Sortable="true" />
            </Columns>
        </MudDataGrid>
    </MudPaper>
    </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private List<string> _rooms = [];
    private string _selectedRoom = string.Empty;
    private int _hours = 24;
    private bool _includeOutdoor = true;
    private string? _error;
    private DateTimeOffset? _lastRefreshAt;
    private int _qualityTotal24h;
    private List<DataQualityReasonCount> _qualityReasons24h = [];

    private string[] _labels = [];
    private long[] _pointTs = [];
    private List<ChartSeries<double>> _series = [];
    private List<ChartSeries<double>> _heatCallingTempTsSeries = [];
    private List<ChartSeries<double>> _heatCallingValveTsSeries = [];
    private bool _heatCallingHasValveSeries;
    private bool _heatCallingHasAnyPlottedSeries;
    private readonly TimeSeriesChartOptions _heatCallingTempTsOptions = new()
    {
        InterpolationOption = InterpolationOption.Straight,
        ShowToolTips = true,
        TimeLabelFormat = "HH:mm",
        TimeLabelSpacing = TimeSpan.FromMinutes(30),
        TooltipTimeLabelFormat = "g",
        XAxisTitle = "Time (local, last 24h)",
        YAxisTitle = "°C",
    };
    private readonly TimeSeriesChartOptions _heatCallingValveTsOptions = new()
    {
        InterpolationOption = InterpolationOption.Straight,
        ShowToolTips = true,
        TimeLabelFormat = "HH:mm",
        TimeLabelSpacing = TimeSpan.FromMinutes(30),
        TooltipTimeLabelFormat = "g",
        XAxisTitle = "Time (local, last 24h)",
        YAxisTitle = "Valve %",
        YAxisSuggestedMax = 100,
        YAxisRequireZeroPoint = true,
        YAxisTicks = 20,
    };
    private readonly List<RoomHeatTile> _roomTiles = [];
    private readonly List<DailySummaryRow> _dailyRows = [];
    private string[] _comfortComplianceLabels = [];
    private List<ChartSeries<double>> _comfortComplianceSeries = [];
    private string[] _currentDeviationLabels = [];
    private List<ChartSeries<double>> _currentDeviationSeries = [];
    private string[] _runtimeDistributionLabels = [];
    private List<ChartSeries<double>> _runtimeDistributionSeries = [];
    private Dictionary<string, bool> _roomIsActiveMap = new(StringComparer.OrdinalIgnoreCase);
    private readonly LineChartOptions _lineOptions = new()
    {
        InterpolationOption = InterpolationOption.Straight,
        ShowToolTips = true,
    };

    private string ChartHostClass => _hours >= 168
        ? "mud-chart-responsive chart-range-long"
        : _hours > 24
            ? "mud-chart-responsive chart-range-medium"
            : "mud-chart-responsive";
    private string LastUpdatedText => _lastRefreshAt is null
        ? "Last updated: never"
        : $"Last updated: {_lastRefreshAt.Value:HH:mm:ss} ({(int)Math.Max(0, (DateTimeOffset.Now - _lastRefreshAt.Value).TotalSeconds)}s ago)";
    private string DailySummaryCsvHref => "/api/export/daily-summary.csv?days=14";
    private string RoomTrendsCsvHref => $"/api/export/room-trends.csv?hours={_hours}";
    private TimeZoneInfo DisplayZone => TimeZoneResolver.Resolve(Options.TimeZoneId);

    protected override async Task OnInitializedAsync()
    {
        LoadRooms();
        LoadDailyRows();
        await LoadChartAsync();
    }

    private void LoadRooms()
    {
        _rooms = Store.ListRooms().OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList();
        if (_rooms.Count > 0 &&
            (string.IsNullOrWhiteSpace(_selectedRoom) || !_rooms.Contains(_selectedRoom, StringComparer.OrdinalIgnoreCase)))
        {
            _selectedRoom = _rooms[0];
        }
    }

    private Task OnRoomChanged(string? room)
    {
        _selectedRoom = room ?? string.Empty;
        return LoadChartAsync();
    }

    private Task<IEnumerable<string>> SearchRoomsAsync(string value, CancellationToken cancellationToken)
    {
        cancellationToken.ThrowIfCancellationRequested();
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult<IEnumerable<string>>(_rooms);
        return Task.FromResult<IEnumerable<string>>(
            _rooms.Where(r => r.Contains(value.Trim(), StringComparison.OrdinalIgnoreCase)));
    }

    private Task OnHoursChanged(int hours)
    {
        _hours = hours;
        return LoadChartAsync();
    }

    private Task OnOutdoorChanged(bool include)
    {
        _includeOutdoor = include;
        return LoadChartAsync();
    }

    private Task LoadChartAsync()
    {
        _error = null;
        _series = [];
        _labels = [];
        _pointTs = [];
        _heatCallingTempTsSeries = [];
        _heatCallingValveTsSeries = [];
        _heatCallingHasValveSeries = false;
        _heatCallingHasAnyPlottedSeries = false;
        _roomTiles.Clear();
        _comfortComplianceLabels = [];
        _comfortComplianceSeries = [];
        _currentDeviationLabels = [];
        _currentDeviationSeries = [];
        _runtimeDistributionLabels = [];
        _runtimeDistributionSeries = [];
        _roomIsActiveMap = new(StringComparer.OrdinalIgnoreCase);

        try
        {
            var since24h = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - (HeatCallingTrendHours * 3600L);
            BuildHeatCallingRoomsTimeseries(since24h);
            LoadDataQualitySummary();

            var since = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - (_hours * 3600L);

            if (!string.IsNullOrWhiteSpace(_selectedRoom))
            {
                var roomRows = Store.SeriesRoom(_selectedRoom, since);
                if (roomRows.Count > 0)
                {
                    _pointTs = roomRows.Select(static x => x.Ts).ToArray();
                    _labels = BuildSparseTimeLabels(_pointTs, _hours, DisplayZone);
                    ApplyLineChartOptions(roomRows.Count);

                    _series =
                    [
                        new ChartSeries<double>
                        {
                            Name = "Room °C",
                            Data = roomRows.Select(static x => x.TempC).ToArray(),
                        },
                        new ChartSeries<double>
                        {
                            Name = "Heat target °C",
                            Data = roomRows.Select(x => x.SetpointC ?? double.NaN).ToArray(),
                        },
                    ];

                    if (roomRows.Any(x => x.PercentageDemand.HasValue))
                    {
                        _series.Add(new ChartSeries<double>
                        {
                            Name = "Valve demand %",
                            Data = roomRows.Select(x => x.PercentageDemand is null ? double.NaN : x.PercentageDemand.Value).ToArray(),
                        });
                    }

                    if (_includeOutdoor && Options.OpenMeteoLat is not null)
                    {
                        var alignedOutdoor = AlignOutdoor(
                            roomRows.Select(static x => x.Ts).ToArray(),
                            Store.SeriesOutdoor(since));
                        if (alignedOutdoor.Any(static x => x is not null))
                        {
                            _series.Add(new ChartSeries<double>
                            {
                                Name = "Outdoor °C",
                                Data = alignedOutdoor.Select(static x => x ?? double.NaN).ToArray(),
                            });
                        }
                    }
                }
            }

            BuildRoomHeatMap(since);
            BuildComfortComplianceTimeline(days: 7);
            BuildCurrentDeviationChart();
            BuildHeatingRuntimeDistribution();
        }
        catch (Exception ex)
        {
            _error = $"Failed loading chart data: {ex.Message}";
        }
        _lastRefreshAt = DateTimeOffset.Now;

        return Task.CompletedTask;
    }

    private void LoadDataQualitySummary()
    {
        var summary = Store.GetDataQualitySummary(24);
        _qualityTotal24h = summary.TotalIgnored;
        _qualityReasons24h = summary.ByReason.Take(4).ToList();
    }

    private void ApplyLineChartOptions(int pointCount)
    {
        _lineOptions.XAxisLabelRotation = _hours switch
        {
            <= 12 => 0,
            <= 24 => 32,
            <= 48 => 48,
            _ => 58,
        };

        _lineOptions.XAxisTitle = _hours >= 168
            ? "Time (local, ~7 days)"
            : _hours > 24
                ? "Time (local)"
                : null;

        _lineOptions.TooltipTitleFormat = "{{SERIES_NAME}}";
        _lineOptions.TooltipSubtitleFormat = "{{Y_VALUE}}";

        var manyPoints = pointCount > 200;
        _lineOptions.ShowDataMarkers = _hours <= 24 && !manyPoints;
    }

    /// <summary>
    /// Fewer x labels for long windows so MudChart does not draw overlapping timestamps. Tooltip still shows exact time.
    /// </summary>
    private static string[] BuildSparseTimeLabels(IReadOnlyList<long> timestampsUtc, int hoursWindow, TimeZoneInfo zone)
    {
        var n = timestampsUtc.Count;
        if (n == 0)
            return [];

        var maxLabels = hoursWindow switch
        {
            <= 12 => 18,
            <= 24 => 15,
            <= 48 => 12,
            <= 96 => 11,
            _ => 10,
        };
        maxLabels = Math.Clamp(maxLabels, 8, 20);
        var step = Math.Max(1, (n + maxLabels - 1) / maxLabels);

        var format = hoursWindow >= 168
            ? "MMM d"
            : hoursWindow >= 72
                ? "ddd d HH:mm"
                : hoursWindow > 24
                    ? "M/d HH:mm"
                    : "HH:mm";

        var labels = new string[n];
        for (var i = 0; i < n; i++)
        {
            var show = i == 0 || i == n - 1 || i % step == 0;
            labels[i] = show
                ? TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(timestampsUtc[i]), zone).ToString(format, CultureInfo.CurrentCulture)
                : string.Empty;
        }

        return labels;
    }

    private const int HeatCallingTrendHours = 24;

    private DateTime TsToHeatChartDateTime(long tsUtc) =>
        TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(tsUtc), DisplayZone).DateTime;

    private static bool IsPlausibleHeatChartTemp(double tempC) => tempC is > -45 and < 75;

    /// <summary>
    /// Multi-room 24h view: same per-room series as <see cref="LoadChartAsync"/> (temp + valve %), using MudChart timeseries (DateTime X).
    /// </summary>
    private void BuildHeatCallingRoomsTimeseries(long sinceTsUtc)
    {
        var qualifying = Store.ListRoomsCallingHeatSince(sinceTsUtc);
        if (qualifying.Count == 0)
            return;

        var orderedRooms = qualifying
            .Select(room => (Room: room, Rows: Store.SeriesRoom(room, sinceTsUtc)))
            .Where(x => x.Rows.Count > 0)
            .OrderBy(x => x.Room, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (orderedRooms.Count == 0)
            return;

        var tempSeries = new List<ChartSeries<double>>(orderedRooms.Count);
        var valveSeries = new List<ChartSeries<double>>(orderedRooms.Count);
        var anyValve = false;

        foreach (var (room, rows) in orderedRooms)
        {
            var dedup = rows.GroupBy(static r => r.Ts).Select(static g => g.Last()).ToList();

            var tempPairs = dedup
                .Where(r => IsPlausibleHeatChartTemp(r.TempC))
                .Select(r => (TsToHeatChartDateTime(r.Ts), r.TempC))
                .OrderBy(x => x.Item1)
                .ToList();

            if (tempPairs.Count > 0)
            {
                tempSeries.Add(new ChartSeries<double>
                {
                    Name = room,
                    Data = tempPairs,
                    TooltipYValueFormat = "F1",
                    TooltipTitleFormat = "{{SERIES_NAME}}",
                    TooltipSubtitleFormat = "{{Y_VALUE}} °C",
                });
            }

            var valvePairs = dedup
                .Where(static r => r.PercentageDemand.HasValue)
                .Select(r => (TsToHeatChartDateTime(r.Ts), (double)r.PercentageDemand!.Value))
                .OrderBy(x => x.Item1)
                .ToList();

            if (valvePairs.Count == 0)
                continue;

            anyValve = true;
            valveSeries.Add(new ChartSeries<double>
            {
                Name = room,
                Data = valvePairs,
                TooltipYValueFormat = "F0",
                TooltipTitleFormat = "{{SERIES_NAME}}",
                TooltipSubtitleFormat = "{{Y_VALUE}} %",
            });
        }

        _heatCallingTempTsSeries = tempSeries;
        _heatCallingValveTsSeries = valveSeries;
        _heatCallingHasValveSeries = anyValve;
        _heatCallingHasAnyPlottedSeries = tempSeries.Count > 0 || valveSeries.Count > 0;

        var estPoints = orderedRooms.Sum(x => x.Rows.Count);
        _heatCallingTempTsOptions.ShowDataMarkers = estPoints <= 200;
        _heatCallingValveTsOptions.ShowDataMarkers = estPoints <= 200;
    }

    private void BuildRoomHeatMap(long sinceTs)
    {
        if (_rooms.Count == 0)
            return;

        var activityMap = Store.GetRoomActivityMap();
        _roomIsActiveMap = activityMap;
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();
        _roomTiles.Clear();
        var tiles = new List<RoomHeatTile>(_rooms.Count);

        foreach (var room in _rooms)
        {
            var isActive = !activityMap.TryGetValue(room, out var activeFlag) || activeFlag;
            var rows = Store.SeriesRoom(room, sinceTs);
            if (rows.Count == 0)
            {
                var (missingMin, missingMax) = GetRecommendedTempRange(room, isActive);
                tiles.Add(new RoomHeatTile(
                    room,
                    null,
                    "—",
                    "#334155",
                    $"Recommended {missingMin:0.#} - {missingMax:0.#}C",
                    $"No data in selected period{(isActive ? string.Empty : ", inactive profile")}",
                    "Trend unavailable",
                    null,
                    -1,
                    0,
                    0,
                    "Current state unavailable",
                    "#94a3b8"));
                continue;
            }

            var current = rows[^1].TempC;
            var trendRows = rows
                .Where(x => !IsWithinIgnoreWindow(x.Ts, ignoreStart, ignoreEnd, DisplayZone))
                .ToList();
            if (trendRows.Count == 0)
            {
                var (missingMin, missingMax) = GetRecommendedTempRange(room, isActive);
                tiles.Add(new RoomHeatTile(
                    room,
                    current,
                    $"{current:0.0}C",
                    "#334155",
                    $"Recommended {missingMin:0.#} - {missingMax:0.#}C",
                    $"No trend data outside ignored window{(isActive ? string.Empty : ", inactive profile")}",
                    $"Ignored {ignoreStart:hh\\:mm}-{ignoreEnd:hh\\:mm}",
                    null,
                    -1,
                    0,
                    0,
                    "Current state unavailable",
                    "#94a3b8"));
                continue;
            }

            var average = trendRows.Average(static x => x.TempC);
            var trendDelta = trendRows[^1].TempC - trendRows[0].TempC;

            var (rangeMin, rangeMax) = GetRecommendedTempRange(room, isActive);
            var status = average < rangeMin
                ? "Too cold"
                : average > rangeMax
                    ? "Too hot"
                    : "In range";
            var statusRank = status switch
            {
                "Too hot" => 2,
                "In range" => 1,
                _ => 0,
            };
            var severity = status switch
            {
                "Too hot" => average - rangeMax,
                "Too cold" => rangeMin - average,
                _ => Math.Abs(average - ((rangeMin + rangeMax) / 2.0)),
            };
            var sortKeyWithinBand = status == "Too cold" ? severity : -severity;

            var color = GetComfortGradientColor(average, rangeMin, rangeMax);
            var (currentStateText, currentStateColor) = GetCurrentState(current, rangeMin, rangeMax);
            tiles.Add(new RoomHeatTile(
                room,
                current,
                $"{current:0.0}C",
                color,
                $"Recommended {rangeMin:0.#} - {rangeMax:0.#}C",
                $"{status} (avg {average:0.0}C over {_hours}h){(isActive ? string.Empty : ", inactive profile")}",
                $"Trend {FormatTrend(trendDelta)}",
                trendDelta,
                statusRank,
                severity,
                sortKeyWithinBand,
                currentStateText,
                currentStateColor));
        }

        _roomTiles.AddRange(tiles
            .OrderByDescending(static x => x.StatusRank)
            .ThenBy(static x => x.SortKeyWithinBand)
            .ThenByDescending(static x => x.TrendDeltaC.HasValue)
            .ThenByDescending(static x => x.TrendDeltaC)
            .ThenBy(static x => x.Room, StringComparer.OrdinalIgnoreCase));
    }

    private void BuildComfortComplianceTimeline(int days)
    {
        days = Math.Clamp(days, 1, 31);
        if (_rooms.Count == 0)
            return;

        var activityMap = Store.GetRoomActivityMap();
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();
        var zone = DisplayZone;
        var todayLocal = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, zone).Date;
        var labels = new string[days];
        var values = new double[days];

        for (var i = 0; i < days; i++)
        {
            var day = todayLocal.AddDays(-(days - 1 - i));
            labels[i] = day.ToString("ddd d", CultureInfo.CurrentCulture);

            var start = new DateTimeOffset(day, zone.GetUtcOffset(day)).ToUnixTimeSeconds();
            var next = day.AddDays(1);
            var end = new DateTimeOffset(next, zone.GetUtcOffset(next)).ToUnixTimeSeconds();

            var inRangeCount = 0;
            var totalCount = 0;
            foreach (var room in _rooms)
            {
                var isActive = !activityMap.TryGetValue(room, out var activeFlag) || activeFlag;
                var (targetMin, targetMax) = GetRecommendedTempRange(room, isActive);
                var rows = Store.SeriesRoom(room, start)
                    .Where(x => x.Ts < end)
                    .Where(x => !IsWithinIgnoreWindow(x.Ts, ignoreStart, ignoreEnd, zone));
                foreach (var row in rows)
                {
                    totalCount++;
                    if (row.TempC >= targetMin && row.TempC <= targetMax)
                        inRangeCount++;
                }
            }

            values[i] = totalCount == 0 ? double.NaN : inRangeCount * 100.0 / totalCount;
        }

        _comfortComplianceLabels = labels;
        _comfortComplianceSeries =
        [
            new ChartSeries<double>
            {
                Name = "Comfort compliance %",
                Data = values,
            },
        ];
    }

    private void BuildCurrentDeviationChart()
    {
        if (_roomTiles.Count == 0)
            return;

        var labels = _roomTiles.Select(static t => t.Room).ToArray();
        var values = _roomTiles
            .Select(t =>
            {
                if (t.TempC is null)
                    return double.NaN;
                var isActive = !_roomIsActiveMap.TryGetValue(t.Room, out var activeFlag) || activeFlag;
                var (targetMin, targetMax) = GetRecommendedTempRange(t.Room, isActive);
                var targetMid = (targetMin + targetMax) / 2.0;
                return t.TempC.Value - targetMid;
            })
            .ToArray();

        _currentDeviationLabels = labels;
        _currentDeviationSeries =
        [
            new ChartSeries<double>
            {
                Name = "Deviation °C (+ warm / - cold)",
                Data = values,
            },
        ];
    }

    private void BuildHeatingRuntimeDistribution()
    {
        var since = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - (_hours * 3600L);
        var systemRows = Store.SeriesSystem(since);
        if (systemRows.Count == 0)
            return;

        var minutesByHour = new double[24];
        var minutesPerSample = Math.Max(10, Options.IntervalSec) / 60.0;
        var zone = DisplayZone;

        foreach (var row in systemRows)
        {
            if (row.HeatingRelayOn == 0)
                continue;
            var hour = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(row.Ts), zone).Hour;
            minutesByHour[hour] += minutesPerSample;
        }

        _runtimeDistributionLabels = Enumerable.Range(0, 24)
            .Select(static h => h.ToString("00", CultureInfo.InvariantCulture))
            .ToArray();
        _runtimeDistributionSeries =
        [
            new ChartSeries<double>
            {
                Name = $"Relay runtime minutes ({_hours}h window)",
                Data = minutesByHour,
            },
        ];
    }

    private void LoadDailyRows()
    {
        _dailyRows.Clear();
        _dailyRows.AddRange(
            Store.GetDailySummaries(14, Math.Max(10, Options.IntervalSec), DisplayZone)
                .OrderByDescending(static x => x.Date, StringComparer.Ordinal));
    }

    private static double?[] AlignOutdoor(long[] timestamps, IReadOnlyList<OutdoorSeriesRow> outdoor)
    {
        if (outdoor.Count == 0)
            return new double?[timestamps.Length];

        var sorted = outdoor.OrderBy(static x => x.Ts).ToList();
        var result = new double?[timestamps.Length];
        var j = 0;
        double? last = null;
        for (var i = 0; i < timestamps.Length; i++)
        {
            var ts = timestamps[i];
            while (j < sorted.Count && sorted[j].Ts <= ts)
            {
                last = sorted[j].TempC;
                j++;
            }

            result[i] = last;
        }

        return result;
    }

    private static string Fmt(double value) => double.IsNaN(value) ? "—" : value.ToString("0.0");
    private static string FmtOpt(double? value) => value is null || double.IsNaN(value.Value) ? "—" : value.Value.ToString("0.0");
    private static (double Min, double Max) GetRecommendedTempRange(string roomName, bool isActive)
    {
        var r = roomName.ToLowerInvariant();
        var baseRange = r switch
        {
            _ when r.Contains("bath") => (21.0, 23.0),
            _ when r.Contains("bed") => (17.0, 19.0),
            _ when r.Contains("kitchen") => (18.0, 20.0),
            _ when r.Contains("hall") || r.Contains("landing") => (16.0, 18.0),
            _ when r.Contains("living") || r.Contains("lounge") => (20.0, 22.0),
            _ => (19.0, 21.0),
        };

        if (isActive)
            return baseRange;

        const double inactiveOffsetC = 2.0;
        return (baseRange.Item1 - inactiveOffsetC, baseRange.Item2 - inactiveOffsetC);
    }

    private static string GetComfortGradientColor(double avgTemp, double targetMin, double targetMax)
    {
        if (avgTemp > targetMax)
        {
            // Hot side: light orange-red -> deep red.
            var tHot = Math.Clamp((avgTemp - targetMax) / 4.0, 0.0, 1.0);
            if (tHot < 0.33)
                return "#ff7f50";
            if (tHot < 0.66)
                return "#ff4500";
            return "#b22222";
        }

        if (avgTemp < targetMin)
        {
            // Cold side: light ice blue -> deep cold blue.
            var tCold = Math.Clamp((targetMin - avgTemp) / 4.0, 0.0, 1.0);
            if (tCold < 0.33)
                return "#87cefa";
            if (tCold < 0.66)
                return "#00bfff";
            return "#1e3a8a";
        }

        // In-range: calm green.
        return "#2e8b57";
    }

    private static (string Text, string Color) GetCurrentState(double currentTemp, double targetMin, double targetMax)
    {
        if (currentTemp > targetMax)
            return ("Now: too warm", "#b22222");
        if (currentTemp < targetMin)
            return ("Now: too cold", "#1e3a8a");
        return ("Now: in range", "#2e8b57");
    }

    private static string FormatTrend(double trendDelta)
    {
        if (trendDelta > 0.4)
            return $"up {trendDelta:+0.0;-0.0;0.0}C";
        if (trendDelta < -0.4)
            return $"down {trendDelta:+0.0;-0.0;0.0}C";
        return $"steady {trendDelta:+0.0;-0.0;0.0}C";
    }

    private static bool IsWithinIgnoreWindow(long timestampUtc, TimeSpan ignoreStart, TimeSpan ignoreEnd, TimeZoneInfo zone)
    {
        if (ignoreStart == ignoreEnd)
            return false;

        var localTod = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(timestampUtc), zone).TimeOfDay;
        if (ignoreStart < ignoreEnd)
            return localTod >= ignoreStart && localTod < ignoreEnd;

        // Overnight window e.g. 22:00 -> 06:00
        return localTod >= ignoreStart || localTod < ignoreEnd;
    }

    private static string GetRoomDetailsHref(string roomName) => $"/rooms#{BuildRoomAnchorId(roomName)}";

    private static string BuildRoomAnchorId(string roomName)
    {
        var chars = roomName.Trim().ToLowerInvariant()
            .Select(static c => char.IsLetterOrDigit(c) ? c : '-')
            .ToArray();
        var normalized = new string(chars).Trim('-');
        return $"room-{(string.IsNullOrWhiteSpace(normalized) ? "unknown" : normalized)}";
    }

    private sealed record RoomHeatTile(
        string Room,
        double? TempC,
        string DisplayTemp,
        string Color,
        string RangeText,
        string StatusText,
        string TrendText,
        double? TrendDeltaC,
        int StatusRank,
        double Severity,
        double SortKeyWithinBand,
        string CurrentStateText,
        string CurrentStateColor);
}


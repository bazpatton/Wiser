                <MudAlert Severity="Severity.Info" Dense="true">No weekly rows to show.</MudAlert>
            }
            else
            {
                <MudTable T="GasWeekInsightRow" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Items="_gasWeekRows">
                    <HeaderContent>
                        <MudTh>Week</MudTh>
                        <MudTh Class="text-right">Est. gas (GBP)</MudTh>
                        <MudTh Class="text-right">HDD Σ</MudTh>
                        <MudTh Class="text-right">Heat est. (min)</MudTh>
                        <MudTh>Note</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Week">@context.WeekLabel</MudTd>
                        <MudTd DataLabel="Est. gas" Class="text-right">@FmtGasGbp(context.EstimatedGasGbp)</MudTd>
                        <MudTd DataLabel="HDD" Class="text-right">@FmtOpt(context.HddSum)</MudTd>
                        <MudTd DataLabel="Heat min" Class="text-right">@Fmt(context.HeatMinutesSum)</MudTd>
                        <MudTd DataLabel="Note">
                            <MudText Typo="Typo.body2">@context.Narrative</MudText>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudTabPanel>

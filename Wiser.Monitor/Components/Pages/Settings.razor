@page "/settings"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@using Wiser.Monitor.Services

@inject TemperatureStore Store
@inject MonitorOptions Options
@inject MonitorState MonitorState
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>Wiser Monitor - Settings</PageTitle>

<MudStack Spacing="3" Class="settings-page">
    <MudPaper Class="pa-4 page-header-card">
        <MudText Typo="Typo.h5">
            <i class="fa-solid fa-gear"></i> Settings
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Mark rooms as inactive to apply a lower recommended average range in charts.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-3 mb-1" Elevation="0" Outlined="true">
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Color="@(HubConfigured ? Color.Success : Color.Warning)">
                Hub @(HubConfigured ? "configured" : "not configured")
            </MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                @_settingsPollStatusText
            </MudChip>
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined"
                     Color="@(_openMeteoConfigured ? Color.Success : Color.Default)">
                Open-Meteo @(_openMeteoConfigured ? "lat/lon set" : "not set")
            </MudChip>
            @if (string.IsNullOrWhiteSpace(Options.AppPublicBaseUrl))
            {
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                    <code>APP_PUBLIC_BASE_URL</code> unset — ntfy timed-away links disabled
                </MudChip>
            }
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        <MudText Typo="Typo.subtitle1" Class="mb-2">Trend ignore window (local time)</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string"
                              Label="Ignore start"
                              Value="_ignoreStartText"
                              ValueChanged="OnIgnoreStartChanged"
                              InputType="InputType.Time"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string"
                              Label="Ignore end"
                              Value="_ignoreEndText"
                              ValueChanged="OnIgnoreEndChanged"
                              InputType="InputType.Time"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex align-center">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Default is 00:00 to 07:00. Readings in this window are excluded from room trend calculations.
                </MudText>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Gas meter reading reminders (ntfy)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Get a phone notification at chosen local times to record your gas meter. Uses the same
            <strong>ntfy</strong> topic as temperature alerts.
        </MudText>
        @if (string.IsNullOrWhiteSpace(Options.NtfyTopic))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                Set <code>NTFY_TOPIC</code> in your environment (or .env for Docker) so ntfy can deliver notifications.
            </MudAlert>
        }
        <MudStack Spacing="2">
            <MudSwitch T="bool"
                       Value="_gasReminderEnabled"
                       ValueChanged="OnGasReminderEnabledChanged"
                       Color="Color.Primary"
                       Class="touch-control"
                       Label="Enable daily reminders" />
            <MudTextField T="string"
                          Label="Reminder times (local)"
                          @bind-Value="_gasReminderTimesText"
                          Placeholder="09:00, 20:00"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          HelperText="Comma-separated HH:mm, 24-hour. Uses TIME_ZONE from your environment / Docker." />
        </MudStack>

        <MudDivider Class="my-3" />

        <div id="timed-away">
        <MudText Typo="Typo.subtitle1" Class="mb-2">Timed and smart away (whole house)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            The monitor calls hub <strong>Away</strong> with your limit temperature, then <strong>Home</strong> when the end time is reached.
            Smart auto uses Open-Meteo hourly forecasts and recent indoor data (requires <code>OPEN_METEO_LAT</code> / <code>OPEN_METEO_LON</code>).
            Pre-end ntfy reminders use the same topic as temperature alerts.
        </MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
            These options (toggle and numbers) are saved to the database as soon as you change them. The main <strong>Save</strong> button at the bottom still saves room activity, gas reminders, and heating routine.
        </MudText>
        @if (!HubConfigured)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                Configure <code>WISER_IP</code> and <code>WISER_SECRET</code> to schedule away from here.
            </MudAlert>
        }
        @if (Options.OpenMeteoLat is null || Options.OpenMeteoLon is null)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Smart auto away needs Open-Meteo coordinates in the environment.
            </MudAlert>
        }
        <MudSwitch T="bool"
                   Value="_taSmartAuto"
                   ValueChanged="OnTimedAwaySmartAutoChanged"
                   Color="Color.Primary"
                   Class="touch-control"
                   Label="Smart auto away (opt-in)" />
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="double"
                                 Value="_taAwayLimit"
                                 ValueChanged="OnTaAwayLimitChanged"
                                 Label="Away limit °C"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Step="0.5"
                                 Adornment="Adornment.End"
                                 AdornmentText="°C" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="int"
                                 Value="_taSmartDurationMin"
                                 ValueChanged="OnTaSmartDurationChanged"
                                 Label="Smart session length (min)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="30"
                                 Max="10080" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="int"
                                 Value="_taExtensionLeadMin"
                                 ValueChanged="OnTaExtensionLeadChanged"
                                 Label="Ntfy lead time (min)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="5"
                                 Max="1440" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="int"
                                 Value="_taForecastHours"
                                 ValueChanged="OnTaForecastHoursChanged"
                                 Label="Forecast horizon (h)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="1"
                                 Max="48" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="double"
                                 Value="_taMinForecastTemp"
                                 ValueChanged="OnTaMinForecastTempChanged"
                                 Label="Min outdoor °C (smart)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Step="0.5"
                                 HelperText="Arm only if hourly min in window is ≥ this" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="int"
                                 Value="_taHeatingIdlePolls"
                                 ValueChanged="OnTaHeatingIdlePollsChanged"
                                 Label="Heating idle polls"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="1"
                                 Max="50"
                                 HelperText="Consecutive polls with heating inactive" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="double"
                                 Value="_taIndoorMinAvg"
                                 ValueChanged="OnTaIndoorMinAvgChanged"
                                 Label="Min indoor avg °C"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Step="0.5" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudNumericField T="int"
                                 Value="_taSmartCooldownHours"
                                 ValueChanged="OnTaSmartCooldownChanged"
                                 Label="Smart cooldown (h)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0"
                                 Max="168" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.subtitle2" Class="mb-2 mt-3">Smart away — last check</MudText>
        @if (_taDiagnostics is null)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">No evaluation recorded yet.</MudText>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-1">
                <strong>Local time:</strong> @FormatDiagnosticsLocalTime(_taDiagnostics.EvaluatedAtUnix)
                · <strong>Outcome:</strong> @_taDiagnostics.Outcome
            </MudText>
            @if (!string.IsNullOrWhiteSpace(_taDiagnostics.SkipReason))
            {
                <MudText Typo="Typo.body2" Class="mb-1 mud-text-secondary">
                    <strong>Reason:</strong> @HumanizeTimedAwaySkipReason(_taDiagnostics.SkipReason)
                </MudText>
            }
            @if (_taDiagnostics.MinForecastC is not null || _taDiagnostics.IndoorAvgC is not null || _taDiagnostics.HeatingIdlePollCount is not null)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @FormatDiagnosticsSnapshot(_taDiagnostics)
                </MudText>
            }
            @if (!string.IsNullOrWhiteSpace(_taDiagnostics.ErrorMessage))
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@_taDiagnostics.ErrorMessage</MudAlert>
            }
        }

        <MudDivider Class="my-3" />

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="mb-1">
            <MudText Typo="Typo.subtitle2">Smart away — live trigger validation</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       Disabled="_taLiveValidationBusy"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="RefreshSmartAwayValidationAsync">
                Refresh live checks
            </MudButton>
        </MudStack>
        @if (_taLiveValidationBusy)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="rounded mb-2" />
        }
        @if (!string.IsNullOrWhiteSpace(_taLiveValidationError))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">@_taLiveValidationError</MudAlert>
        }
        else if (_taLiveValidation is null)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">No live validation yet.</MudText>
        }
        else
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Filled"
                     Color="@(_taLiveValidation.CanArm ? Color.Success : Color.Warning)"
                     Class="mb-2">
                @(_taLiveValidation.CanArm ? "Would arm now" : $"Blocked now ({HumanizeLiveReason(_taLiveValidation.Reason)})")
            </MudChip>
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                Checked @FormatDiagnosticsLocalTime(_taLiveValidation.EvaluatedAtUnix)
            </MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                @FormatLiveValidationSnapshot(_taLiveValidation)
            </MudText>
            @if (!_taLiveValidation.CanArm)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                    <MudText Typo="Typo.caption" Class="d-block mb-1"><strong>Currently blocking trigger:</strong></MudText>
                    @foreach (var failed in FailedSmartAwayChecks(_taLiveValidation))
                    {
                        <MudText Typo="Typo.caption" Class="d-block">• @failed.Label: @failed.Detail</MudText>
                    }
                </MudAlert>
            }
            <MudTable T="SmartAwayLiveCheckView" Dense="true" Elevation="0" Items="_taLiveValidation.Checks">
                <HeaderContent>
                    <MudTh>Check</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Detail</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Check">@context.Label</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="@(context.Pass ? Color.Success : Color.Warning)">
                            @(context.Pass ? "Pass" : "Fail")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Detail">@context.Detail</MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudStack Row="true" Spacing="2" Class="flex-wrap mt-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="DownloadTimedAwayPolicyAsync">
                Download policy JSON
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       HtmlTag="label"
                       for="@_timedAwayPolicyImportId"
                       StartIcon="@Icons.Material.Filled.UploadFile">
                Upload policy JSON
            </MudButton>
            <InputFile id="@_timedAwayPolicyImportId"
                       OnChange="OnTimedAwayPolicyImportAsync"
                       accept=".json,application/json"
                       class="settings-input-file-hidden" />
        </MudStack>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.subtitle2" Class="mb-2">Manual away until (local)</MudText>
        @if (_taActiveSession is not null)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Active monitor session until <strong>@FormatLocalEnds(_taActiveSession.EndsAtUnix)</strong>
                (@_taActiveSession.Source, limit @_taActiveSession.AwayLimitC.ToString("F1", CultureInfo.InvariantCulture) °C).
            </MudAlert>
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Disabled="@(!HubConfigured || _timedAwayBusy)"
                           OnClick="@(() => ExtendTimedAwayAsync(60))">
                    +1 hour
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Disabled="@(!HubConfigured || _timedAwayBusy)"
                           OnClick="@(() => ExtendTimedAwayAsync(180))">
                    +3 hours
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Disabled="@(!HubConfigured || _timedAwayBusy)"
                           OnClick="@(() => ExtendTimedAwayAsync(360))">
                    +6 hours
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Disabled="@(!HubConfigured || _timedAwayBusy)"
                           OnClick="@(() => ExtendTimedAwayAsync(540))">
                    +9 hours
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Disabled="@(!HubConfigured || _timedAwayBusy)"
                           OnClick="CancelTimedAwayAsync">
                    Cancel away (Home)
                </MudButton>
            </MudStack>
        }
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="4">
                <MudDatePicker @bind-Date="_taEndDate"
                               Label="End date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Disabled="@(!HubConfigured || _timedAwayBusy)" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudTimePicker @bind-Time="_taEndTime"
                               Label="End time"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Disabled="@(!HubConfigured || _timedAwayBusy)" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Class="touch-target"
                           Disabled="@(!HubConfigured || _timedAwayBusy)"
                           OnClick="ScheduleTimedAwayAsync">
                    Apply away until selected time
                </MudButton>
            </MudItem>
        </MudGrid>

        </div>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Heating routine (for Home savings suggestions)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Tell the app when you are usually out so Home can suggest schedule tweaks that may reduce heating costs.
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           @bind-Value="_weekdayDaytimeAway"
                           Color="Color.Primary"
                           Class="touch-control"
                           Label="Weekdays: usually away in daytime" />
                <MudStack Row="true" Spacing="2" Class="mt-1">
                    <MudTextField T="string"
                                  Label="Weekday away start"
                                  @bind-Value="_weekdayAwayStartText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                    <MudTextField T="string"
                                  Label="Weekday away end"
                                  @bind-Value="_weekdayAwayEndText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           Value="_weekendDaytimeAway"
                           ValueChanged="OnWeekendAwayChanged"
                           Color="Color.Primary"
                           Class="touch-control"
                           Label="Weekends: usually away in daytime" />
                <MudStack Row="true" Spacing="2" Class="mt-1">
                    <MudTextField T="string"
                                  Label="Weekend away start"
                                  @bind-Value="_weekendAwayStartText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                    <MudTextField T="string"
                                  Label="Weekend away end"
                                  @bind-Value="_weekendAwayEndText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudSwitch T="bool"
                           Value="_nightSetbackOk"
                           ValueChanged="OnNightSetbackOkChanged"
                           Color="Color.Primary"
                           Class="touch-control"
                           Label="Comfort setting: small night setback is acceptable" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Database backup and restore</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Download a snapshot of your SQLite history, or restore from a file created with Download backup on this or another instance.
            Restore replaces the live database; the previous file is kept in the data directory as
            <code>wiser_monitor.pre-restore-*.sqlite3</code>.
            Maximum upload size is 512&nbsp;MB.
        </MudText>
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
            Restoring overwrites current readings and settings in the database (after saving a pre-restore copy). You may need to refresh the browser.
        </MudAlert>
        <MudStack Row="true" Spacing="2" Class="flex-wrap">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Href="@Nav.ToAbsoluteUri("/api/backup/database").ToString()"
                       StartIcon="@Icons.Material.Filled.Download">
                Download backup
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Warning"
                       HtmlTag="label"
                       for="@_restoreFileId"
                       StartIcon="@Icons.Material.Filled.UploadFile"
                       Disabled="@_restoreBusy">
                Restore from file…
            </MudButton>
            <InputFile id="@_restoreFileId"
                       OnChange="OnRestoreBackupAsync"
                       accept=".sqlite3,.db,application/x-sqlite3,application/octet-stream"
                       class="settings-input-file-hidden" />
        </MudStack>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Floorplan temperature overlay</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Upload your floorplan image, then map room pins using X/Y percentages (0-100). Home will render live room temperatures
            with comfort colors on top of the image.
        </MudText>
        <MudStack Row="true" Spacing="2" Class="flex-wrap mb-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       HtmlTag="label"
                       for="@_floorplanUploadFileId"
                       StartIcon="@Icons.Material.Filled.UploadFile"
                       Disabled="@_floorplanUploadBusy">
                Upload floorplan image
            </MudButton>
            <InputFile id="@_floorplanUploadFileId"
                       OnChange="OnFloorplanImageUploadAsync"
                       accept=".png,.jpg,.jpeg,.webp,image/png,image/jpeg,image/webp"
                       class="settings-input-file-hidden" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveFloorplanMappingAsync"
                       StartIcon="@Icons.Material.Filled.Save">
                Save floorplan mapping
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="ReloadFloorplanMapping"
                       StartIcon="@Icons.Material.Filled.Refresh">
                Reload floorplan mapping
            </MudButton>
        </MudStack>
        @if (!string.IsNullOrWhiteSpace(_floorplanImageName))
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                Current image: @_floorplanImageName
            </MudText>
            <div class="settings-floorplan-preview-wrap mb-2">
                <div id="@_floorplanPreviewSurfaceId"
                     class="settings-floorplan-live-surface"
                     @onmousedown="OnFloorplanSurfaceMouseDown"
                     @onmousemove="OnFloorplanSurfaceMouseMove"
                     @onmouseup="OnFloorplanSurfaceMouseUp"
                     @onmouseleave="OnFloorplanSurfaceMouseUp">
                    <img src="@FloorplanImageHref"
                         alt="Floorplan preview"
                         class="settings-floorplan-preview"
                         draggable="false"
                         @onload="OnFloorplanPreviewImageLoaded" />
                    @foreach (var pin in _floorplanPins.Where(static p => p.Enabled))
                    {
                        <button type="button"
                                class="@($"settings-floorplan-pin {(string.Equals(_selectedFloorplanRoom, pin.Room, StringComparison.OrdinalIgnoreCase) ? "is-selected" : "")}")"
                                style="@($"left:{pin.XPercent:0.##}%;top:{pin.YPercent:0.##}%;")"
                                title="@($"{pin.Room}: {pin.XPercent:0.0}%, {pin.YPercent:0.0}%")"
                                @onmousedown="@((MouseEventArgs e) => OnFloorplanPinMouseDown(pin, e))"
                                @onmousedown:stopPropagation="true">
                            <span>@pin.Room</span>
                        </button>
                    }
                </div>
            </div>
            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
                Drag a pin directly on the preview, or select a room below and click/drag on the image to place it.
            </MudText>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                No floorplan image uploaded yet.
            </MudAlert>
        }
        @if (_floorplanPins.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No rooms available yet for pin mapping.
            </MudAlert>
        }
        else
        {
            <MudTable T="FloorplanPinSetting" Items="_floorplanPins" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Room</MudTh>
                    <MudTh>Edit</MudTh>
                    <MudTh>Show pin</MudTh>
                    <MudTh>X %</MudTh>
                    <MudTh>Y %</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Room">@context.Room</MudTd>

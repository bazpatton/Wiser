    private async Task ScheduleTimedAwayAsync()
    {
        if (_taEndDate is null || _taEndTime is null)
        {
            Snackbar.Add("Pick end date and time.", Severity.Warning);
            return;
        }

        var zone = TimeZoneResolver.Resolve(Options.TimeZoneId);
        var localWall = _taEndDate.Value.Date + _taEndTime.Value;
        var localUnspec = DateTime.SpecifyKind(localWall, DateTimeKind.Unspecified);
        var nowLocal = TimeZoneInfo.ConvertTime(DateTimeOffset.UtcNow, zone);
        if (localUnspec <= nowLocal.DateTime)
        {
            Snackbar.Add("End must be in the future (local time).", Severity.Warning);
            return;
        }

        var utc = TimeZoneInfo.ConvertTimeToUtc(localUnspec, zone);
        var unix = new DateTimeOffset(utc, TimeSpan.Zero).ToUnixTimeSeconds();
        _timedAwayBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            using var resp = await Http.PostAsJsonAsync(
                "/api/away/schedule",
                new { ends_at_unix = unix, temperature_c = _taAwayLimit });
            if (!resp.IsSuccessStatusCode)
            {
                var err = await resp.Content.ReadAsStringAsync();
                Snackbar.Add($"Schedule failed: {err}", Severity.Error);
                return;
            }

            Snackbar.Add("Away scheduled on the hub until the chosen time.", Severity.Success);
            RefreshTimedAwayActiveSessionOnly();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _timedAwayBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CancelTimedAwayAsync()
    {
        _timedAwayBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            using var resp = await Http.PostAsync("/api/away/cancel", null);
            if (!resp.IsSuccessStatusCode)
            {
                Snackbar.Add(await resp.Content.ReadAsStringAsync(), Severity.Warning);
                return;
            }

            Snackbar.Add("Away cancelled; hub set to Home.", Severity.Success);
            RefreshTimedAwayActiveSessionOnly();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _timedAwayBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExtendTimedAwayAsync(int minutes)

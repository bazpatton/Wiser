            await InvokeAsync(StateHasChanged);
        }
    }

    private void LoadFloorplanMapping(IReadOnlyList<string> rooms)
    {
        var cfg = Store.GetFloorplanConfig();
        _floorplanImageName = cfg.ImageFileName;
        _floorplanImageContentType = cfg.ImageContentType;
        _floorplanImageVersion = cfg.UpdatedTs > 0 ? cfg.UpdatedTs : DateTimeOffset.UtcNow.ToUnixTimeSeconds();

        var byRoom = cfg.Pins
            .Where(p => !string.IsNullOrWhiteSpace(p.Room))
            .ToDictionary(p => p.Room, StringComparer.OrdinalIgnoreCase);

        _floorplanPins.Clear();
        foreach (var room in rooms.OrderBy(x => x, StringComparer.OrdinalIgnoreCase))
        {
            if (byRoom.TryGetValue(room, out var pin))
            {
                _floorplanPins.Add(new FloorplanPinSetting(room, true, pin.XPercent, pin.YPercent));
            }
            else
            {
                _floorplanPins.Add(new FloorplanPinSetting(room, false, 50, 50));
            }
        }
        _selectedFloorplanRoom = _floorplanPins.FirstOrDefault(static p => p.Enabled)?.Room
            ?? _floorplanPins.FirstOrDefault()?.Room;
    }

    private async Task ReloadFloorplanMapping()
    {
        var rooms = _rooms.Select(static r => r.Room).ToList();
        LoadFloorplanMapping(rooms);
        await RefreshFloorplanPreviewSizeAsync();
        Snackbar.Add("Floorplan mapping reloaded.", Severity.Info);
    }

    private async Task SaveFloorplanMappingAsync()
    {
        var pins = _floorplanPins
            .Where(p => p.Enabled)
            .Select(p => new FloorplanRoomPin(
                p.Room,
                Math.Clamp(p.XPercent, 0, 100),
                Math.Clamp(p.YPercent, 0, 100)))
            .ToList();

        Store.SaveFloorplanConfig(new FloorplanConfig(
            _floorplanImageName,
            _floorplanImageContentType,
            0,
            pins));

        _floorplanImageVersion = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
        Snackbar.Add("Floorplan mapping saved.", Severity.Success);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnFloorplanImageUploadAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
            return;

        _floorplanUploadBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            if (file.Size <= 0)
            {
                Snackbar.Add("Please choose an image file.", Severity.Warning);
                return;
            }
            if (file.Size > MaxFloorplanUploadBytes)
            {
                Snackbar.Add($"Floorplan file is too large (max {MaxFloorplanUploadBytes / (1024 * 1024)} MB).", Severity.Warning);
                return;
            }

            var ext = Path.GetExtension(file.Name);
            if (!IsAllowedFloorplanExtension(ext))
            {
                Snackbar.Add("Unsupported image extension (allowed: .png, .jpg, .jpeg, .webp).", Severity.Warning);
                return;
            }

            var normalizedExt = NormalizeFloorplanExtension(ext);
            var generatedName = $"floorplan-{Guid.NewGuid():N}{normalizedExt}";
            var dir = Path.Combine(Path.GetFullPath(Options.DataDir), "floorplan");
            Directory.CreateDirectory(dir);
            var destPath = Path.Combine(dir, generatedName);

            await using (var stream = file.OpenReadStream(MaxFloorplanUploadBytes))
            await using (var output = File.Create(destPath))
            {
                await stream.CopyToAsync(output);
            }

            var contentType = FloorplanContentTypeFromExtension(normalizedExt);
            var current = Store.GetFloorplanConfig();
            Store.SaveFloorplanConfig(current with
            {
                ImageFileName = generatedName,
                ImageContentType = contentType,
                UpdatedTs = 0,
            });

            LoadFloorplanMapping(_rooms.Select(static r => r.Room).ToList());
            await RefreshFloorplanPreviewSizeAsync();
            Snackbar.Add("Floorplan image uploaded.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _floorplanUploadBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool IsAllowedFloorplanExtension(string? ext) =>
        ext is not null
        && (ext.Equals(".png", StringComparison.OrdinalIgnoreCase)
            || ext.Equals(".jpg", StringComparison.OrdinalIgnoreCase)
            || ext.Equals(".jpeg", StringComparison.OrdinalIgnoreCase)
            || ext.Equals(".webp", StringComparison.OrdinalIgnoreCase));

    private static string NormalizeFloorplanExtension(string? ext) =>
        ext is not null && ext.Equals(".jpeg", StringComparison.OrdinalIgnoreCase)
            ? ".jpg"
            : (ext ?? ".png").ToLowerInvariant();

    private static string FloorplanContentTypeFromExtension(string ext) =>
        ext.Equals(".png", StringComparison.OrdinalIgnoreCase)
            ? "image/png"
            : ext.Equals(".webp", StringComparison.OrdinalIgnoreCase)
                ? "image/webp"
                : "image/jpeg";

    private Task SaveAsync()
    {
        if (!TryParseTime(_ignoreStartText, out var ignoreStart) || !TryParseTime(_ignoreEndText, out var ignoreEnd))
        {
            Snackbar.Add("Please enter valid ignore times in HH:mm format.", Severity.Warning);
            return Task.CompletedTask;
        }

        if (!TryParseGasReminderTimes(_gasReminderTimesText, out var reminderTimes))
        {
            Snackbar.Add("Gas reminder times: use comma-separated HH:mm (e.g. 09:00, 20:30).", Severity.Warning);
            return Task.CompletedTask;
        }
        if (!TryParseTime(_weekdayAwayStartText, out var weekdayStart) ||
            !TryParseTime(_weekdayAwayEndText, out var weekdayEnd) ||
            !TryParseTime(_weekendAwayStartText, out var weekendStart) ||
            !TryParseTime(_weekendAwayEndText, out var weekendEnd))
        {
            Snackbar.Add("Heating routine times: use HH:mm (e.g. 09:00).", Severity.Warning);
            return Task.CompletedTask;
        }

        foreach (var room in _rooms)
            Store.SetRoomActive(room.Room, room.IsActive);
        Store.SetTrendIgnoreWindow(ignoreStart, ignoreEnd);
        Store.SetGasMeterReminderSettings(_gasReminderEnabled, reminderTimes);
        var priorityRooms = _rooms.Where(r => r.IsPriority).Select(r => r.Room).ToList();
        Store.SaveHeatingSavingsProfile(new HeatingSavingsProfile(
            _weekdayDaytimeAway,
            Math.Clamp((int)weekdayStart.TotalMinutes, 0, 1439),
            Math.Clamp((int)weekdayEnd.TotalMinutes, 0, 1439),
            _weekendDaytimeAway,
            Math.Clamp((int)weekendStart.TotalMinutes, 0, 1439),
            Math.Clamp((int)weekendEnd.TotalMinutes, 0, 1439),
            _nightSetbackOk,
            priorityRooms,
            0));
        PersistTimedAwayPolicyToStore();
        Snackbar.Add("Settings saved.", Severity.Success);
        return Task.CompletedTask;
    }

    private static string ToHm(int totalMinutes)
    {
        totalMinutes = Math.Clamp(totalMinutes, 0, 1439);
        var ts = TimeSpan.FromMinutes(totalMinutes);
        return $"{ts.Hours:D2}:{ts.Minutes:D2}";
    }


@page "/settings"
@rendermode InteractiveServer

@inject TemperatureStore Store
@inject ISnackbar Snackbar

<PageTitle>Wiser Monitor - Settings</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4 page-header-card">
        <MudText Typo="Typo.h5">
            <i class="fa-solid fa-gear"></i> Settings
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Mark rooms as inactive to apply a lower recommended average range in charts.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        @if (_rooms.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">No rooms available yet.</MudAlert>
        }
        else
        {
            <MudTable T="RoomActivitySetting" Items="_rooms" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Room</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Room">@context.Room</MudTd>
                    <MudTd DataLabel="Active">
                        <MudSwitch T="bool"
                                   Value="@context.IsActive"
                                   ValueChanged="@((value) => context.IsActive = value)"
                                   Color="Color.Primary" />
                    </MudTd>
                    <MudTd DataLabel="Status">@(context.IsActive ? "Active" : "Inactive")</MudTd>
                </RowTemplate>
            </MudTable>

            <MudStack Row="true" Spacing="1" Class="mt-3">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveAsync"
                           StartIcon="@Icons.Material.Filled.Save">
                    Save
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           OnClick="LoadAsync"
                           StartIcon="@Icons.Material.Filled.Refresh">
                    Reload
                </MudButton>
            </MudStack>
        }
    </MudPaper>
</MudStack>

@code {
    private readonly List<RoomActivitySetting> _rooms = [];

    protected override Task OnInitializedAsync() => LoadAsync();

    private Task LoadAsync()
    {
        _rooms.Clear();
        var rooms = Store.ListRooms().OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList();
        var activity = Store.GetRoomActivityMap();
        foreach (var room in rooms)
            _rooms.Add(new RoomActivitySetting(room, !activity.TryGetValue(room, out var isActive) || isActive));
        return Task.CompletedTask;
    }

    private Task SaveAsync()
    {
        foreach (var room in _rooms)
            Store.SetRoomActive(room.Room, room.IsActive);
        Snackbar.Add("Room activity settings saved.", Severity.Success);
        return Task.CompletedTask;
    }

    private sealed class RoomActivitySetting
    {
        public RoomActivitySetting(string room, bool isActive)
        {
            Room = room;
            IsActive = isActive;
        }

        public string Room { get; }
        public bool IsActive { get; set; }
    }
}

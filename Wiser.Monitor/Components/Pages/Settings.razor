            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="LoadAsync"
                       StartIcon="@Icons.Material.Filled.Refresh">
                Reload
            </MudButton>
        </MudStack>
    </MudPaper>
</MudStack>


    }

    private async Task OnRestoreBackupAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
            return;

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Replace database?",
            $"Restore from “{file.Name}”? This replaces the live database. The current file is copied aside first.",
            yesText: "Restore",
            noText: null,
            cancelText: "Cancel");
        if (confirm is not true)
            return;

        _restoreBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            await using var stream = file.OpenReadStream(TemperatureStore.MaxDatabaseRestoreBytes);
            using var content = new MultipartFormDataContent();
            content.Add(new StreamContent(stream), "file", file.Name);
            using var resp = await Http.PostAsync("api/backup/restore", content).ConfigureAwait(false);
            var body = await resp.Content.ReadAsStringAsync().ConfigureAwait(false);
            if (!resp.IsSuccessStatusCode)
            {
                await ReportRestoreErrorAsync(resp, body).ConfigureAwait(false);
                return;
            }

            Snackbar.Add("Database restored from backup.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _restoreBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReportRestoreErrorAsync(HttpResponseMessage resp, string body)
    {
        var parsed = ParseApiError(body);
        if (!string.IsNullOrWhiteSpace(parsed))
        {
            Snackbar.Add(parsed, Severity.Error);
            return;
        }

        Snackbar.Add(string.IsNullOrWhiteSpace(body) ? $"{(int)resp.StatusCode} {resp.ReasonPhrase}" : body, Severity.Error);
    }

    private static string? ParseApiError(string? body)
    {
        if (string.IsNullOrWhiteSpace(body))
            return null;
        try
        {
            using var doc = JsonDocument.Parse(body);
            var root = doc.RootElement;
            if (root.TryGetProperty("error", out var err) && err.ValueKind == JsonValueKind.String)
                return err.GetString() ?? "Request failed.";

            if (root.TryGetProperty("detail", out var detail) && detail.ValueKind == JsonValueKind.String)
                return detail.GetString() ?? "Request failed.";
        }
        catch (JsonException)
        {
            return body;
        }

        return body;
    }

    /// <summary>
    /// Parses a time-of-day from Settings fields. Browsers often send <c>HH:mm:ss</c> from
    /// <c>input type="time"</c>; we accept that plus <c>HH:mm</c> and single-digit hours.
    /// </summary>
    private static bool TryParseTime(string? text, out TimeSpan value)
    {
        value = default;
        if (string.IsNullOrWhiteSpace(text))
            return false;

        var s = text.Trim();
        if (s.Length > 0 && s[0] == 'T')
            s = s[1..].TrimStart();

        string[] formats =
        [
            @"hh\:mm",
            @"h\:mm",
            @"hh\:mm\:ss",
            @"h\:mm\:ss",
        ];
        foreach (var fmt in formats)
        {
            if (TimeSpan.TryParseExact(s, fmt, CultureInfo.InvariantCulture, out value))
                return true;
        }

        var parts = s.Split(':', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length < 2)
            return false;

        if (!int.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out var h))
            return false;
        if (!int.TryParse(parts[1], NumberStyles.Integer, CultureInfo.InvariantCulture, out var m))
            return false;
        var sec = 0;
        if (parts.Length >= 3 && !int.TryParse(parts[2], NumberStyles.Integer, CultureInfo.InvariantCulture, out sec))
            return false;

        if (h is < 0 or > 23 || m is < 0 or > 59 || sec is < 0 or > 59)
            return false;

        value = new TimeSpan(h, m, sec);
        return true;
    }

    private static bool TryParseGasReminderTimes(string? text, out List<TimeSpan> times)
    {
        times = [];
        if (string.IsNullOrWhiteSpace(text))
            return true;

        foreach (var part in text.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (!TryParseTime(part, out var t))
                return false;
            times.Add(TimeSpan.FromMinutes(Math.Clamp((int)t.TotalMinutes, 0, 1439)));
        }

        times = times.Distinct().OrderBy(x => x.TotalMinutes).ToList();
        return true;
    }


    private async Task SetFloorplanPinFromMouseAsync(string? room, MouseEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(room))
            return;

        if (_floorplanPreviewWidth <= 1 || _floorplanPreviewHeight <= 1)
            await RefreshFloorplanPreviewSizeAsync();
        if (_floorplanPreviewWidth <= 1 || _floorplanPreviewHeight <= 1)
            return;

        var row = _floorplanPins.FirstOrDefault(r => string.Equals(r.Room, room, StringComparison.OrdinalIgnoreCase));
        if (row is null)
            return;

        row.Enabled = true;
        row.XPercent = Math.Clamp((e.OffsetX / _floorplanPreviewWidth) * 100.0, 0, 100);
        row.YPercent = Math.Clamp((e.OffsetY / _floorplanPreviewHeight) * 100.0, 0, 100);
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _rooms.Clear();
        var rooms = Store.ListRooms().OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList();
        var activity = Store.GetRoomActivityMap();
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();
        _ignoreStartText = ignoreStart.ToString(@"hh\:mm", CultureInfo.InvariantCulture);
        _ignoreEndText = ignoreEnd.ToString(@"hh\:mm", CultureInfo.InvariantCulture);
        var gr = Store.GetGasMeterReminderSettings();
        _gasReminderEnabled = gr.Enabled;
        _gasReminderTimesText = string.Join(
            ", ",
            gr.Times.Select(t => $"{t.Hours:D2}:{t.Minutes:D2}"));
        var profile = Store.GetHeatingSavingsProfile();
        _weekdayDaytimeAway = profile.WeekdayDaytimeAway;
        _weekdayAwayStartText = ToHm(profile.WeekdayAwayStartMin);
        _weekdayAwayEndText = ToHm(profile.WeekdayAwayEndMin);
        _weekendDaytimeAway = profile.WeekendDaytimeAway;
        _weekendAwayStartText = ToHm(profile.WeekendAwayStartMin);
        _weekendAwayEndText = ToHm(profile.WeekendAwayEndMin);
        _nightSetbackOk = profile.NightSetbackOk;
        var prioritySet = profile.PriorityRooms.ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var room in rooms)
            _rooms.Add(new RoomActivitySetting(
                room,
                !activity.TryGetValue(room, out var isActive) || isActive,
                prioritySet.Contains(room)));
        LoadFloorplanMapping(rooms);
        var snap = MonitorState.Snapshot();
        _openMeteoConfigured = Options.OpenMeteoLat is not null && Options.OpenMeteoLon is not null;
        if (snap.LastOkUnix is null)
            _settingsPollStatusText = "Last poll: no successful poll yet";
        else
        {
            var local = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(snap.LastOkUnix.Value), DisplayZone);
            _settingsPollStatusText = $"Last poll OK: {local.ToString("g", CultureInfo.CurrentCulture)}";
        }
        if (!string.IsNullOrWhiteSpace(snap.LastError))
            _settingsPollStatusText += $" · last error: {snap.LastError}";
        LoadTimedAwayFields();
        await RefreshSmartAwayValidationAsync();
    }


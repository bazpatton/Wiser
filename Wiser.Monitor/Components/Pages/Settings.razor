@page "/settings"
@rendermode InteractiveServer
@using System.Globalization

@inject TemperatureStore Store
@inject MonitorOptions Options
@inject ISnackbar Snackbar

<PageTitle>Wiser Monitor - Settings</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="pa-4 page-header-card">
        <MudText Typo="Typo.h5">
            <i class="fa-solid fa-gear"></i> Settings
        </MudText>
        <MudText Typo="Typo.body2" Class="mt-1">
            Mark rooms as inactive to apply a lower recommended average range in charts.
        </MudText>
    </MudPaper>

    <MudPaper Class="pa-4 card-soft">
        <MudText Typo="Typo.subtitle1" Class="mb-2">Trend ignore window (local time)</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string"
                              Label="Ignore start"
                              Value="_ignoreStartText"
                              ValueChanged="OnIgnoreStartChanged"
                              InputType="InputType.Time"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField T="string"
                              Label="Ignore end"
                              Value="_ignoreEndText"
                              ValueChanged="OnIgnoreEndChanged"
                              InputType="InputType.Time"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="6" Class="d-flex align-center">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Default is 00:00 to 07:00. Readings in this window are excluded from room trend calculations.
                </MudText>
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Gas meter reading reminders (ntfy)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Get a phone notification at chosen local times to record your gas meter. Uses the same
            <strong>ntfy</strong> topic as temperature alerts.
        </MudText>
        @if (string.IsNullOrWhiteSpace(Options.NtfyTopic))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                Set <code>NTFY_TOPIC</code> in your environment (or .env for Docker) so ntfy can deliver notifications.
            </MudAlert>
        }
        <MudStack Spacing="2">
            <MudSwitch T="bool"
                       Value="_gasReminderEnabled"
                       ValueChanged="OnGasReminderEnabledChanged"
                       Color="Color.Primary"
                       Class="touch-control"
                       Label="Enable daily reminders" />
            <MudTextField T="string"
                          Label="Reminder times (local)"
                          @bind-Value="_gasReminderTimesText"
                          Placeholder="09:00, 20:00"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          HelperText="Comma-separated HH:mm, 24-hour. Uses TIME_ZONE from your environment / Docker." />
        </MudStack>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Heating routine (for Home savings suggestions)</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Tell the app when you are usually out so Home can suggest schedule tweaks that may reduce heating costs.
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           @bind-Value="_weekdayDaytimeAway"
                           Color="Color.Primary"
                           Class="touch-control"
                           Label="Weekdays: usually away in daytime" />
                <MudStack Row="true" Spacing="2" Class="mt-1">
                    <MudTextField T="string"
                                  Label="Weekday away start"
                                  @bind-Value="_weekdayAwayStartText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                    <MudTextField T="string"
                                  Label="Weekday away end"
                                  @bind-Value="_weekdayAwayEndText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudStack>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSwitch T="bool"
                           Value="_weekendDaytimeAway"
                           ValueChanged="OnWeekendAwayChanged"
                           Color="Color.Primary"
                           Class="touch-control"
                           Label="Weekends: usually away in daytime" />
                <MudStack Row="true" Spacing="2" Class="mt-1">
                    <MudTextField T="string"
                                  Label="Weekend away start"
                                  @bind-Value="_weekendAwayStartText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                    <MudTextField T="string"
                                  Label="Weekend away end"
                                  @bind-Value="_weekendAwayEndText"
                                  InputType="InputType.Time"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudStack>
            </MudItem>
            <MudItem xs="12">
                <MudSwitch T="bool"
                           Value="_nightSetbackOk"
                           ValueChanged="OnNightSetbackOkChanged"
                           Color="Color.Primary"
                           Class="touch-control"
                           Label="Comfort setting: small night setback is acceptable" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Room activity profile</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
            Active affects chart recommendation ranges. Priority marks rooms where comfort matters most for schedule suggestions.
        </MudText>
        @if (_rooms.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">No rooms available yet.</MudAlert>
        }
        else
        {
            <MudTable T="RoomActivitySetting" Items="_rooms" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Room</MudTh>
                    <MudTh>Active</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Room">@context.Room</MudTd>
                    <MudTd DataLabel="Active">
                        <MudSwitch T="bool"
                                   Value="@context.IsActive"
                                   ValueChanged="@((value) => context.IsActive = value)"
                                   Color="Color.Primary" />
                    </MudTd>
                    <MudTd DataLabel="Priority">
                        <MudSwitch T="bool"
                                   Value="@context.IsPriority"
                                   ValueChanged="@((value) => OnRoomPriorityChanged(context, value))"
                                   Color="Color.Secondary" />
                    </MudTd>
                    <MudTd DataLabel="Status">@(context.IsActive ? "Active" : "Inactive")</MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudStack Row="true" Spacing="1" Class="mt-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveAsync"
                       StartIcon="@Icons.Material.Filled.Save">
                Save
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="LoadAsync"
                       StartIcon="@Icons.Material.Filled.Refresh">
                Reload
            </MudButton>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private readonly List<RoomActivitySetting> _rooms = [];
    private string _ignoreStartText = "00:00";
    private string _ignoreEndText = "07:00";
    private bool _gasReminderEnabled;
    private string _gasReminderTimesText = "";
    private bool _weekdayDaytimeAway;
    private string _weekdayAwayStartText = "09:00";
    private string _weekdayAwayEndText = "17:00";
    private bool _weekendDaytimeAway;
    private string _weekendAwayStartText = "10:00";
    private string _weekendAwayEndText = "16:00";
    private bool _nightSetbackOk = true;

    protected override Task OnInitializedAsync() => LoadAsync();

    private Task OnGasReminderEnabledChanged(bool value)
    {
        _gasReminderEnabled = value;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnWeekdayAwayChanged(bool value)
    {
        _weekdayDaytimeAway = value;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnWeekendAwayChanged(bool value)
    {
        _weekendDaytimeAway = value;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnNightSetbackOkChanged(bool value)
    {
        _nightSetbackOk = value;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnRoomActiveChanged(RoomActivitySetting row, bool value)
    {
        row.IsActive = value;
        return InvokeAsync(StateHasChanged);
    }

    private Task OnRoomPriorityChanged(RoomActivitySetting row, bool value)
    {
        row.IsPriority = value;
        return InvokeAsync(StateHasChanged);
    }

    private Task LoadAsync()
    {
        _rooms.Clear();
        var rooms = Store.ListRooms().OrderBy(x => x, StringComparer.OrdinalIgnoreCase).ToList();
        var activity = Store.GetRoomActivityMap();
        var (ignoreStart, ignoreEnd) = Store.GetTrendIgnoreWindow();
        _ignoreStartText = ignoreStart.ToString(@"hh\:mm", CultureInfo.InvariantCulture);
        _ignoreEndText = ignoreEnd.ToString(@"hh\:mm", CultureInfo.InvariantCulture);
        var gr = Store.GetGasMeterReminderSettings();
        _gasReminderEnabled = gr.Enabled;
        _gasReminderTimesText = string.Join(
            ", ",
            gr.Times.Select(t => $"{t.Hours:D2}:{t.Minutes:D2}"));
        var profile = Store.GetHeatingSavingsProfile();
        _weekdayDaytimeAway = profile.WeekdayDaytimeAway;
        _weekdayAwayStartText = ToHm(profile.WeekdayAwayStartMin);
        _weekdayAwayEndText = ToHm(profile.WeekdayAwayEndMin);
        _weekendDaytimeAway = profile.WeekendDaytimeAway;
        _weekendAwayStartText = ToHm(profile.WeekendAwayStartMin);
        _weekendAwayEndText = ToHm(profile.WeekendAwayEndMin);
        _nightSetbackOk = profile.NightSetbackOk;
        var prioritySet = profile.PriorityRooms.ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var room in rooms)
            _rooms.Add(new RoomActivitySetting(
                room,
                !activity.TryGetValue(room, out var isActive) || isActive,
                prioritySet.Contains(room)));
        return Task.CompletedTask;
    }

    private Task SaveAsync()
    {
        if (!TryParseTime(_ignoreStartText, out var ignoreStart) || !TryParseTime(_ignoreEndText, out var ignoreEnd))
        {
            Snackbar.Add("Please enter valid ignore times in HH:mm format.", Severity.Warning);
            return Task.CompletedTask;
        }

        if (!TryParseGasReminderTimes(_gasReminderTimesText, out var reminderTimes))
        {
            Snackbar.Add("Gas reminder times: use comma-separated HH:mm (e.g. 09:00, 20:30).", Severity.Warning);
            return Task.CompletedTask;
        }
        if (!TryParseTime(_weekdayAwayStartText, out var weekdayStart) ||
            !TryParseTime(_weekdayAwayEndText, out var weekdayEnd) ||
            !TryParseTime(_weekendAwayStartText, out var weekendStart) ||
            !TryParseTime(_weekendAwayEndText, out var weekendEnd))
        {
            Snackbar.Add("Heating routine times: use HH:mm (e.g. 09:00).", Severity.Warning);
            return Task.CompletedTask;
        }

        foreach (var room in _rooms)
            Store.SetRoomActive(room.Room, room.IsActive);
        Store.SetTrendIgnoreWindow(ignoreStart, ignoreEnd);
        Store.SetGasMeterReminderSettings(_gasReminderEnabled, reminderTimes);
        var priorityRooms = _rooms.Where(r => r.IsPriority).Select(r => r.Room).ToList();
        Store.SaveHeatingSavingsProfile(new HeatingSavingsProfile(
            _weekdayDaytimeAway,
            Math.Clamp((int)weekdayStart.TotalMinutes, 0, 1439),
            Math.Clamp((int)weekdayEnd.TotalMinutes, 0, 1439),
            _weekendDaytimeAway,
            Math.Clamp((int)weekendStart.TotalMinutes, 0, 1439),
            Math.Clamp((int)weekendEnd.TotalMinutes, 0, 1439),
            _nightSetbackOk,
            priorityRooms,
            0));
        Snackbar.Add("Settings saved.", Severity.Success);
        return Task.CompletedTask;
    }

    private static string ToHm(int totalMinutes)
    {
        totalMinutes = Math.Clamp(totalMinutes, 0, 1439);
        var ts = TimeSpan.FromMinutes(totalMinutes);
        return $"{ts.Hours:D2}:{ts.Minutes:D2}";
    }

    private Task OnIgnoreStartChanged(string value)
    {
        _ignoreStartText = value;
        return Task.CompletedTask;
    }

    private Task OnIgnoreEndChanged(string value)
    {
        _ignoreEndText = value;
        return Task.CompletedTask;
    }

    /// <summary>
    /// Parses a time-of-day from Settings fields. Browsers often send <c>HH:mm:ss</c> from
    /// <c>input type="time"</c>; we accept that plus <c>HH:mm</c> and single-digit hours.
    /// </summary>
    private static bool TryParseTime(string? text, out TimeSpan value)
    {
        value = default;
        if (string.IsNullOrWhiteSpace(text))
            return false;

        var s = text.Trim();
        if (s.Length > 0 && s[0] == 'T')
            s = s[1..].TrimStart();

        string[] formats =
        [
            @"hh\:mm",
            @"h\:mm",
            @"hh\:mm\:ss",
            @"h\:mm\:ss",
        ];
        foreach (var fmt in formats)
        {
            if (TimeSpan.TryParseExact(s, fmt, CultureInfo.InvariantCulture, out value))
                return true;
        }

        var parts = s.Split(':', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length < 2)
            return false;

        if (!int.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out var h))
            return false;
        if (!int.TryParse(parts[1], NumberStyles.Integer, CultureInfo.InvariantCulture, out var m))
            return false;
        var sec = 0;
        if (parts.Length >= 3 && !int.TryParse(parts[2], NumberStyles.Integer, CultureInfo.InvariantCulture, out sec))
            return false;

        if (h is < 0 or > 23 || m is < 0 or > 59 || sec is < 0 or > 59)
            return false;

        value = new TimeSpan(h, m, sec);
        return true;
    }

    private static bool TryParseGasReminderTimes(string? text, out List<TimeSpan> times)
    {
        times = [];
        if (string.IsNullOrWhiteSpace(text))
            return true;

        foreach (var part in text.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (!TryParseTime(part, out var t))
                return false;
            times.Add(TimeSpan.FromMinutes(Math.Clamp((int)t.TotalMinutes, 0, 1439)));
        }

        times = times.Distinct().OrderBy(x => x.TotalMinutes).ToList();
        return true;
    }

    private sealed class RoomActivitySetting
    {
        public RoomActivitySetting(string room, bool isActive, bool isPriority)
        {
            Room = room;
            IsActive = isActive;
            IsPriority = isPriority;
        }

        public string Room { get; }
        public bool IsActive { get; set; }
        public bool IsPriority { get; set; }
    }
}

    private string FormatLocalEnds(long unix)
    {
        var zone = TimeZoneResolver.Resolve(Options.TimeZoneId);
        var local = TimeZoneInfo.ConvertTime(DateTimeOffset.FromUnixTimeSeconds(unix), zone);
        return local.ToString("g", CultureInfo.CurrentCulture);

                    </MudTd>
                    <MudTd DataLabel="Status">@(context.IsActive ? "Active" : "Inactive")</MudTd>
                </RowTemplate>
            </MudTable>
        }

        <MudStack Row="true" Spacing="1" Class="mt-3">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveAsync"
                       StartIcon="@Icons.Material.Filled.Save">
